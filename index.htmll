<!-- 댓글 모달 -->
<!-- ══ 인스타그램 스타일 게시물 뷰어 ══ -->
<div id="postViewer" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:3000;align-items:center;justify-content:center;padding:12px;">
  <button onclick="closePostViewer()" style="position:absolute;top:16px;right:20px;background:none;border:none;color:white;font-size:26px;cursor:pointer;z-index:1;opacity:.8;transition:.2s;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=.8">✕</button>

  <div id="postViewerInner" style="display:flex;width:100%;max-width:980px;max-height:92vh;border-radius:var(--rl);overflow:hidden;background:var(--bg2);border:1px solid var(--bd);box-shadow:0 24px 80px rgba(0,0,0,.8);">

    <!-- 왼쪽: 이미지/영상 -->
    <div id="pv-media" style="flex:0 0 60%;background:#000;display:flex;align-items:center;justify-content:center;position:relative;min-height:400px;max-height:92vh;overflow:hidden;">
      <!-- 미디어는 JS로 주입 -->
    </div>

    <!-- 오른쪽: 정보 + 댓글 -->
    <div style="flex:1;display:flex;flex-direction:column;min-width:0;max-height:92vh;overflow:hidden;">

      <!-- 작가 헤더 -->
      <div id="pv-header" style="padding:14px 16px;border-bottom:1px solid var(--bd);display:flex;align-items:center;gap:10px;flex-shrink:0;">
        <!-- JS로 채움 -->
      </div>

      <!-- 설명 + 댓글 스크롤 영역 -->
      <div id="pv-comments-wrap" style="flex:1;overflow-y:auto;padding:14px 16px;">
        <!-- 작품 설명 -->
        <div id="pv-desc" style="margin-bottom:14px;"></div>
        <!-- 댓글 목록 -->
        <div id="pv-comment-list" style="display:flex;flex-direction:column;gap:12px;"></div>
      </div>

      <!-- 하단 액션바 -->
      <div style="border-top:1px solid var(--bd);padding:12px 16px;flex-shrink:0;">
        <!-- 하트 · 조회수 -->
        <div id="pv-actions" style="display:flex;align-items:center;gap:14px;margin-bottom:10px;">
          <!-- JS로 채움 -->
        </div>
        <!-- 댓글 입력 -->
        <div id="pv-comment-input-wrap" style="display:flex;gap:8px;align-items:center;">
          <div id="pv-commenter-av" style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--t600),var(--ta));display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:#fff;flex-shrink:0;"></div>
          <input id="pv-comment-input" type="text"
            placeholder="댓글 달기..."
            style="flex:1;background:rgba(255,255,255,0.06);border:1px solid var(--bd);border-radius:20px;padding:8px 14px;color:var(--ink);font-size:13px;outline:none;font-family:var(--fn);"
            onkeydown="if(event.key==='Enter')pvSubmitComment()">
          <button onclick="pvSubmitComment()" style="background:none;border:none;color:var(--tc);font-size:13px;font-weight:600;cursor:pointer;padding:4px 8px;font-family:var(--fn);">게시</button>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- 기존 라이트박스 (일반 이미지용 유지) -->
<div class="lightbox" id="lightbox" onclick="closeLB()">
  <img id="lbImg" src="" alt="">
</div>

<style>
/* 포스트 뷰어 스크롤바 */
#pv-comments-wrap::-webkit-scrollbar{width:4px;}
#pv-comments-wrap::-webkit-scrollbar-thumb{background:var(--bd2);border-radius:2px;}
/* 댓글 입력 포커스 */
#pv-comment-input:focus{border-color:var(--tc);box-shadow:0 0 0 2px rgba(86,201,172,0.12);}
/* 모바일: 세로 레이아웃 */
@media(max-width:700px){
  #postViewerInner{flex-direction:column;max-height:96vh;}
  #pv-media{flex:0 0 auto;min-height:260px;max-height:52vw;}
}
</style>

<div class="tw" id="tw"></div>
<script>
// ══════════════════════════════
//  CONSTANTS
// ══════════════════════════════
const PLAN_SLOTS={free:4,pro:9,ultra:15};
const PLAN_TYPES={free:4,pro:9,ultra:15};
const PLAN_FEE={free:7,pro:5,ultra:3.5};
const ALL_TYPES=['일러스트 (전신)','일러스트 (반신)','캐릭터 디자인','SD·치비','배경','버추얼·리깅','그래픽·로고','이모티콘','애니메이션·GIF','배너·썸네일','명함·브로슈어','패키지 디자인','UI·앱 디자인','타이포그래피','포스터·플라이어','SNS 콘텐츠'];
const EMOJIS=['🌸','🎭','🐉','🦋','🌙','⭐','🍃','🔮','🌺','🎋','🦄','🏔️'];
const FAQS=[
  {q:'수수료는 어떻게 계산되나요?',a:'의뢰 완료 후 최종 결제 금액에서 자동 차감됩니다. Free 7%, Pro 5%, Ultra 3.5%가 적용됩니다.'},
  {q:'슬롯이란 무엇인가요?',a:'슬롯은 동시에 진행할 수 있는 커미션의 수입니다. Free 4개, Pro 7개, Ultra 9개까지 동시 진행 가능합니다.'},
  {q:'끌올 쿨타임은 어떻게 적용되나요?',a:'커미션 끌올(상단 올리기) 기능은 30시간 쿨타임이 적용됩니다. 모든 구독 플랜 동일합니다.'},
  {q:'Discord 연동은 어떻게 하나요?',a:'대시보드 > 설정에서 Discord 웹훅 URL을 입력하면 새 문의·결제 완료 시 알림이 전송됩니다.'},
  {q:'구독을 취소하면 어떻게 되나요?',a:'해지 신청 시 해당 월 마지막 날까지 혜택이 유지됩니다.'},
  {q:'에스크로 결제란?',a:'의뢰인이 결제하면 플랫폼이 금액을 보관하고, 최종 승인 시 작가에게 지급됩니다. 분쟁 발생 시 플랫폼이 중재합니다.'},
  {q:'이미지는 어디에 저장되나요?',a:'현재 데모 버전은 브라우저 내에 임시 저장됩니다. 실제 배포 시 AWS S3, Cloudflare Images 등 외부 스토리지와 연동이 필요합니다.'},
];

// ══════════════════════════════
//  STATE
// ══════════════════════════════
let S={
  users:[], commissions:[], seekingPosts:[], inquiries:[],
  orders:[], reviews:[], portfolio:[],
  notices:[
    {id:1,cat:'업데이트',icon:'📢',title:'플랫폼 오픈 안내',date:'2025.05.20',body:'Sōkin 그림 커미션 플랫폼이 정식 오픈했습니다. 많은 이용 부탁드립니다!'},
    {id:2,cat:'이벤트',icon:'🎉',title:'오픈 기념 Pro 구독 첫 달 50% 할인',date:'2025.05.20',body:'5월 31일까지 Pro 구독 시 첫 달 1,995원에 이용하실 수 있습니다.'},
    {id:3,cat:'점검',icon:'🛠️',title:'서버 안정화 작업 안내',date:'2025.05.21',body:'안정적인 서비스를 위해 점검이 예정되어 있습니다.'},
  ],
  currentUser:null, selectedArtistId:null,
  filters:{type:'전체',seek:'전체'}, dashTab:'overview',
  // temp image data (base64) for uploads in progress
  _thumbData:null, _sampleData:[], _refData:[], _skImgData:[], _portImgData:[],
};

function save(){
  try{
    const s=JSON.parse(JSON.stringify(S));
    // 임시 작업 데이터 제거
    s._thumbData=null;s._sampleData=[];s._refData=[];s._skImgData=[];s._portImgData=[];
    const str=JSON.stringify(s);
    localStorage.setItem('sokin3',str);
  }catch(e){
    // localStorage 용량 초과 시 — 커뮤니티 미디어 제외하고 재시도
    try{
      const s2=JSON.parse(JSON.stringify(S));
      s2._thumbData=null;s2._sampleData=[];s2._refData=[];s2._skImgData=[];s2._portImgData=[];
      // 미디어가 큰 게시물의 mediaData를 null로 대체 (썸네일만 제거, 텍스트 보존)
      if(s2.communityPosts){
        s2.communityPosts=s2.communityPosts.map(p=>{
          const size=(p.mediaData||'').length;
          if(size>200000)return{...p,mediaData:null,mediaLost:true};
          return p;
        });
      }
      // 커미션 썸네일도 제거 (sampleUrls 보존)
      if(s2.commissions){
        s2.commissions=s2.commissions.map(c=>({...c,thumbUrl:c.thumbUrl&&c.thumbUrl.length>200000?null:c.thumbUrl}));
      }
      localStorage.setItem('sokin3',JSON.stringify(s2));
      console.warn('[KIMAS] 저장 공간 부족으로 일부 미디어 데이터가 압축되었습니다. 실제 배포 시 S3/Cloudflare 스토리지 연동을 권장합니다.');
    }catch(e2){console.error('[KIMAS] 저장 실패:', e2);}
  }
}
function load(){
  try{
    const d=localStorage.getItem('sokin3');
    if(d)Object.assign(S,JSON.parse(d));
  }catch(e){console.error('[KIMAS] 로드 실패:',e);}
}

// ══════════════════════════════
//  IMAGE HANDLING
// ══════════════════════════════
function readFileAsDataURL(file){
  return new Promise(res=>{const r=new FileReader();r.onload=e=>res(e.target.result);r.readAsDataURL(file);});
}

async function handleThumb(input){
  const file=input.files[0];if(!file)return;
  if(file.size>10*1024*1024*1024){toast('파일은 10GB 이하여야 합니다.','err');return;}
  const data=await readFileAsDataURL(file);
  S._thumbData=data;
  const prev=document.getElementById('thumbPreview');
  const ph=document.getElementById('thumbPlaceholder');
  const ed=document.getElementById('thumbEdit');
  if(prev){prev.src=data;prev.style.display='block';}
  if(ph)ph.style.display='none';
  if(ed)ed.style.display='block';
}

async function handleSamples(input){
  const files=[...input.files].slice(0,20);
  const wrap=document.getElementById('samplePreviewWrap');
  for(const f of files){
    if(f.size>10*1024*1024*1024){toast(f.name+' — 10GB 초과','err');continue;}
    const data=await readFileAsDataURL(f);
    S._sampleData.push(data);
    const item=document.createElement('div');item.className='img-preview-item';
    item.style.cssText='position:relative;';
    item.innerHTML=`<img src="${data}" style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:8px;border:1px solid var(--bd2);cursor:pointer;" onclick="openLB('${data}')"><button class="del-img" onclick="delSample(this,'${data}')">✕</button>`;
    wrap.appendChild(item);
  }
}
// ── 리치 에디터 함수 ──
function execCmd(cmd,val=null){
  document.getElementById('richEditor')?.focus();
  document.execCommand(cmd,false,val);
}
function insertEditorHeading(){
  execCmd('formatBlock','H2');
}
function insertEditorHr(){
  execCmd('insertHTML','<hr>');
}
async function insertEditorImages(input){
  const editor=document.getElementById('richEditor');if(!editor)return;
  const files=[...input.files];
  for(const f of files){
    if(f.size>10*1024*1024*1024){toast(f.name+' — 10GB 초과','err');continue;}
    const data=await readFileAsDataURL(f);
    execCmd('insertHTML',`<img src="${data}" style="max-width:100%;border-radius:10px;margin:6px 0;" onclick="openLB('${data}')">`);
  }
  input.value='';
}
async function handleEditorPaste(e){
  const items=[...(e.clipboardData?.items||[])];
  const imageItems=items.filter(i=>i.type.startsWith('image/'));
  if(!imageItems.length)return;
  e.preventDefault();
  for(const item of imageItems){
    const file=item.getAsFile();if(!file)continue;
    const data=await readFileAsDataURL(file);
    execCmd('insertHTML',`<img src="${data}" style="max-width:100%;border-radius:10px;margin:6px 0;" onclick="openLB('${data}')">`);
  }
}

// ── 커미션 등록 탭 전환 ──
function switchCrTab(name,btn){
  document.querySelectorAll('.cr-panel').forEach(p=>p.style.display='none');
  const panel=document.getElementById('cr-'+name);
  if(panel)panel.style.display='block';
  document.querySelectorAll('.cr-tab').forEach(b=>b.classList.remove('active'));
  if(btn)btn.classList.add('active');
  if(name==='guide')updateCrSummary();
}
function updatePricePreview(){
  const min=parseInt(document.getElementById('crMinP')?.value)||0;
  const max=parseInt(document.getElementById('crMaxP')?.value)||0;
  const prev=document.getElementById('pricePreview');
  if(!prev)return;
  if(min>0){
    prev.style.display='block';
    prev.textContent=max>min?`가격 범위: ₩${min.toLocaleString()} ~ ₩${max.toLocaleString()}`:`시작 가격: ₩${min.toLocaleString()}`;
  }else{prev.style.display='none';}
}
function updateCrSummary(){
  const summary=document.getElementById('crSummary');if(!summary)return;
  const title=document.getElementById('crTitle')?.value||'(미입력)';
  const types=[...document.querySelectorAll('.type-opt.on')].map(e=>e.dataset.type);
  const min=parseInt(document.getElementById('crMinP')?.value)||0;
  const max=parseInt(document.getElementById('crMaxP')?.value)||0;
  const hasThumb=!!S._thumbData;
  const sampleCount=S._sampleData.length;
  const editorLen=document.getElementById('richEditor')?.innerText?.length||0;
  summary.innerHTML=[
    `${hasThumb?'✅':'⚠️'} 썸네일: ${hasThumb?'업로드 완료':'미업로드 (권장)'}`,
    `${title!=='(미입력)'?'✅':'❌'} 제목: ${title}`,
    `${types.length?'✅':'❌'} 타입: ${types.length?types.join(', '):'미선택'}`,
    `${min?'✅':'❌'} 가격: ${min?`₩${min.toLocaleString()}${max>min?'~₩'+max.toLocaleString():''}` : '미입력'}`,
    `${editorLen>10?'✅':'⚠️'} 상세 내용: ${editorLen>10?editorLen+'자 작성됨':'미작성 (권장)'}`,
    `${sampleCount?'✅':'⚠️'} 포트폴리오: ${sampleCount?sampleCount+'장':'미업로드 (권장)'}`,
  ].map(t=>`<div style="font-size:12px;">${t}</div>`).join('');
}



async function handleRefImages(input){
  const files=[...input.files].slice(0,5);
  const wrap=document.getElementById('refPreviewWrap');
  for(const f of files){
    if(f.size>5*1024*1024){toast(f.name+' — 5MB 초과','err');continue;}
    const data=await readFileAsDataURL(f);
    S._refData.push(data);
    const item=document.createElement('div');item.className='img-preview-item';
    item.innerHTML=`<img src="${data}" class="img-preview" onclick="openLB('${data}')" style="cursor:pointer;"><button class="del-img" onclick="delRef(this,'${data}')">✕</button>`;
    wrap.appendChild(item);
  }
}
function delRef(btn,data){S._refData=S._refData.filter(d=>d!==data);btn.parentElement.remove();}

async function handleSkImages(input){
  const files=[...input.files].slice(0,3);
  const wrap=document.getElementById('skImgWrap');
  for(const f of files){
    const data=await readFileAsDataURL(f);
    S._skImgData.push(data);
    const item=document.createElement('div');item.className='img-preview-item';
    item.innerHTML=`<img src="${data}" class="img-preview" onclick="openLB('${data}')" style="cursor:pointer;"><button class="del-img" onclick="delSkImg(this,'${data}')">✕</button>`;
    wrap.appendChild(item);
  }
}
function delSkImg(btn,data){S._skImgData=S._skImgData.filter(d=>d!==data);btn.parentElement.remove();}

async function applyWatermark(dataUrl, userName){
  return new Promise(resolve=>{
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = ()=>{
      try{
        const canvas = document.createElement('canvas');
        canvas.width = img.naturalWidth || img.width;
        canvas.height = img.naturalHeight || img.height;
        const ctx = canvas.getContext('2d');

        ctx.drawImage(img, 0, 0);

        const w = canvas.width;
        const h = canvas.height;

        // ── 대각선 KIMAS 반복 — 외곽선으로 배경 무관하게 항상 보임 ──
        ctx.save();
        const diagSize = Math.max(24, Math.min(w * 0.06, 56));
        ctx.font = `bold ${diagSize}px Arial, sans-serif`;
        ctx.translate(w/2, h/2);
        ctx.rotate(-30 * Math.PI / 180);
        ctx.textAlign = 'center';
        const dw = ctx.measureText('KIMAS').width + diagSize * 2.2;
        for(let y = -h * 1.5; y < h * 1.5; y += diagSize * 3.8){
          for(let x = -w * 1.5; x < w * 1.5; x += dw){
            // 흰 외곽선
            ctx.globalAlpha = 0.55;
            ctx.strokeStyle = '#ffffff';
            ctx.lineWidth = diagSize * 0.25;
            ctx.strokeText('KIMAS', x, y);
            // 어두운 텍스트
            ctx.globalAlpha = 0.45;
            ctx.fillStyle = '#1a1a3e';
            ctx.fillText('KIMAS', x, y);
          }
        }
        ctx.restore();

        // ── 우하단 워터마크 박스 ──
        const text = `© ${userName}  via  KIMAS`;
        const fontSize = Math.max(13, Math.min(w * 0.028, 32));
        ctx.font = `bold ${fontSize}px Arial, sans-serif`;
        const tw = ctx.measureText(text).width;
        const pad = fontSize * 0.7;
        const bx = w - tw - pad * 2 - 10;
        const by = h - fontSize - pad * 2 - 10;
        const bw = tw + pad * 2;
        const bh = fontSize + pad * 2;

        // 배경
        ctx.fillStyle = 'rgba(0,0,0,0.55)';
        ctx.beginPath();
        if(ctx.roundRect) ctx.roundRect(bx, by, bw, bh, 6);
        else ctx.rect(bx, by, bw, bh);
        ctx.fill();

        // 텍스트
        ctx.fillStyle = 'rgba(255,255,255,0.95)';
        ctx.fillText(text, bx + pad, by + pad + fontSize * 0.85);

        resolve(canvas.toDataURL('image/jpeg', 0.92));
      }catch(e){
        console.warn('워터마크 오류:', e);
        resolve(dataUrl);
      }
    };
    img.onerror = ()=> resolve(dataUrl);
    img.src = dataUrl;
  });
}

async function handlePortImages(input){
  const files=[...input.files].slice(0,10);
  const wrap=document.getElementById('portImgWrap');
  for(const f of files){
    let data=await readFileAsDataURL(f);
    // 업로드 시점에 워터마크 적용
    if(S.currentUser && S.currentUser.watermark!==false){
      data = await applyWatermark(data, S.currentUser.handle||S.currentUser.name);
    }
    S._portImgData.push(data);
    const item=document.createElement('div');item.className='img-preview-item';
    item.innerHTML=`<img src="${data}" class="img-preview" onclick="openLB('${data}')" style="cursor:pointer;"><button class="del-img" onclick="delPortImg(this,'${data}')">✕</button>`;
    wrap.appendChild(item);
  }
}
function delPortImg(btn,data){S._portImgData=S._portImgData.filter(d=>d!==data);btn.parentElement.remove();}

// Lightbox
function delSample(btn,data){
  S._sampleData=S._sampleData.filter(d=>d!==data);
  if(btn&&btn.parentElement)btn.parentElement.remove();
}
// openLB / closeLB — 아래 통합 정의로 대체됨

// ══════════════════════════════
//  AUTH
// ══════════════════════════════
const OWNER_EMAIL = 'cdk061201@gmail.com';
function isOwner(email){ return email.trim().toLowerCase() === OWNER_EMAIL; }

// doLogin: see window.doLogin below
function doSignup(){
  const name=document.getElementById('rName').value.trim();
  const role=document.getElementById('rRole').value;
  const email=document.getElementById('rEmail').value.trim();
  const pw=document.getElementById('rPw').value;
  const pw2=document.getElementById('rPw2').value;
  const agree=document.getElementById('rAgree').checked;
  if(!name||!email||!pw){toast('모든 필수 항목을 입력해주세요.','err');return;}
  if(pw!==pw2){toast('비밀번호가 일치하지 않습니다.','err');return;}
  if(pw.length<8){toast('비밀번호는 8자 이상이어야 합니다.','err');return;}
  if(!agree){toast('이용약관에 동의해주세요.','err');return;}
  if(S.users.find(u=>u.email===email)){toast('이미 사용 중인 이메일입니다.','err');return;}
  const owner = isOwner(email);
  const u={id:Date.now(),name,handle:'@'+name.replace(/\s+/g,'_').toLowerCase(),email,pw,
    role: owner ? 'both' : role,
    plan: owner ? 'ultra' : 'free',
    isOwner: owner,
    done:0,rating:null,followers:0,bio:'',tags:[],webhookUrl:'',avatarUrl:null,
    createdAt:new Date().toLocaleDateString('ko-KR')};
  S.users.push(u);S.currentUser=u;save();closeM('mSignup');updateNav();
  if(owner){
    toast('👑 운영자 계정으로 가입되었습니다. Ultra 플랜이 자동 적용됩니다.','ok');
    goto('admin');
  } else {
    toast(name+'님, 가입을 환영합니다! 🌿','ok');
    goto('dashboard');
  }
}
function doLogout(){
  S.currentUser=null;
  // 로그인 유지 캐시 삭제
  try{localStorage.removeItem('kimas_remember');}catch(e){}
  save();updateNav();goto('home');toast('로그아웃 되었습니다.','ok');
  // 로그인 폼 초기화
  const em=document.getElementById('lEmail');const pw=document.getElementById('lPw');
  const rm=document.getElementById('rememberMe');
  if(em)em.value='';if(pw)pw.value='';if(rm)rm.checked=false;
}
function requireLogin(cb){if(!S.currentUser){toast('로그인이 필요합니다.','err');openM('mLogin');return;}cb();}
function updateNav(){
  const li=!!S.currentUser;
  const owner=li&&S.currentUser.isOwner;
  document.getElementById('loginBtn').style.display=li?'none':'';
  document.getElementById('signupBtn').style.display=li?'none':'';
  document.getElementById('dashBtn').style.display=li?'':'none';
  document.getElementById('dashBtn').textContent=owner?'🛡️ 관리자':'대시보드';
  document.getElementById('logoutBtn').style.display=li?'':'none';
  let adminLi=document.getElementById('navAdminLi');
  if(owner&&!adminLi){
    adminLi=document.createElement('li');adminLi.id='navAdminLi';
    adminLi.innerHTML='<a onclick="goto(\'admin\');setNav(this)" style="color:var(--g200);">🛡️ 관리자</a>';
    document.getElementById('navLinks').appendChild(adminLi);
  }else if(!owner&&adminLi){adminLi.remove();}
}

// ══════════════════════════════
//  NAVIGATION
// ══════════════════════════════
// ── 내비게이션 히스토리 스택 ──
const _navHistory = [];
let _currentPage = 'home';

function goto(name){
  // 히스토리 스택에 현재 페이지 push
  if(_currentPage && _currentPage !== name) _navHistory.push(_currentPage);
  if(_navHistory.length > 30) _navHistory.shift();
  _currentPage = name;

  document.querySelectorAll('.page').forEach(p=>{p.classList.remove('active');p.style.display='none';});
  // home-extra (stat-bar, 광고, 이용방법 등) 홈일때만 표시
  const homeExtra=document.getElementById('home-extra');
  if(homeExtra) homeExtra.style.display = name==='home' ? '' : 'none';
  const pg=document.getElementById('page-'+name);
  if(pg){pg.classList.add('active');pg.style.display='block';}
  window.scrollTo({top:0,behavior:'smooth'});closeMob();
  if(name==='home')renderHome();
  if(name==='artists')renderAP();
  if(name==='seeking')renderSeeking();
  if(name==='pricing')renderFAQ();
  if(name==='notice')renderNotice();
  if(name==='qna')renderQnA();
  if(name==='dashboard'){if(!S.currentUser){openM('mLogin');return;}renderDash();}
  if(name==='artist-detail')renderAD();
  if(name==='admin')renderAdmin();

  if(name==='community')renderCommunity?.();
  updateStats();
}

function goBack(){
  if(_navHistory.length > 0){
    const prev = _navHistory.pop();
    _currentPage = prev;
    document.querySelectorAll('.page').forEach(p=>{p.classList.remove('active');p.style.display='none';});
    const homeExtra=document.getElementById('home-extra');
    if(homeExtra) homeExtra.style.display = prev==='home' ? '' : 'none';
    const pg=document.getElementById('page-'+prev);
    if(pg){pg.classList.add('active');pg.style.display='block';}
    window.scrollTo({top:0,behavior:'smooth'});
    if(prev==='home')renderHome();
    if(prev==='artists')renderAP();
    if(prev==='seeking')renderSeeking();
    if(prev==='dashboard'&&S.currentUser)renderDash();
    if(prev==='admin')renderAdmin();
    if(prev==='userprofile'){renderUserProfile();const u=S.users.find(x=>x.id===S.selectedUserId);if(u)setTimeout(()=>applyUserProfileDecorations(u),100);}
    if(prev==='community')renderCommunity?.();
    updateStats();
  } else {
    goto('home');
  }
}
function setNav(el){document.querySelectorAll('.nav-links a').forEach(a=>a.classList.remove('active'));el.classList.add('active');}
function toggleMob(){document.getElementById('nb').classList.toggle('mob-open');}
function closeMob(){document.getElementById('nb').classList.remove('mob-open');}

// ══════════════════════════════
//  COMMISSION SUBMIT
// ══════════════════════════════
function openCommReg(){
  if(!S.currentUser)return;
  const plan=S.currentUser.plan,maxT=PLAN_TYPES[plan];
  document.getElementById('crMaxT').textContent=maxT;
  const sel=document.getElementById('crTypeSelector');
  sel.innerHTML=ALL_TYPES.map(t=>`<button class="type-opt" data-type="${t}" onclick="toggleTO(this)">${t}</button>`).join('');
  ['crTitle','crMinP','crMaxP','crDesc','crTags','crCanDo','crCantDo','crDeadline','crRevision','crNote'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('crStatus').value='open';
  // 리치 에디터 초기화
  const editor=document.getElementById('richEditor');
  if(editor)editor.innerHTML='';
  // 썸네일 초기화
  S._thumbData=null;S._sampleData=[];
  const prev=document.getElementById('thumbPreview');
  const ph=document.getElementById('thumbPlaceholder');
  const ed2=document.getElementById('thumbEdit');
  if(prev){prev.style.display='none';prev.src='';}
  if(ph)ph.style.display='block';
  if(ed2)ed2.style.display='none';
  document.getElementById('samplePreviewWrap').innerHTML='';
  document.getElementById('thumbInput').value='';
  document.getElementById('sampleInput').value='';
  // 첫 번째 탭으로
  switchCrTab('basic',document.querySelectorAll('.cr-tab')[0]);
  openM('mCommReg');setTimeout(()=>{initTagInput('crTags','crTagsSug');},100);
}
function toggleTO(btn){
  const plan=S.currentUser?.plan||'free',maxT=PLAN_TYPES[plan];
  const on=document.querySelectorAll('.type-opt.on').length;
  if(!btn.classList.contains('on')&&on>=maxT){toast('최대 '+maxT+'개까지 선택 가능합니다.','err');return;}
  btn.classList.toggle('on');
}
function submitCommission(){
  if(!S.currentUser)return;
  const title=document.getElementById('crTitle').value.trim();
  const status=document.getElementById('crStatus').value;
  const minP=parseInt(document.getElementById('crMinP').value)||0;
  const maxP=parseInt(document.getElementById('crMaxP').value)||0;
  const desc=document.getElementById('crDesc').value.trim();
  const tags=document.getElementById('crTags').value.split(',').map(t=>t.trim()).filter(Boolean);
  const selected=[...document.querySelectorAll('.type-opt.on')].map(el=>el.dataset.type);
  const richContent=document.getElementById('richEditor')?.innerHTML||'';
  const canDo=document.getElementById('crCanDo')?.value.trim()||'';
  const cantDo=document.getElementById('crCantDo')?.value.trim()||'';
  const deadline=document.getElementById('crDeadline')?.value.trim()||'';
  const revision=document.getElementById('crRevision')?.value.trim()||'';
  const note=document.getElementById('crNote')?.value.trim()||'';
  if(!title){toast('제목을 입력해주세요.','err');switchCrTab('basic',document.querySelectorAll('.cr-tab')[0]);return;}
  if(selected.length===0){toast('커미션 타입을 최소 1개 선택해주세요.','err');switchCrTab('basic',document.querySelectorAll('.cr-tab')[0]);return;}
  if(!minP){toast('최소 가격을 입력해주세요.','err');switchCrTab('basic',document.querySelectorAll('.cr-tab')[0]);return;}
  const plan=S.currentUser.plan,maxT=PLAN_TYPES[plan];
  if(selected.length>maxT){toast('플랜 한도 초과 ('+maxT+'개까지)','err');return;}
  const c={
    id:Date.now(),artistId:S.currentUser.id,
    title,status,types:selected,minPrice:minP,maxPrice:maxP||minP,
    desc,tags,slots:PLAN_SLOTS[plan],filledSlots:0,
    thumbUrl:S._thumbData||null,
    sampleUrls:[...S._sampleData],
    richContent,
    guideline:{canDo,cantDo,deadline,revision,note},
    bumpedAt:Date.now(),createdAt:new Date().toLocaleDateString('ko-KR')
  };
  S.commissions.push(c);save();closeM('mCommReg');toast('커미션이 등록되었습니다! 🎨','ok');renderHome();renderAP();updateStats();
}
function bumpComm(id){
  const c=S.commissions.find(x=>x.id===id);if(!c)return;
  const hrs=(Date.now()-c.bumpedAt)/(3600000);
  if(hrs<30){toast('끌올 쿨타임 중 ('+(30-hrs).toFixed(1)+'시간 후 가능)','err');return;}
  c.bumpedAt=Date.now();save();toast('커미션이 끌올되었습니다! ⬆','ok');showDash(S.dashTab);
}
function deleteComm(id){
  S.commissions=S.commissions.filter(c=>c.id!==id);save();toast('커미션이 삭제되었습니다.','ok');showDash(S.dashTab);
}

// ══════════════════════════════
//  PORTFOLIO SUBMIT
// ══════════════════════════════
function toggleWatermark(enabled){
  if(!S.currentUser)return;
  S.currentUser.watermark = enabled;
  const slider = document.getElementById('wmSlider');
  if(slider){
    slider.style.background = enabled ? 'var(--tc)' : 'var(--bd)';
    const knob = slider.querySelector('span');
    if(knob) knob.style.left = enabled ? '23px' : '3px';
  }
  save();
  toast(enabled ? '워터마크가 활성화됐습니다 🔒' : '워터마크가 비활성화됐습니다', 'ok');
}

function openPortfolioUpload(){S._portImgData=[];document.getElementById('portImgWrap').innerHTML='';document.getElementById('portInput').value='';document.getElementById('portDesc').value='';document.getElementById('portTags').value='';openM('mPortfolio');}


async function submitPortfolio(){
  if(!S.currentUser)return;
  if(S._portImgData.length===0){toast('이미지를 업로드해주세요.','err');return;}
  const desc=document.getElementById('portDesc').value.trim();
  const tags=document.getElementById('portTags').value.split(',').map(t=>t.trim()).filter(Boolean);

  toast('워터마크 적용 중...','ok');

  const wmEnabled = S.currentUser.watermark !== false; // 기본 활성화
  const userName = S.currentUser.handle || S.currentUser.name;

  for(const img of S._portImgData){
    const finalImg = wmEnabled ? await applyWatermark(img, userName) : img;
    S.portfolio.push({id:Date.now()+Math.random(),userId:S.currentUser.id,imgUrl:finalImg,desc,tags,createdAt:new Date().toLocaleDateString('ko-KR')});
  }
  save();closeM('mPortfolio');toast('포트폴리오가 업로드되었습니다! 🎨','ok');showDash('portfolio');
}

// ══════════════════════════════
//  SEEKING SUBMIT
// ══════════════════════════════
function submitSeeking(){
  if(!S.currentUser)return;
  const title=document.getElementById('skTitle').value.trim();
  const cat=document.getElementById('skCat').value;
  const budget=document.getElementById('skBudget').value.trim();
  const desc=document.getElementById('skDesc').value.trim();
  const tags=document.getElementById('skTags').value.split(',').map(t=>t.trim()).filter(Boolean);
  if(!title||!desc||!budget){toast('필수 항목을 입력해주세요.','err');return;}
  S.seekingPosts.unshift({
    id:Date.now(),userId:S.currentUser.id,userName:S.currentUser.name,
    userInitial:S.currentUser.name[0],userAvatar:S.currentUser.avatarUrl,
    title,cat,budget,desc,tags,imgUrls:[...S._skImgData],replies:0,
    createdAt:'방금 전'
  });
  save();closeM('mSeeking');toast('구해요 글이 게시되었습니다.','ok');renderSeeking();
}

// ══════════════════════════════
//  INQUIRY SUBMIT
// ══════════════════════════════
function openInquiryFor(artistId){
  S.selectedArtistId=artistId;
  const comms=S.commissions.filter(c=>c.artistId===artistId);
  const sel=document.getElementById('inqType');
  const types=[...new Set(comms.flatMap(c=>c.types))];
  sel.innerHTML=types.length?types.map(t=>`<option>${t}</option>`).join(''):'<option>기타</option>';
  S._refData=[];document.getElementById('refPreviewWrap').innerHTML='';document.getElementById('refInput').value='';
  openM('mInquiry');
}
function submitInquiry(){
  if(!S.currentUser)return;
  const type=document.getElementById('inqType').value;
  const budget=document.getElementById('inqBudget').value.trim();
  const content=document.getElementById('inqContent').value.trim();
  if(!budget||!content){toast('예산과 의뢰 내용을 입력해주세요.','err');return;}
  const inq={
    id:Date.now(),commId:null,fromUserId:S.currentUser.id,toArtistId:S.selectedArtistId,
    type,budget,content,refImgs:[...S._refData],
    revisions:document.getElementById('inqRevisions').value,
    note:document.getElementById('inqNote').value,
    status:'대기 중',createdAt:new Date().toLocaleDateString('ko-KR')
  };
  S.inquiries.push(inq);save();closeM('mInquiry');toast('문의가 전송되었습니다. 작가의 답변을 기다려주세요.','ok');
}

// ══════════════════════════════
//  RENDER HOME
// ══════════════════════════════
function renderHome(){
  const g=document.getElementById('homeGrid');if(!g)return;
  if(S.commissions.length===0){
    g.innerHTML=`<div class="empty"><div class="empty-icon">🌿</div><h3>아직 등록된 커미션이 없습니다</h3><p>첫 번째 작가가 되어 커미션을 등록해보세요!<br>회원가입 후 대시보드에서 등록할 수 있습니다.</p><button class="btn btn-teal" style="margin-top:15px;" onclick="openM('mSignup')">시작하기</button></div>`;
  }else{
    const recent=[...S.commissions].filter(c=>!c.hidden).sort((a,b)=>b.bumpedAt-a.bumpedAt).slice(0,8);
    g.innerHTML=`<div class="card-grid">${recent.map(c=>commCard(c)).join('')}</div>`;
  }
}

// ══════════════════════════════
//  RENDER ARTISTS PAGE
// ══════════════════════════════
function renderAP(){
  const q=(document.getElementById('aSearch')||{}).value||'';
  const tf=S.filters.type;
  let comms=S.commissions.filter(c=>!c.hidden);
  if(q)comms=comms.filter(c=>{const a=S.users.find(u=>u.id===c.artistId);return(a&&a.name.includes(q))||c.title.includes(q)||c.tags.some(t=>t.includes(q))||c.types.some(t=>t.includes(q));});
  if(tf!=='전체')comms=comms.filter(c=>c.types.some(t=>t.includes(tf)));
  const sorted=[...comms].sort((a,b)=>b.bumpedAt-a.bumpedAt);
  const g1=document.getElementById('gAll'),g2=document.getElementById('gOpen'),g3=document.getElementById('gArtists');
  if(g1)g1.innerHTML=sorted.length?`<div class="card-grid">${sorted.map(c=>commCard(c)).join('')}</div>`:emptyHtml('🎨','커미션 없음','아직 등록된 커미션이 없습니다.<br>첫 번째 작가가 되어보세요!');
  if(g2){const op=sorted.filter(c=>c.status==='open');g2.innerHTML=op.length?`<div class="card-grid">${op.map(c=>commCard(c)).join('')}</div>`:emptyHtml('🟢','모집 중 커미션 없음','현재 모집 중인 커미션이 없습니다.');}
  if(g3){const aids=[...new Set(S.commissions.map(c=>c.artistId))];const arts=aids.map(id=>S.users.find(u=>u.id===id)).filter(Boolean);g3.innerHTML=arts.length?arts.map(a=>artistRowCard(a)).join(''):emptyHtml('🎨','작가 없음','아직 등록된 작가가 없습니다.');}
}

// ══════════════════════════════
//  RENDER SEEKING
// ══════════════════════════════
function renderSeeking(){
  const list=document.getElementById('seekList');if(!list)return;
  const f=S.filters.seek;
  const posts=(f==='전체'?S.seekingPosts:S.seekingPosts.filter(p=>p.cat.includes(f))).filter(p=>!p.hidden);
  if(!posts.length){list.innerHTML=emptyHtml('📋','구해요 글 없음','아직 게시된 글이 없습니다.<br>첫 번째로 구하는 글을 올려보세요!');return;}
  list.innerHTML=posts.map(p=>`
    <div class="sk">
      <div class="sk-head">
        <div class="sk-av">${p.userAvatar?`<img src="${p.userAvatar}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`:`<span style="font-size:14px;">${p.userInitial}</span>`}</div>
        <div style="flex:1;"><div style="font-size:12.5px;font-weight:500;color:var(--ink);">${p.userName}</div><div style="font-size:10px;color:var(--ink3);">${p.createdAt} · ${p.cat}</div></div>
        <div style="font-family:var(--fs);font-size:13.5px;font-weight:600;color:var(--g200);">₩${p.budget}</div>
      </div>
      <div style="font-size:13.5px;font-weight:500;color:var(--ink);margin-bottom:4px;">${p.title}</div>
      <div style="font-size:12px;color:var(--ink3);line-height:1.65;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${p.desc}</div>
      ${p.imgUrls&&p.imgUrls.length?`<div style="display:flex;gap:6px;margin-top:8px;flex-wrap:wrap;">${p.imgUrls.map(u=>`<img src="${u}" style="width:64px;height:64px;object-fit:cover;border-radius:7px;border:1px solid var(--bd);cursor:pointer;" onclick="openLB('${u}')">`).join('')}</div>`:``}
      <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:7px;">${p.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</div>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-top:8px;padding-top:8px;border-top:1px solid var(--bd);">
        <div style="font-size:11px;color:var(--ink3);">💬 ${p.replies}개 답변</div>
        <div style="display:flex;gap:6px;">
          <button class="btn btn-ghost btn-sm" onclick="requireLogin(()=>openInquiryFor(0))">제안하기</button>
          <button class="btn btn-ghost btn-sm" style="color:#e87;border-color:rgba(200,80,80,.2);" onclick="requireLogin(()=>openReport('${p.userId}','${p.userName}','기타'))">🚨 신고</button>
        </div>
      </div>
    </div>`).join('');
}

// ══════════════════════════════
//  RENDER NOTICE / FAQ
// ══════════════════════════════
function renderNotice(){const list=document.getElementById('noticeList');if(!list)return;list.innerHTML=S.notices.map(n=>`<div class="nc"><div class="ni">${n.icon}</div><div><div style="font-size:13px;font-weight:500;color:var(--ink);">${n.title}</div><div style="font-size:10px;color:var(--ink3);">${n.date} · ${n.cat}</div><div style="font-size:12px;color:var(--ink3);margin-top:3px;line-height:1.5;">${n.body}</div></div></div>`).join('');}
function renderFAQ(){const list=document.getElementById('faqList');if(!list||list.innerHTML)return;list.innerHTML=FAQS.map(f=>`<div style="border:1px solid var(--bd);border-radius:8px;overflow:hidden;"><button onclick="toggleFaq(this)" style="width:100%;text-align:left;padding:11px 14px;background:var(--sf);border:none;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:10px;font-family:var(--fn);font-size:12.5px;font-weight:500;color:var(--ink);"><span>${f.q}</span><span style="flex-shrink:0;color:var(--ink3);transition:transform .2s;">▾</span></button><div style="display:none;padding:0 14px 11px;font-size:12px;color:var(--ink3);line-height:1.7;">${f.a}</div></div>`).join('');}
function toggleFaq(btn){const b=btn.nextElementSibling,a=btn.querySelector('span:last-child'),open=b.style.display!=='none';b.style.display=open?'none':'block';a.style.transform=open?'':'rotate(180deg)';}

// ══════════════════════════════
//  RENDER DASHBOARD
// ══════════════════════════════
function renderDash(){
  const u=S.currentUser;if(!u)return;
  const av=document.getElementById('profAv');
  const planLabel=u.isOwner?'👑 운영자':u.plan.toUpperCase();
  const planClass=u.isOwner?'pp-ultra':`pp-${u.plan}`;
  av.innerHTML=u.avatarUrl
    ?`<img src="${u.avatarUrl}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;"><div class="pp ${planClass}">${planLabel}</div>`
    :`${u.name[0]}<div class="pp ${planClass}">${planLabel}</div>`;
  document.getElementById('profName').textContent=u.name;
  document.getElementById('profHandle').textContent=u.handle;
  document.getElementById('profDone').textContent=u.done;
  document.getElementById('profRating').textContent=u.rating||'—';
  document.getElementById('profFollowers').textContent=u.followers;
  showDash(S.dashTab);
}
function showDash(tab,btn){
  S.dashTab=tab;
  document.querySelectorAll('.si').forEach(b=>b.classList.remove('active'));
  if(btn)btn.classList.add('active');
  else{const items=document.querySelectorAll('.si');const map={overview:0,portfolio:1,slots:2,orders:3,inquiries:4,earnings:5,reviews:6,subscription:7,settings:8};if(map[tab]!==undefined)items[map[tab]]?.classList.add('active');}
  const u=S.currentUser;if(!u)return;
  const plan=u.plan;
  const myC=S.commissions.filter(c=>c.artistId===u.id);
  const maxS=PLAN_SLOTS[plan];const filledS=myC.filter(c=>c.status==='open').length;
  const main=document.getElementById('dashMain');if(!main)return;

  if(tab==='overview'){
    const myPort=S.portfolio.filter(p=>p.userId===u.id);
    const myInq=S.inquiries.filter(i=>i.toArtistId===u.id&&i.status==='대기 중');
    main.innerHTML=`
    <div class="sg"><div class="sc2"><div class="sc-l">내 커미션</div><div class="sc-v">${myC.length}</div></div><div class="sc2"><div class="sc-l">사용 슬롯</div><div class="sc-v">${filledS}<span style="font-size:12px;color:var(--ink3);">/${maxS}</span></div></div><div class="sc2"><div class="sc-l">포트폴리오</div><div class="sc-v">${myPort.length}</div></div><div class="sc2"><div class="sc-l">미처리 문의</div><div class="sc-v" style="color:${myInq.length?'var(--g200)':'var(--ta)'};">${myInq.length}</div></div></div>
    ${(u.role==='artist'||u.role==='both')?`
    <div class="dc-box"><div style="font-size:24px;">🎮</div><div><h3>Discord 알림 연동</h3><p>새 문의, 결제 완료 시 Discord로 즉시 알림이 전송됩니다.</p></div><button class="btn-dc" onclick="showDash('settings')">설정하기</button></div>
    <div class="cc">
      <div class="cct">🎨 내 커미션 <button class="btn btn-teal btn-sm" style="margin-left:auto;" onclick="openCommReg()">+ 커미션 등록</button></div>
      ${myC.length===0?`<div class="empty" style="padding:34px 0;"><div class="empty-icon">🖌️</div><h3>등록된 커미션 없음</h3><p>커미션을 등록하면 플랫폼에 공개됩니다.</p><button class="btn btn-teal btn-sm" style="margin-top:12px;" onclick="openCommReg()">첫 커미션 등록하기</button></div>`:`<div style="display:flex;flex-direction:column;gap:9px;">${myC.map(c=>miniCommCard(c)).join('')}</div>`}
    </div>
    <div class="cc">
      <div class="cct">🖼️ 포트폴리오 <button class="btn btn-ghost btn-sm" style="margin-left:auto;" onclick="openPortfolioUpload()">+ 업로드</button></div>
      ${myPort.length===0?`<div class="empty" style="padding:28px 0;"><div class="empty-icon">🖼️</div><h3>포트폴리오를 추가해보세요</h3></div>`:`<div class="portfolio-grid">${myPort.slice(0,6).map(p=>`<div class="port-item" onclick="openLB('${p.imgUrl}')"><img src="${p.imgUrl}" alt="${p.desc||''}"><div class="port-overlay">🔍 크게 보기</div></div>`).join('')}</div>`}
    </div>`:''}`;
  }
  else if(tab==='mycomm'){
    main.innerHTML=`<div class="cc"><div class="cct">🎨 내 커미션 관리 <button class="btn btn-teal btn-sm" style="margin-left:auto;" onclick="openCommReg()">+ 등록</button></div>
    ${myC.length===0?`<div class="empty" style="padding:34px 0;"><div class="empty-icon">🖌️</div><h3>등록된 커미션이 없습니다</h3><button class="btn btn-teal btn-sm" style="margin-top:12px;" onclick="openCommReg()">커미션 등록하기</button></div>`:`<div style="display:flex;flex-direction:column;gap:9px;">${myC.map(c=>miniCommCard(c,true)).join('')}</div>`}</div>`;
  }
  else if(tab==='portfolio'){
    const myPort=S.portfolio.filter(p=>p.userId===u.id);
    main.innerHTML=`<div class="cc"><div class="cct">🖼️ 내 포트폴리오 <button class="btn btn-teal btn-sm" style="margin-left:auto;" onclick="openPortfolioUpload()">+ 업로드</button></div>
    ${myPort.length===0?`<div class="empty" style="padding:40px 0;"><div class="empty-icon">🖼️</div><h3>포트폴리오가 없습니다</h3><p>작품 이미지를 업로드하여 포트폴리오를 채워보세요.</p><button class="btn btn-teal btn-sm" style="margin-top:12px;" onclick="openPortfolioUpload()">첫 작품 업로드</button></div>`:
    `<div class="portfolio-grid">${myPort.map(p=>`<div class="port-item" style="position:relative;" onclick="openLB('${p.imgUrl}')"><img src="${p.imgUrl}" alt="${p.desc||''}"><div class="port-overlay">🔍 크게 보기</div><button style="position:absolute;top:4px;right:4px;background:rgba(200,50,50,.8);border:none;color:#fff;border-radius:5px;padding:2px 6px;font-size:10px;cursor:pointer;z-index:2;" onclick="event.stopPropagation();delPort(${p.id})">삭제</button></div>`).join('')}</div>`}
    </div>`;
  }
  else if(tab==='slots'){
    const skinId=u.equipped?.slotSkin||'';
    const skinVal={slot_crystal:'crystal',slot_fire:'fire',slot_night:'night',slot_sakura:'sakura'}[skinId]||'';
    const skinLabel={slot_crystal:'💠 크리스탈',slot_fire:'🔥 파이어',slot_night:'🌙 나이트',slot_sakura:'🌸 벚꽃'}[skinId]||'기본';
    const skinCls=skinVal?`slot-skin-${skinVal}`:'';
    main.innerHTML=`<div class="cc"><div class="cct">🔢 슬롯 관리 <span style="font-size:11px;font-weight:400;color:var(--ink3);margin-left:5px;">${plan.toUpperCase()} · ${maxS}개 · 스킨: ${skinLabel}</span></div>
    <div class="${skinCls}" id="slotGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:10px;padding:4px 0;">
      ${Array.from({length:maxS},(_,i)=>{
        const used=i<filledS;
        return`<div class="slot${used?' on':''}">
          <div style="font-size:22px;margin-bottom:4px;">${used?'✓':'○'}</div>
          <div style="font-size:12px;font-weight:600;color:${used?'var(--tc)':'var(--ink3)'};">${i+1}번</div>
          <div style="font-size:10px;color:${used?'var(--ink2)':'var(--ink3)'};margin-top:2px;">${used?'사용 중':'비어있음'}</div>
        </div>`;
      }).join('')}
    </div>
    ${u.slotExtUntil&&u.slotExtUntil>Date.now()?`<div style="margin-top:12px;padding:8px 12px;background:rgba(232,168,0,0.08);border:1px solid var(--bdg);border-radius:7px;font-size:11.5px;color:var(--g300);">📦 슬롯 확장권 적용 중 — ${new Date(u.slotExtUntil).toLocaleDateString('ko-KR')} 만료</div>`:''}
    </div>`;
    // 스킨 CSS 직접 적용 (body 클래스 + 그리드 컨테이너)
    if(skinVal){
      document.body.className=document.body.className.replace(/slot-skin-\w+/g,'').trim();
      document.body.classList.add('slot-skin-'+skinVal);
    }
  }
  else if(tab==='orders'){
    const myOrders=S.orders.filter(o=>o.artistId===u.id||o.clientId===u.id);
    main.innerHTML=`<div class="cc"><div class="cct">📦 주문 관리</div>
    ${myOrders.length===0?`<div class="empty" style="padding:34px 0;"><div class="empty-icon">📦</div><h3>주문 내역이 없습니다</h3><p>커미션 신청이 들어오면 여기서 관리할 수 있습니다.</p></div>`:
    `<table style="width:100%;border-collapse:collapse;font-size:12px;"><thead><tr style="border-bottom:1px solid var(--bd);">${['의뢰인','타입','금액','상태','날짜'].map(h=>`<th style="text-align:left;padding:8px 10px;color:var(--ink3);font-size:10.5px;">${h}</th>`).join('')}</tr></thead><tbody>${myOrders.map(o=>`<tr style="border-bottom:1px solid var(--bd);"><td style="padding:9px 10px;">${S.users.find(x=>x.id===o.clientId)?.name||'—'}</td><td style="padding:9px 10px;color:var(--ink3);">${o.type}</td><td style="padding:9px 10px;color:var(--ta);">₩${Number(o.amount).toLocaleString()}</td><td style="padding:9px 10px;"><span style="padding:2px 7px;border-radius:5px;font-size:10.5px;background:rgba(49,144,112,0.12);color:var(--tc);">${o.status}</span></td><td style="padding:9px 10px;color:var(--ink3);font-size:10.5px;">${o.date}</td></tr>`).join('')}</tbody></table>`}
    </div>`;
  }
  else if(tab==='inquiries'){
    const myI=S.inquiries.filter(i=>i.toArtistId===u.id);
    main.innerHTML=`<div class="cc"><div class="cct">💬 문의함</div>
    ${myI.length===0?`<div class="empty" style="padding:32px 0;"><div class="empty-icon">💬</div><h3>아직 문의가 없습니다</h3></div>`:
    myI.map(i=>{const from=S.users.find(x=>x.id===i.fromUserId);return`<div style="border:1px solid var(--bd);border-radius:9px;padding:13px;margin-bottom:10px;background:var(--sf2);">
      <div style="display:flex;align-items:center;gap:9px;margin-bottom:8px;">
        <div class="av">${from?from.name[0]:'?'}</div>
        <div><div style="font-size:12.5px;font-weight:500;">${from?from.name:'알 수 없음'}</div><div style="font-size:10.5px;color:var(--ink3);">${i.createdAt} · ${i.type}</div></div>
        <span style="margin-left:auto;padding:3px 8px;border-radius:5px;font-size:10.5px;background:${i.status==='대기 중'?'rgba(212,160,23,0.12)':'rgba(49,144,112,0.12)'};color:${i.status==='대기 중'?'var(--g200)':'var(--tc)'};">${i.status}</span>
      </div>
      <div style="font-size:12px;color:var(--ink2);line-height:1.65;margin-bottom:8px;">${i.content}</div>
      <div style="font-size:12px;color:var(--ta);margin-bottom:8px;">예산: ₩${i.budget}</div>
      ${i.refImgs&&i.refImgs.length?`<div style="display:flex;gap:5px;flex-wrap:wrap;margin-bottom:8px;">${i.refImgs.map(u=>`<img src="${u}" style="width:58px;height:58px;object-fit:cover;border-radius:7px;border:1px solid var(--bd);cursor:pointer;" onclick="openLB('${u}')">`).join('')}</div>`:``}
      <div style="display:flex;gap:7px;"><button class="btn btn-teal btn-sm" onclick="acceptInquiry(${i.id})">수락</button><button class="btn btn-ghost btn-sm" onclick="rejectInquiry(${i.id})">거절</button></div>
    </div>`;}).join('')}
    </div>`;
  }
  else if(tab==='earnings'){
    main.innerHTML=`<div class="cc"><div class="cct">💰 수익 현황</div><div class="sg"><div class="sc2"><div class="sc-l">이번 달 수익</div><div class="sc-v">—</div><div class="sc-s">수수료 ${PLAN_FEE[plan]}% 적용</div></div><div class="sc2"><div class="sc-l">완료 건수</div><div class="sc-v">${u.done}</div></div><div class="sc2"><div class="sc-l">평균 금액</div><div class="sc-v">—</div></div></div><div style="text-align:center;padding:24px;color:var(--ink3);font-size:12px;">실제 거래 데이터가 쌓이면 여기에 표시됩니다.</div></div>`;
  }
  else if(tab==='reviews'){
    const myR=S.reviews.filter(r=>r.artistId===u.id);
    const avg=myR.length?Math.round(myR.reduce((a,r)=>a+r.rating,0)/myR.length*10)/10:null;
    main.innerHTML=`<div class="cc"><div class="cct">⭐ 리뷰</div>
    ${myR.length===0?`<div class="empty" style="padding:32px 0;"><div class="empty-icon">⭐</div><h3>아직 리뷰가 없습니다</h3></div>`:`
    <div style="display:flex;align-items:center;gap:18px;padding:14px;background:var(--sf2);border-radius:var(--r);margin-bottom:14px;">
      <div style="text-align:center;padding-right:16px;border-right:1px solid var(--bd);"><div style="font-family:var(--fs);font-size:40px;font-weight:700;color:var(--g200);">${avg}</div><div style="font-size:16px;color:var(--g300);">${'★'.repeat(Math.round(avg))}${'☆'.repeat(5-Math.round(avg))}</div><div style="font-size:10.5px;color:var(--ink3);margin-top:3px;">${myR.length}개 리뷰</div></div>
      <div style="flex:1;">${[5,4,3,2,1].map(s=>{const cnt=myR.filter(r=>r.rating===s).length;const pct=Math.round(cnt/myR.length*100);return`<div style="display:flex;align-items:center;gap:7px;margin-bottom:5px;"><span style="font-size:11px;color:var(--g300);width:18px;">${s}★</span><div style="flex:1;height:5px;border-radius:3px;background:var(--bg2);overflow:hidden;"><div style="width:${pct}%;height:100%;background:linear-gradient(90deg,var(--g300),var(--ta));border-radius:3px;"></div></div><span style="font-size:10.5px;color:var(--ink3);width:26px;">${pct}%</span></div>`;}).join('')}</div>
    </div>
    ${myR.map(r=>{const from=S.users.find(x=>x.id===r.userId);return`<div class="review-card"><div style="display:flex;align-items:center;gap:9px;margin-bottom:7px;"><div class="av">${from?from.name[0]:'?'}</div><div><div style="font-size:12.5px;font-weight:500;">${from?from.name:'익명'}</div><div style="font-size:10px;color:var(--ink3);">${r.date}</div></div><div class="stars" style="margin-left:auto;">${'★'.repeat(r.rating)}${'☆'.repeat(5-r.rating)}</div></div><div style="font-size:12px;color:var(--ink3);line-height:1.65;">${r.comment}</div></div>`;}).join('')}`}
    </div>`;
  }
  else if(tab==='subscription'){
    main.innerHTML=`<div class="cc"><div class="cct">💎 구독 관리</div>
    <div style="border:1.5px solid ${plan==='ultra'?'var(--g400)':plan==='pro'?'var(--ta)':'var(--bd)'};border-radius:var(--rl);padding:17px;margin-bottom:15px;background:${plan==='ultra'?'rgba(212,160,23,0.03)':plan==='pro'?'rgba(49,144,112,0.03)':'var(--sf2)'};">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:11px;"><span style="font-size:22px;">${plan==='ultra'?'👑':plan==='pro'?'🎨':'🖌️'}</span><div><div style="font-family:var(--fs);font-size:15px;font-weight:600;color:${plan==='ultra'?'var(--g200)':'var(--tc)'};">${plan.toUpperCase()} 플랜</div><div style="font-size:11px;color:var(--ink3);">${plan==='free'?'무료 이용 중':plan==='pro'?'₩3,990/월 자동 결제':'₩5,990/월 자동 결제'}</div></div></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;"><div class="hlr" style="margin-bottom:0;"><span>슬롯</span><span class="hlv">${PLAN_SLOTS[plan]}개</span></div><div class="hlr" style="margin-bottom:0;"><span>수수료</span><span class="hlv">${PLAN_FEE[plan]}%</span></div><div class="hlr" style="margin-bottom:0;"><span>타입</span><span class="hlv">${PLAN_TYPES[plan]}개</span></div></div>
    </div>
    ${plan==='free'?`<button class="btn btn-teal" onclick="openM('mSubscribe')">업그레이드하기</button>`:`<button class="btn btn-ghost" style="font-size:12px;color:#e55;border-color:rgba(200,50,50,.3);" onclick="cancelSub()">구독 해지</button>`}
    </div>`;
  }
  else if(tab==='settings'){
    main.innerHTML=`<div class="cc"><div class="cct">⚙️ 계정 설정</div>
    <!-- 프로필 아바타 업로드 -->
    <div class="fg"><label class="fl2">프로필 이미지</label>
      <div style="display:flex;align-items:center;gap:12px;">
        <div class="pav" style="width:52px;height:52px;position:relative;margin:0;overflow:hidden;">${u.avatarUrl?`<img src="${u.avatarUrl}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`:`<span style="font-size:17px;">${u.name[0]}</span>`}</div>
        <div><button class="btn btn-ghost btn-sm" onclick="document.getElementById('avatarInput').click()">이미지 변경</button><input type="file" id="avatarInput" accept="image/*" style="display:none" onchange="handleAvatar(this)"><div style="font-size:10.5px;color:var(--ink3);margin-top:4px;">JPG, PNG · 최대 3MB</div></div>
      </div>
    </div>
    <div class="fg"><label class="fl2">닉네임</label><input class="fi2" id="setName" value="${u.name}" type="text"></div>
    <div class="fg"><label class="fl2">한줄 소개</label><input class="fi2" id="setBio" value="${u.bio||''}" type="text" placeholder="나를 소개해주세요"></div>
    <div class="fg"><label class="fl2">태그 (쉼표 구분)</label><input class="fi2" id="setTags" value="${(u.tags||[]).join(', ')}" type="text" placeholder="동양풍, 판타지, 여성캐릭터"></div>
    <div class="fg"><label class="fl2">Discord 웹훅 URL</label><input class="fi2" id="setWebhook" value="${u.webhookUrl||''}" type="text" placeholder="https://discord.com/api/webhooks/..."></div>
    <!-- 수익 계좌 -->
    <div class="fg"><label class="fl2">수익 정산 계좌</label>
      ${u.bankAccount
        ? `<div style="display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--sf2);border:1px solid var(--bd);border-radius:8px;">
            <span style="font-size:18px;">🏦</span>
            <div style="flex:1;"><div style="font-size:13px;font-weight:500;">${u.bankAccount.bank}</div><div style="font-size:11.5px;color:var(--ink3);">${u.bankAccount.number} · ${u.bankAccount.holder}</div></div>
            <button class="btn btn-ghost btn-sm" onclick="openM('mBankAccount')">변경</button>
          </div>`
        : `<div style="display:flex;align-items:center;justify-content:space-between;gap:10px;padding:10px 12px;background:var(--sf2);border:1px dashed var(--bd2);border-radius:8px;">
            <span style="font-size:12px;color:var(--ink3);">등록된 계좌가 없습니다</span>
            <button class="btn btn-teal btn-sm" onclick="openM('mBankAccount')">계좌 등록</button>
          </div>`}
    </div>
    <div class="fg"><label class="fl2">알림 설정</label>
      <div style="display:flex;flex-direction:column;gap:7px;margin-top:4px;">
        <label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:12px;"><input type="checkbox" checked> 새 문의 알림 (Discord)</label>
        <label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:12px;"><input type="checkbox" checked> 결제 완료 알림 (Discord)</label>
        <label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:12px;"><input type="checkbox" checked> 커미션 상태 변경 알림</label>
      </div>
    </div>
    <!-- 워터마크 설정 -->
    <div class="fg">
      <label class="fl2">🔒 워터마크 설정</label>
      <div style="padding:14px 16px;background:var(--sf2);border:1px solid var(--bd);border-radius:10px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
          <div>
            <div style="font-size:13px;font-weight:500;color:var(--ink);margin-bottom:3px;">포트폴리오 워터마크</div>
            <div style="font-size:11px;color:var(--ink3);">업로드 시 자동으로 <strong style="color:var(--tc);">© ${u.handle||u.name} via KIMAS</strong> 삽입</div>
          </div>
          <label style="position:relative;display:inline-block;width:44px;height:24px;flex-shrink:0;">
            <input type="checkbox" id="wmToggle" ${u.watermark!==false?'checked':''} onchange="toggleWatermark(this.checked)" style="opacity:0;width:0;height:0;">
            <span style="position:absolute;inset:0;background:${u.watermark!==false?'var(--tc)':'var(--bd)'};border-radius:12px;cursor:pointer;transition:0.2s;" id="wmSlider">
              <span style="position:absolute;width:18px;height:18px;background:#fff;border-radius:50%;top:3px;left:${u.watermark!==false?'23px':'3px'};transition:0.2s;"></span>
            </span>
          </label>
        </div>
        <div style="font-size:10.5px;color:var(--ink3);padding:8px 10px;background:rgba(86,201,172,0.05);border-radius:6px;border-left:2px solid var(--tc);">
          💡 워터마크는 우측 하단에 반투명하게 표시됩니다. 무단 도용 방지에 도움이 됩니다.
        </div>
      </div>
    </div>
    </div>
    <button class="btn btn-teal" onclick="saveSettings()">변경사항 저장</button>
    </div>`;
  }
}

// ══════════════════════════════
//  DASHBOARD HELPERS
// ══════════════════════════════
function miniCommCard(c,detailed=false){
  const em=EMOJIS[c.id%EMOJIS.length];const plan=S.currentUser?.plan||'free';
  const sMap={open:'모집 중',waiting:'대기 중',closed:'마감'};
  const bump=(Date.now()-c.bumpedAt)/3600000;const canBump=bump>=30;
  return`<div style="display:flex;align-items:center;gap:10px;padding:10px 13px;background:var(--sf2);border:1px solid var(--bd);border-radius:8px;flex-wrap:wrap;">
    ${c.thumbUrl?`<img src="${c.thumbUrl}" style="width:42px;height:42px;object-fit:cover;border-radius:7px;flex-shrink:0;">`:`<span style="font-size:20px;">${em}</span>`}
    <div style="flex:1;min-width:120px;"><div style="font-size:12.5px;font-weight:500;color:var(--ink);">${c.title}</div><div style="font-size:10.5px;color:var(--ink3);">${c.types.join(', ')} · ₩${c.minPrice.toLocaleString()}~</div></div>
    <span style="padding:2px 7px;border-radius:5px;font-size:10.5px;background:${c.status==='open'?'rgba(49,144,112,0.15)':c.status==='waiting'?'rgba(212,160,23,0.12)':'rgba(60,90,80,0.1)'};color:${c.status==='open'?'var(--tc)':c.status==='waiting'?'var(--g200)':'var(--ink3)'};">${sMap[c.status]}</span>
    <div style="display:flex;gap:5px;">
      <button class="btn btn-ghost btn-sm" onclick="bumpComm(${c.id})" style="${canBump?'':'opacity:.4;'}" title="${canBump?'끌올':'쿨타임 중 ('+(30-bump).toFixed(1)+'h)'}">⬆ 끌올</button>
      <button class="btn btn-ghost btn-sm" style="color:#e55;border-color:rgba(200,50,50,.3);" onclick="deleteComm(${c.id})">삭제</button>
    </div>
  </div>`;
}

async function handleAvatar(input){
  const file=input.files[0];if(!file)return;
  if(file.size>3*1024*1024){toast('이미지 크기는 3MB 이하여야 합니다.','err');return;}
  const data=await readFileAsDataURL(file);
  S.currentUser.avatarUrl=data;
  const idx=S.users.findIndex(x=>x.id===S.currentUser.id);if(idx>=0)S.users[idx].avatarUrl=data;
  save();toast('프로필 이미지가 업데이트되었습니다.','ok');showDash('settings');renderDash();
}

function saveSettings(){
  const u=S.currentUser;
  u.name=document.getElementById('setName').value.trim()||u.name;
  u.bio=document.getElementById('setBio').value.trim();
  u.tags=document.getElementById('setTags').value.split(',').map(t=>t.trim()).filter(Boolean);
  u.webhookUrl=document.getElementById('setWebhook').value.trim();
  const idx=S.users.findIndex(x=>x.id===u.id);if(idx>=0)S.users[idx]=u;
  save();toast('설정이 저장되었습니다.','ok');renderDash();
}
function cancelSub(){
  S.currentUser.plan='free';const idx=S.users.findIndex(x=>x.id===S.currentUser.id);if(idx>=0)S.users[idx].plan='free';
  save();toast('구독이 해지되었습니다.','ok');showDash('subscription');
}
function delPort(id){
  S.portfolio=S.portfolio.filter(p=>p.id!==id);save();toast('삭제되었습니다.','ok');showDash('portfolio');
}
function acceptInquiry(id){
  const i=S.inquiries.find(x=>x.id===id);if(!i)return;i.status='수락됨';save();toast('문의를 수락했습니다.','ok');showDash('inquiries');
}
function rejectInquiry(id){
  const i=S.inquiries.find(x=>x.id===id);if(!i)return;i.status='거절됨';save();toast('문의를 거절했습니다.','ok');showDash('inquiries');
}

// ══════════════════════════════
//  ARTIST DETAIL PAGE
// ══════════════════════════════
// renderUserProfile 후 프레임·배경 적용
function applyUserProfileDecorations(u){
  if(!u||!u.equipped)return;
  const eq=u.equipped;
  // 배경
  if(eq.bg){
    const header=document.getElementById('uprofHeader');
    if(header&&BG_CANVASES){
      const bi=PROFILE_ITEMS.find(x=>x.id===eq.bg);
      if(bi){
        header.querySelectorAll('.pbox-bg-canvas').forEach(c=>{c._stopAnim?.();c.remove();});
        const canvas=document.createElement('canvas');
        canvas.className='pbox-bg-canvas';
        canvas.style.cssText='position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;';
        header.insertBefore(canvas,header.firstChild);
        setTimeout(()=>{canvas.width=header.offsetWidth||600;canvas.height=header.offsetHeight||200;BG_CANVASES[bi.value]?.(canvas);},80);
      }
    }
  }
  // 프레임
  if(eq.frame){
    const av=document.getElementById('uprofAv');
    if(av&&FRAME_SVGS){
      const fi=PROFILE_ITEMS.find(x=>x.id===eq.frame);
      if(fi&&FRAME_SVGS[fi.value]){
        av.parentElement.querySelectorAll('.pav-frame-svg').forEach(e=>e.remove());
        const tmp=document.createElement('div');tmp.innerHTML=FRAME_SVGS[fi.value];
        const svg=tmp.firstElementChild;
        if(svg)av.parentElement.appendChild(svg);
      }
    }
  }
}

function viewArtist(artistId){S.selectedArtistId=artistId;goto('artist-detail');}
function renderAD(){
  const cont=document.getElementById('adContent');if(!cont)return;
  const artist=S.users.find(u=>u.id===S.selectedArtistId);
  if(!artist){cont.innerHTML='<p style="color:var(--ink3);padding:30px;">작가를 찾을 수 없습니다.</p>';return;}
  const comms=S.commissions.filter(c=>c.artistId===artist.id);
  const myPort=S.portfolio.filter(p=>p.userId===artist.id);
  const myR=S.reviews.filter(r=>r.artistId===artist.id);
  const avg=myR.length?Math.round(myR.reduce((a,r)=>a+r.rating,0)/myR.length*10)/10:null;
  cont.innerHTML=`
  <button onclick="goto('artists')" style="display:inline-flex;align-items:center;gap:5px;background:none;border:none;cursor:pointer;font-size:12px;color:var(--ink3);margin-bottom:18px;font-family:var(--fn);">← 목록으로</button>
  <!-- 작가 헤더 -->
  <div style="background:linear-gradient(135deg,var(--t200),var(--sf));border:1px solid var(--bdg);border-radius:var(--rl);padding:22px;margin-bottom:20px;position:relative;overflow:hidden;">
    <div style="position:absolute;right:18px;top:50%;transform:translateY(-50%);font-family:var(--fs);font-size:100px;opacity:.02;pointer-events:none;">蒼</div>
    <div style="display:flex;align-items:flex-start;gap:16px;flex-wrap:wrap;">
      <div class="artist-row-av" style="width:72px;height:72px;font-size:22px;">${artist.avatarUrl?`<img src="${artist.avatarUrl}">`:`${artist.name[0]}`}</div>
      <div style="flex:1;min-width:160px;">
        <div style="font-family:var(--fs);font-size:20px;font-weight:600;color:var(--tc);margin-bottom:2px;">${artist.name}${artist.plan!=='free'?`<span class="pb ${artist.plan==='ultra'?'pb-u':'pb-p'}">${artist.plan.toUpperCase()}</span>`:''}</div>
        <div style="font-size:11.5px;color:var(--ink3);margin-bottom:8px;">${artist.handle} · 가입일 ${artist.createdAt}</div>
        ${artist.bio?`<div style="font-size:12.5px;color:var(--ink2);line-height:1.6;margin-bottom:8px;">${artist.bio}</div>`:''}
        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:10px;">${(artist.tags||[]).map(t=>`<span class="tag">${t}</span>`).join('')}</div>
        <div style="display:flex;gap:16px;flex-wrap:wrap;">
          <div style="text-align:center;"><div style="font-size:16px;font-weight:700;color:var(--ta);">${artist.done}</div><div style="font-size:9.5px;color:var(--ink3);">완료</div></div>
          <div style="text-align:center;"><div style="font-size:16px;font-weight:700;color:${avg?'var(--g200)':'var(--ink3)'};">${avg||'—'}</div><div style="font-size:9.5px;color:var(--ink3);">평점</div></div>
          <div style="text-align:center;"><div style="font-size:16px;font-weight:700;color:var(--ta);">${artist.followers}</div><div style="font-size:9.5px;color:var(--ink3);">팔로워</div></div>
          <div style="text-align:center;"><div style="font-size:16px;font-weight:700;color:var(--ta);">${myPort.length}</div><div style="font-size:9.5px;color:var(--ink3);">포트폴리오</div></div>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:7px;">
        <button class="btn btn-teal" onclick="requireLogin(()=>{openInquiryFor(${artist.id});})">💬 문의하기</button>
        <button class="btn btn-ghost" onclick="toast('팔로우 기능은 준비 중입니다.','ok')">🤍 팔로우</button>
        <button class="btn btn-ghost btn-sm" style="color:#e87;border-color:rgba(200,80,80,.25);font-size:11px;" onclick="requireLogin(()=>openReport(${artist.id},'${artist.name}','기타'))">🚨 신고</button>
      </div>
    </div>
  </div>
  <!-- 탭 -->
  <div class="tab-bar">
    <button class="tab-btn active" onclick="switchADTab('ad-comms',this)">🎨 커미션 (${comms.length})</button>
    <button class="tab-btn" onclick="switchADTab('ad-content',this)">📝 상세 내용</button>
    <button class="tab-btn" onclick="switchADTab('ad-port',this)">🖼️ 포트폴리오 (${myPort.length})</button>
    <button class="tab-btn" onclick="switchADTab('ad-reviews',this)">⭐ 리뷰 (${myR.length})</button>
    <button class="tab-btn" onclick="switchADTab('ad-guide',this)">📋 가이드라인</button>
  </div>
  <div id="ad-comms" class="tab-content active">${comms.length===0?emptyHtml('🖌️','커미션 없음','이 작가의 커미션이 없습니다.'):`<div class="card-grid">${comms.map(c=>commCard(c,true)).join('')}</div>`}</div>
  <div id="ad-content" class="tab-content"><div class="cc"><div id="adRichContent" style="font-size:13.5px;color:var(--ink);line-height:1.75;">${emptyHtml('📝','탭을 클릭하면 내용이 표시됩니다','')}</div></div></div>
  <div id="ad-port" class="tab-content">${myPort.length===0?emptyHtml('🖼️','포트폴리오 없음','아직 업로드된 작품이 없습니다.'):`<div class="portfolio-grid">${myPort.map(p=>`<div class="port-item" onclick="openLB('${p.imgUrl}')"><img src="${p.imgUrl}" alt="${p.desc||''}"><div class="port-overlay">🔍 ${p.desc||'크게 보기'}</div></div>`).join('')}</div>`}</div>
  <div id="ad-reviews" class="tab-content">${myR.length===0?emptyHtml('⭐','리뷰 없음','아직 리뷰가 없습니다.'):myR.map(r=>{const from=S.users.find(x=>x.id===r.userId);return`<div class="review-card"><div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;"><div class="av">${from?from.name[0]:'?'}</div><div><div style="font-size:12.5px;font-weight:500;">${from?from.name:'익명'}</div><div style="font-size:10px;color:var(--ink3);">${r.date}</div></div><div class="stars" style="margin-left:auto;">${'★'.repeat(r.rating)}${'☆'.repeat(5-r.rating)}</div></div><div style="font-size:12px;color:var(--ink3);line-height:1.65;">${r.comment}</div></div>`;}).join('')}</div>
  <div id="ad-guide" class="tab-content"><div class="cc"><div style="font-family:var(--fs);font-size:15px;font-weight:600;color:var(--tc);margin-bottom:13px;">커미션 가이드라인</div>
    <div style="display:flex;flex-direction:column;gap:13px;" id="adGuideContent">
    </div>
  </div></div>`;
}
function switchADTab(id,btn){
  document.querySelectorAll('[id^="ad-"]').forEach(t=>t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.closest('.tab-bar').querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');

  // 상세 내용 탭: 리치 에디터 내용 렌더
  if(id==='ad-content'){
    const artist=S.users.find(u=>u.id===S.selectedArtistId);
    const comms=S.commissions.filter(c=>c.artistId===artist?.id);
    const contentDiv=document.getElementById('adRichContent');
    if(contentDiv){
      const allContent=comms.filter(c=>c.richContent).map(c=>`
        <div style="margin-bottom:20px;">
          <div style="font-family:var(--fs);font-size:14px;font-weight:600;color:var(--tc);margin-bottom:8px;padding-bottom:6px;border-bottom:1px solid var(--bd);">${c.title}</div>
          <div style="font-size:13.5px;color:var(--ink);line-height:1.75;">${c.richContent}</div>
        </div>`).join('');
      contentDiv.innerHTML=allContent||emptyHtml('📝','상세 내용 없음','작가가 아직 상세 내용을 작성하지 않았습니다.');
    }
  }
  // 가이드라인 탭
  if(id==='ad-guide'){
    const artist=S.users.find(u=>u.id===S.selectedArtistId);
    const comms=S.commissions.filter(c=>c.artistId===artist?.id&&c.guideline);
    const guideDiv=document.getElementById('adGuideContent');
    if(guideDiv){
      const g=comms[0]?.guideline;
      guideDiv.innerHTML=g?`
        ${g.canDo?`<div><div style="font-size:13px;font-weight:500;color:var(--tc);margin-bottom:6px;">✅ 가능한 의뢰</div><div style="font-size:12.5px;color:var(--ink3);line-height:1.8;white-space:pre-wrap;">${g.canDo}</div></div>`:''}
        ${g.cantDo?`<div><div style="font-size:13px;font-weight:500;color:#e87;margin-bottom:6px;">❌ 불가능한 의뢰</div><div style="font-size:12.5px;color:var(--ink3);line-height:1.8;white-space:pre-wrap;">${g.cantDo}</div></div>`:''}
        ${g.deadline?`<div><div style="font-size:13px;font-weight:500;color:var(--g300);margin-bottom:4px;">⏰ 납기일</div><div style="font-size:12.5px;color:var(--ink3);">${g.deadline}</div></div>`:''}
        ${g.revision?`<div><div style="font-size:13px;font-weight:500;color:var(--g300);margin-bottom:4px;">🔄 수정 정책</div><div style="font-size:12.5px;color:var(--ink3);">${g.revision}</div></div>`:''}
        ${g.note?`<div><div style="font-size:13px;font-weight:500;color:var(--ink2);margin-bottom:4px;">📌 추가 안내</div><div style="font-size:12.5px;color:var(--ink3);line-height:1.7;white-space:pre-wrap;">${g.note}</div></div>`:''}
      `:`<div style="font-size:12.5px;color:var(--ink3);">작가가 아직 가이드라인을 작성하지 않았습니다.</div>`;
    }
  }
}

// ══════════════════════════════
//  ADMIN
// ══════════════════════════════
function renderAdmin(){
  // 통계
  document.getElementById('admTU').textContent=S.users.length;
  document.getElementById('admAR').textContent=S.users.filter(u=>u.role==='artist'||u.role==='both').length;
  document.getElementById('admCM').textContent=S.commissions.length;
  document.getElementById('admSK').textContent=S.seekingPosts.length;

  // 수수료 요약
  const earDiv=document.getElementById('adminEarnings');
  if(earDiv)earDiv.innerHTML=renderEarningsSummary();

  // 회원 테이블
  const ut=document.getElementById('admUT');
  if(ut)ut.innerHTML=S.users.length===0?'<p style="color:var(--ink3);padding:16px;font-size:12px;">등록된 회원이 없습니다.</p>':
    `<table class="at"><thead><tr><th>닉네임</th><th>이메일</th><th>역할</th><th>플랜</th><th>상태</th><th>신고수</th><th>가입일</th><th>관리</th></tr></thead>
    <tbody>${S.users.map(u=>{
      const rptCnt=(S.reports||[]).filter(r=>r.targetId==u.id&&r.status!=='반려').length;
      const banned=u.banned;
      return`<tr style="${banned?'opacity:.5;':''}">
        <td><div style="display:flex;align-items:center;gap:7px;">
          <div class="av" style="width:26px;height:26px;font-size:10px;">${u.avatarUrl?`<img src="${u.avatarUrl}" style="width:100%;height:100%;border-radius:50%;object-fit:cover;">`:`${u.name[0]}`}</div>
          <div><div style="font-weight:500;">${u.name}${banned?'<span style="font-size:9.5px;color:#e55;margin-left:4px;">[정지]</span>':''}</div><div style="font-size:9.5px;color:var(--ink3);">${u.handle}</div></div>
        </div></td>
        <td style="color:var(--ink3);font-size:10.5px;">${u.email}</td>
        <td><span class="tag">${{artist:'작가',client:'의뢰인',both:'둘 다'}[u.role]||u.role}</span></td>
        <td>${u.plan==='ultra'?`<span class="pb pb-u">ULTRA</span>`:u.plan==='pro'?`<span class="pb pb-p">PRO</span>`:`<span style="font-size:10px;color:var(--ink3);">Free</span>`}</td>
        <td><span style="font-size:10.5px;padding:2px 6px;border-radius:5px;background:${banned?'rgba(200,50,50,0.15)':'rgba(49,144,112,0.12)'};color:${banned?'#e55':'var(--tc)'};">${banned?'정지':'정상'}</span></td>
        <td style="font-size:12px;font-weight:${rptCnt>=3?'700':'400'};color:${rptCnt>=3?'#e55':'var(--ink3)'};">${rptCnt}건</td>
        <td style="font-size:10.5px;color:var(--ink3);">${u.createdAt}</td>
        <td><div style="display:flex;gap:4px;flex-wrap:wrap;">
          <button class="btn btn-ghost btn-sm" onclick="adminGiveUltra(${u.id})">Ultra</button>
          ${banned
            ?`<button class="btn btn-ghost btn-sm" style="color:var(--tc);" onclick="adminUnban(${u.id})">해제</button>`
            :`<button class="btn btn-ghost btn-sm" style="color:#e55;" onclick="adminBanUser(${u.id},false)">경고</button>
              <button class="btn btn-ghost btn-sm" style="color:#e55;border-color:rgba(200,50,50,.3);" onclick="adminBanUser(${u.id},true)">정지</button>`}
        </div></td>
      </tr>`;}).join('')}</tbody></table>`;

  // 커미션 테이블
  const ct=document.getElementById('admCT');
  if(ct)ct.innerHTML=S.commissions.length===0?'<p style="color:var(--ink3);padding:16px;font-size:12px;">등록된 커미션이 없습니다.</p>':
    `<div style="margin-bottom:12px;display:flex;gap:8px;flex-wrap:wrap;">
      <input class="fi2" id="admCommSearch" type="text" placeholder="🔍 커미션/작가 검색..." style="max-width:240px;padding:7px 11px;font-size:12px;" oninput="renderAdminCommTable()">
      <select class="fs2" id="admCommStatus" style="padding:7px 11px;font-size:12px;width:auto;" onchange="renderAdminCommTable()">
        <option value="">전체 상태</option><option value="open">모집 중</option><option value="waiting">대기 중</option><option value="closed">마감</option>
      </select>
      <select class="fs2" id="admCommFlag" style="padding:7px 11px;font-size:12px;width:auto;" onchange="renderAdminCommTable()">
        <option value="">전체</option><option value="flagged">신고 있음</option><option value="hidden">숨김 처리됨</option>
      </select>
    </div>
    <div id="admCommTableBody"></div>`;
  renderAdminCommTable();

  // 구해요 테이블
  const st=document.getElementById('admST');
  if(st)renderAdminSeekTable();
}

// saveOwnerWebhook — 아래 통합 버전으로 대체됨

function adminGiveUltra(id){const u=S.users.find(x=>x.id===id);if(!u)return;u.plan='ultra';if(S.currentUser&&S.currentUser.id===id)S.currentUser.plan='ultra';save();toast(u.name+'님에게 Ultra 부여됨','ok');renderAdmin();}
function adminDelUser(id){if(!confirm('이 회원을 삭제하시겠습니까?'))return;S.users=S.users.filter(u=>u.id!==id);S.commissions=S.commissions.filter(c=>c.artistId!==id);save();toast('회원 삭제됨','ok');renderAdmin();}
function adminDelComm(id){S.commissions=S.commissions.filter(c=>c.id!==id);save();toast('커미션 삭제됨','ok');renderAdmin();}

// ── 처벌 시스템 ──
// 기준: 신고 1건=경고, 3건=1주일 정지, 5건=영구 정지
const PENALTY_RULES=[
  {count:1, action:'warn',  label:'경고',      color:'#f5d060', days:0},
  {count:3, action:'ban7',  label:'7일 정지',  color:'#e87',    days:7},
  {count:5, action:'ban',   label:'영구 정지', color:'#e55',    days:999999},
];

function autoPenalty(targetId){
  const u=S.users.find(x=>x.id==targetId);if(!u)return;
  const rptCnt=(S.reports||[]).filter(r=>r.targetId==targetId&&r.status!=='반려').length;
  const rule=[...PENALTY_RULES].reverse().find(r=>rptCnt>=r.count);
  if(!rule)return;
  if(rule.action==='warn'){
    u.warnings=(u.warnings||0)+1;
    toast(`⚠️ ${u.name}님에게 경고가 누적되었습니다. (총 ${u.warnings}회)`,'ok');
  } else {
    const banUntil=rule.days===999999?null:Date.now()+rule.days*86400000;
    u.banned=true;u.banUntil=banUntil;u.banReason=`신고 ${rptCnt}건 누적`;
    toast(`🚫 ${u.name}님이 자동으로 ${rule.label} 처리되었습니다.`,'ok');
    // Discord 알림
    const webhook=getOwnerWebhook();
    if(webhook)sendDiscord(webhook,{
      title:`🚫 자동 처벌 — ${rule.label}`,color:0xe74c3c,
      fields:[
        {name:'대상',value:u.name,inline:true},
        {name:'처벌',value:rule.label,inline:true},
        {name:'누적 신고',value:`${rptCnt}건`,inline:true},
        {name:'사유',value:`신고 ${rptCnt}건 자동 처벌`},
      ],timestamp:new Date().toISOString(),footer:{text:'KIMAS 자동 처벌 시스템'}
    });
  }
  save();renderAdmin();
}

function adminBanUser(id, permanent){
  const u=S.users.find(x=>x.id===id);if(!u)return;
  const days=permanent?999999:7;
  u.banned=true;u.banUntil=permanent?null:Date.now()+days*86400000;u.banReason='관리자 수동 처리';
  if(S.currentUser?.id===id){S.currentUser=null;updateNav();}
  save();toast(`${u.name}님이 ${permanent?'영구':'7일'} 정지되었습니다.`,'ok');
  // Discord 알림
  const webhook=getOwnerWebhook();
  if(webhook)sendDiscord(webhook,{
    title:`🚫 수동 처벌 — ${permanent?'영구 정지':'7일 정지'}`,color:0xe74c3c,
    fields:[{name:'대상',value:u.name,inline:true},{name:'처벌',value:permanent?'영구 정지':'7일 정지',inline:true}],
    timestamp:new Date().toISOString(),footer:{text:'KIMAS 관리자'}
  });
  renderAdmin();
}

function adminUnban(id){
  const u=S.users.find(x=>x.id===id);if(!u)return;
  u.banned=false;u.banUntil=null;u.banReason=null;
  save();toast(`${u.name}님의 정지가 해제되었습니다.`,'ok');renderAdmin();
}

// 로그인 시 정지 여부 체크
// doLogin redefined above
function switchAdminTab(id,btn){
  // 관리자 패널 안의 모든 tab-content 숨기기
  document.querySelectorAll('#page-admin .tab-content').forEach(t=>t.classList.remove('active'));
  const target=document.getElementById(id);
  if(target)target.classList.add('active');
  // 버튼 active 처리
  if(btn){
    btn.closest('.tab-bar').querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
  }
}
function publishNotice(){const t=document.getElementById('admNT').value.trim(),b=document.getElementById('admNB').value.trim(),c=document.getElementById('admNC').value;if(!t||!b){toast('제목과 내용을 입력해주세요.','err');return;}S.notices.unshift({id:Date.now(),cat:c,icon:'📢',title:t,body:b,date:new Date().toLocaleDateString('ko-KR')});save();toast('공지사항이 게시되었습니다.','ok');}

// ══════════════════════════════
//  CARD BUILDERS
// ══════════════════════════════
function commCard(c,noNav=false){
  const a=S.users.find(u=>u.id===c.artistId);if(!a)return'';
  const sMap={open:'모집 중',waiting:'대기 중',closed:'마감'};
  const sCls={open:'s-open',waiting:'s-wait',closed:'s-closed'};
  let dots='';for(let i=0;i<c.slots;i++)dots+=`<div class="dot${i<c.filledSlots?' on':''}"></div>`;
  const em=EMOJIS[c.id%EMOJIS.length];
  const avHtml=a.avatarUrl?`<img src="${a.avatarUrl}">`:`${a.name[0]}`;
  const thumbHtml=c.thumbUrl?`<img src="${c.thumbUrl}" style="width:100%;height:100%;object-fit:cover;">`:`<div class="card-pat"></div><span class="card-emoji">${em}</span>`;
  return`<div class="comm-card" onclick="viewArtist(${a.id})">
    <div class="card-thumb">${thumbHtml}<div class="c-st ${sCls[c.status]}">${sMap[c.status]}</div></div>
    <div class="card-body">
      <div class="card-artist-row"><div class="av">${avHtml}</div><div><div class="a-nm">${a.name}${a.plan!=='free'?`<span class="pb ${a.plan==='ultra'?'pb-u':'pb-p'}">${a.plan.toUpperCase()}</span>`:''}</div><div class="a-sb">⭐ ${a.rating||'신규'} · ${a.done}건</div></div></div>
      <div class="card-title">${c.title}</div>
      <div class="type-tags">${c.types.map(t=>`<span class="tag">${t}</span>`).join('')}</div>
      ${c.sampleUrls&&c.sampleUrls.length?`<div style="display:flex;gap:4px;flex-wrap:wrap;">${c.sampleUrls.slice(0,4).map(u=>`<img src="${u}" style="width:48px;height:48px;object-fit:cover;border-radius:6px;border:1px solid var(--bd);cursor:pointer;" onclick="event.stopPropagation();openLB('${u}')">`).join('')}</div>`:``}
      <div class="card-bot">
        <span class="price">₩${c.minPrice.toLocaleString()}${c.maxPrice>c.minPrice?'~':''}</span>
        <div class="sdots">${dots}<span style="margin-left:2px;">${c.filledSlots}/${c.slots}</span></div>
      </div>
      <!-- 문의 + 신고 버튼 -->
      <div style="display:flex;gap:6px;padding-top:8px;border-top:1px solid var(--bd);margin-top:2px;" onclick="event.stopPropagation()">
        <button class="btn btn-teal btn-sm" style="flex:1;justify-content:center;" onclick="requireLogin(()=>{openInquiryFor(${a.id});})">💬 문의하기</button>
        <button class="btn btn-ghost btn-sm" style="color:#e87;border-color:rgba(200,80,80,.2);padding:5px 9px;" onclick="requireLogin(()=>openReport(${a.id},'${a.name}','기타'))">🚨</button>
      </div>
    </div>
  </div>`;
}

function artistRowCard(a){
  const comms=S.commissions.filter(c=>c.artistId===a.id);
  const port=S.portfolio.filter(p=>p.userId===a.id);
  return`<div class="artist-row" onclick="viewArtist(${a.id})">
    <div class="artist-row-av">${a.avatarUrl?`<img src="${a.avatarUrl}">`:`${a.name[0]}`}</div>
    <div class="artist-row-info">
      <div class="artist-row-name">${a.name}${a.plan!=='free'?`<span class="pb ${a.plan==='ultra'?'pb-u':'pb-p'}">${a.plan.toUpperCase()}</span>`:''}</div>
      <div class="artist-row-handle">${a.handle}</div>
      <div class="artist-row-tags">${(a.tags||[]).slice(0,4).map(t=>`<span class="tag">${t}</span>`).join('')}</div>
    </div>
    <div class="artist-row-stats">
      <div class="ars"><div class="ars-n">${comms.length}</div><div class="ars-l">커미션</div></div>
      <div class="ars"><div class="ars-n">${port.length}</div><div class="ars-l">포트폴리오</div></div>
      <div class="ars"><div class="ars-n">${a.done}</div><div class="ars-l">완료</div></div>
    </div>
    <div style="display:flex;gap:6px;" onclick="event.stopPropagation()">
      <button class="btn btn-teal btn-sm" onclick="requireLogin(()=>{openInquiryFor(${a.id});})">💬 문의</button>
      <button class="btn btn-ghost btn-sm" style="color:#e87;border-color:rgba(200,80,80,.2);" onclick="requireLogin(()=>openReport(${a.id},'${a.name}','기타'))">🚨 신고</button>
    </div>
  </div>`;
}

function emptyHtml(i,t,d){return`<div class="empty"><div class="empty-icon">${i}</div><h3>${t}</h3><p>${d}</p></div>`;}

// ══════════════════════════════
//  MISC
// ══════════════════════════════
function openM(id){
  // 커뮤니티 게시물 초기화
  if(id==='mCommunityPost'){
    if(typeof _postMediaData!=='undefined')_postMediaData=null;
    ['postImgPreview'].forEach(eid=>{const el=document.getElementById(eid);if(el)el.innerHTML='';});
    ['postImgInput','postDesc','postTags'].forEach(eid=>{const el=document.getElementById(eid);if(el)el.value='';});
    const _sa=document.getElementById('postSaveAllow');if(_sa)_sa.checked=false;
    const _ad=document.getElementById('postAdult');if(_ad)_ad.checked=false;
  }
  // 광고 커미션 목록 채우기
  if(id==='mAdPurchase'&&typeof S!=='undefined'&&S.currentUser){
    const myComms=S.commissions.filter(c=>c.artistId===S.currentUser.id);
    const sel=document.getElementById('adCommSel');
    if(sel)sel.innerHTML=myComms.length
      ?myComms.map(c=>`<option value="${c.id}">${c.title}</option>`).join('')
      :'<option value="">커미션이 없습니다</option>';
  }
  const el=document.getElementById(id);
  if(!el)return;
  el.classList.add('open');
  document.body.style.overflow='hidden';
}
function closeM(id){document.getElementById(id).classList.remove('open');document.body.style.overflow='';}
function closeOut(e,id){if(e.target.id===id)closeM(id);}
function switchTab(id,btn){document.querySelectorAll('[id^="tab-c"]').forEach(t=>t.classList.remove('active'));document.getElementById('tab-'+id).classList.add('active');if(btn){btn.closest('.tab-bar').querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');}}
function setF(btn,g,v){S.filters[g]=v;btn.closest('.filter-bar').querySelectorAll('.chip').forEach(c=>c.classList.remove('on'));btn.classList.add('on');if(g==='type')renderAP();if(g==='seek')renderSeeking();}
function submitSub(){if(!S.currentUser){toast('로그인 필요','err');return;}S.currentUser.plan='pro';const idx=S.users.findIndex(u=>u.id===S.currentUser.id);if(idx>=0)S.users[idx].plan='pro';save();closeM('mSubscribe');toast('Pro 구독이 시작되었습니다! ✦','ok');renderDash();}
function selPlan(el,plan){el.closest('.modal').querySelectorAll('[onclick^="selPlan"]').forEach(e=>{e.style.border='1px solid var(--bd)';e.style.background='transparent';});el.style.border=plan==='ultra'?'1.5px solid var(--g400)':'1.5px solid var(--ta)';el.style.background=plan==='ultra'?'rgba(212,160,23,0.04)':'rgba(49,144,112,0.05)';}
function updateStats(){const sa=document.getElementById('statA'),sc=document.getElementById('statC');const aids=new Set(S.commissions.map(c=>c.artistId));if(sa)sa.textContent=aids.size;if(sc)sc.textContent=S.commissions.length;}
function toast(msg,type=''){const w=document.getElementById('tw');const el=document.createElement('div');el.className='toast '+type;el.innerHTML=`<span>${type==='ok'?'✓':type==='err'?'✕':'ℹ'}</span><span>${msg}</span>`;w.appendChild(el);setTimeout(()=>el.style.opacity='0',2800);setTimeout(()=>el.remove(),3200);}

// saveOwnerWebhook — 아래 통합 버전으로 대체됨 (2)

// ══════════════════════════════════════════════════════
//  Discord 웹훅 — 통합 저장 함수
// ══════════════════════════════════════════════════════
function saveOwnerWebhook(){
  // admWebhookInput (관리자 패널 Discord 탭) 에서 URL 읽기
  const input=document.getElementById('admWebhookInput');
  const url=(input?.value||'').trim();

  if(!url){
    toast('웹훅 URL을 입력해주세요.','err');
    return;
  }
  if(!url.startsWith('https://discord.com/api/webhooks/')){
    toast('❌ 올바르지 않은 웹훅 URL입니다.\n\n올바른 형식:\nhttps://discord.com/api/webhooks/숫자ID/토큰\n\n➤ Discord 서버 > 채널 우클릭 > 편집 > 연동 > 웹후크 > URL 복사','err');
    return;
  }

  // 상태에 저장
  const owner=S.users.find(u=>u.isOwner);
  if(owner)owner.webhookUrl=url;
  if(S.currentUser?.isOwner)S.currentUser.webhookUrl=url;
  save();

  toast('저장 중... Discord에 테스트 메시지를 보냅니다.','ok');

  // 즉시 테스트 전송
  sendDiscord(url,{
    title:'✅ KIMAS ↔ Discord 연결 성공!',
    color:0x56c9ac,
    description:'KIMAS 플랫폼과 Discord가 성공적으로 연결되었습니다.\n이제 신고·결제·문의 알림이 이 채널로 전송됩니다.',
    fields:[
      {name:'플랫폼',value:'KIMAS 커미션',inline:true},
      {name:'상태',value:'🟢 연결됨',inline:true},
    ],
    timestamp:new Date().toISOString(),
    footer:{text:'KIMAS 알림 시스템 • 테스트 메시지'}
  }).then(ok=>{
    if(ok!==false){
      toast('✅ Discord 연결 완료! 채널에서 테스트 메시지를 확인하세요.','ok');
    } else {
      toast('⚠ 저장은 완료됐지만 테스트 전송에 실패했습니다.\n\n가능한 원인:\n1. 웹훅 URL이 만료되었거나 삭제됨\n2. 로컬 파일(file://)에서는 CORS 차단됨 → 서버 배포 후 작동\n3. Discord 서버 권한 문제\n\nURL을 다시 확인해주세요.','err');
    }
  });
}


function fillWebhookInput(){
  const owner=S.users.find(u=>u.isOwner);
  const savedUrl=owner?.webhookUrl||'';
  const input=document.getElementById('admWebhookInput');
  if(input&&savedUrl)input.value=savedUrl;
  const statusEl=document.getElementById('webhookStatus');
  if(!statusEl)return;
  if(savedUrl&&savedUrl.startsWith('https://discord.com/api/webhooks/')){
    const masked=savedUrl.replace(/\/([^/]{4})[^/]+$/,'/...$1...');
    statusEl.innerHTML=`<div style="display:flex;align-items:center;gap:9px;padding:10px 14px;background:rgba(86,201,172,0.08);border:1px solid rgba(86,201,172,0.2);border-radius:8px;">
      <span style="font-size:16px;">✅</span>
      <div style="flex:1;min-width:0;">
        <div style="font-size:12.5px;font-weight:500;color:var(--tc);">웹훅 URL 저장됨</div>
        <div style="font-size:10.5px;color:var(--ink3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${masked}</div>
      </div>
      <button class="btn btn-ghost btn-sm" onclick="saveOwnerWebhook()">테스트 전송</button>
    </div>`;
  } else {
    statusEl.innerHTML=`<div style="padding:10px 14px;background:rgba(232,168,0,0.06);border:1px solid rgba(232,168,0,0.2);border-radius:8px;font-size:12px;color:var(--g300);">
      ⚠ 아직 웹훅 URL이 설정되지 않았습니다.
    </div>`;
  }
}

function saveBankAccount(){
  const bank=document.getElementById('bankName').value;
  const number=document.getElementById('bankNumber').value.trim().replace(/[^0-9]/g,'');
  const holder=document.getElementById('bankHolder').value.trim();
  if(!number||!holder){toast('계좌번호와 예금주명을 입력해주세요.','err');return;}
  if(number.length<10){toast('계좌번호를 정확히 입력해주세요.','err');return;}
  const u=S.currentUser;if(!u)return;
  u.bankAccount={bank,number,holder,registeredAt:new Date().toLocaleDateString('ko-KR')};
  const idx=S.users.findIndex(x=>x.id===u.id);if(idx>=0)S.users[idx]=u;
  save();closeM('mBankAccount');toast(`${bank} 계좌가 등록되었습니다. 🏦`,'ok');
  showDash('settings');
}

// ── 광고 슬라이더 ──
let _adIdx=0;
let _adTimer=null;

function renderAds(){
  const now=Date.now();
  const active=(S.ads||[]).filter(a=>a.expiresAt>now);
  const wrap=document.getElementById('adBannerWrap');
  const emptyWrap=document.getElementById('adEmptyWrap');
  if(!wrap)return;
  if(active.length===0){
    wrap.style.display='none';
    if(emptyWrap)emptyWrap.style.display='flex';
    return;
  }
  wrap.style.display='block';
  if(emptyWrap)emptyWrap.style.display='none';
  const slider=document.getElementById('adSlider');
  const dots=document.getElementById('adDots');
  if(!slider)return;
  slider.innerHTML=active.map(ad=>{
    const artist=S.users.find(u=>u.id===ad.userId);
    const comm=S.commissions.find(c=>c.id===ad.commId);
    if(!artist||!comm)return'';
    return`<div style="min-width:100%;padding:0 1px;box-sizing:border-box;">
      <div onclick="viewArtist(${artist.id})" style="cursor:pointer;border-radius:var(--rl);overflow:hidden;border:1px solid var(--bdg);background:linear-gradient(135deg,var(--t300),var(--sf));display:flex;align-items:stretch;min-height:130px;position:relative;">
        <div style="position:absolute;top:10px;left:12px;padding:3px 8px;background:rgba(212,160,23,0.18);border:1px solid var(--bdg);border-radius:5px;font-size:10px;color:var(--g300);font-weight:600;z-index:2;">AD · 스폰서</div>
        <div style="width:180px;flex-shrink:0;background:${comm.thumbUrl?'transparent':'linear-gradient(135deg,var(--t400),var(--t600))'};display:flex;align-items:center;justify-content:center;overflow:hidden;">
          ${comm.thumbUrl?`<img src="${comm.thumbUrl}" style="width:100%;height:100%;object-fit:cover;">`:`<span style="font-size:52px;">${EMOJIS[comm.id%EMOJIS.length]}</span>`}
        </div>
        <div style="flex:1;padding:20px 22px;display:flex;flex-direction:column;justify-content:center;gap:8px;">
          <div style="font-family:var(--fs);font-size:17px;font-weight:600;color:var(--tc);">${comm.title}</div>
          <div style="display:flex;align-items:center;gap:8px;">
            <div class="av" style="width:24px;height:24px;font-size:10px;">${artist.avatarUrl?`<img src="${artist.avatarUrl}">`:`${artist.name[0]}`}</div>
            <span style="font-size:12.5px;color:var(--ink2);">${artist.name}</span>
            ${artist.plan!=='free'?`<span class="pb ${artist.plan==='ultra'?'pb-u':'pb-p'}">${artist.plan.toUpperCase()}</span>`:''}
          </div>
          <div style="display:flex;gap:5px;flex-wrap:wrap;">${comm.types.map(t=>`<span class="tag">${t}</span>`).join('')}</div>
          <div style="font-family:var(--fs);font-size:16px;font-weight:700;color:var(--ta);">₩${comm.minPrice.toLocaleString()}~</div>
        </div>
        <div style="position:absolute;bottom:10px;right:14px;font-size:10.5px;color:var(--ink3);">광고 만료: ${new Date(ad.expiresAt).toLocaleDateString('ko-KR')}</div>
      </div>
    </div>`;
  }).join('');
  // dots
  dots.innerHTML=active.map((_,i)=>`<div onclick="goToAd(${i})" style="width:${_adIdx===i?'18':'6'}px;height:6px;border-radius:3px;background:${_adIdx===i?'var(--g300)':'rgba(255,255,255,.25)'};cursor:pointer;transition:all .3s;"></div>`).join('');
  slider.style.transform=`translateX(-${_adIdx*100}%)`;
  // prev/next visibility
  const prev=document.getElementById('adPrev'),next=document.getElementById('adNext');
  if(prev)prev.style.display=active.length>1?'flex':'none';
  if(next)next.style.display=active.length>1?'flex':'none';
  // auto slide
  if(_adTimer)clearInterval(_adTimer);
  if(active.length>1)_adTimer=setInterval(()=>slideAd(1),4000);
}

function slideAd(dir){
  const now=Date.now();
  const active=(S.ads||[]).filter(a=>a.expiresAt>now);
  if(!active.length)return;
  _adIdx=(_adIdx+dir+active.length)%active.length;
  renderAds();
}
function goToAd(i){_adIdx=i;renderAds();}

// ── 광고 구매 ──
let _selectedAdDays=4,_selectedAdPrice=3000;
function selectAdPlan(el){
  document.querySelectorAll('.ad-plan-opt').forEach(e=>e.classList.remove('on'));
  el.classList.add('on');
  _selectedAdDays=parseInt(el.dataset.days);
  _selectedAdPrice=parseInt(el.dataset.price);
  const priceEl=document.getElementById('adTotalPrice');
  if(priceEl)priceEl.textContent=_selectedAdPrice.toLocaleString();
}

function openAdPurchase(){
  const myComms=S.commissions.filter(c=>c.artistId===S.currentUser?.id);
  const sel=document.getElementById('adCommSel');
  if(!sel)return;
  if(!myComms.length){toast('먼저 커미션을 등록해주세요.','err');return;}
  sel.innerHTML=myComms.map(c=>`<option value="${c.id}">${c.title}</option>`).join('');
  _selectedAdDays=4;_selectedAdPrice=3000;
  document.querySelectorAll('.ad-plan-opt').forEach((e,i)=>{e.classList.toggle('on',i===0);});
  const priceEl=document.getElementById('adTotalPrice');if(priceEl)priceEl.textContent='3,000';
  openM('mAdPurchase');
}

async function purchaseAd(){
  if(!S.currentUser){toast('로그인이 필요합니다.','err');return;}
  const commId=parseInt(document.getElementById('adCommSel').value);
  if(!commId){toast('커미션을 선택해주세요.','err');return;}
  // 관리자 무료
  if(S.currentUser.isOwner){
    const expiresAt=Date.now()+_selectedAdDays*24*3600*1000;
    if(!S.ads)S.ads=[];
    S.ads.push({id:Date.now(),userId:S.currentUser.id,commId,days:_selectedAdDays,price:0,expiresAt,createdAt:new Date().toLocaleDateString('ko-KR')});
    save();closeM('mAdPurchase');toast(`광고가 무료로 등록됐습니다! ${_selectedAdDays}일간 노출됩니다. 👑`,'ok');renderAds();return;
  }
  const tossPayments=TossPayments(TOSS_CLIENT_KEY);
  const orderId='ad_'+Date.now();
  // 결제 전 광고 정보를 임시 저장
  sessionStorage.setItem('pendingAd',JSON.stringify({commId,days:_selectedAdDays,price:_selectedAdPrice,userId:S.currentUser.id}));
  try{
    await tossPayments.requestPayment('카드',{
      amount:_selectedAdPrice,orderId,
      orderName:`[KIMAS] 광고 ${_selectedAdDays}일`,
      customerName:S.currentUser.name,
      successUrl:window.location.href+'?adpay=success&orderId='+orderId,
      failUrl:window.location.href+'?adpay=fail',
    });
  }catch(e){if(e.code!=='USER_CANCEL')toast('결제 오류: '+e.message,'err');}
}

function handleAdPaymentSuccess(){
  const params=new URLSearchParams(window.location.search);
  if(params.get('adpay')!=='success')return;
  const pending=sessionStorage.getItem('pendingAd');
  if(!pending)return;
  const {commId,days,price,userId}=JSON.parse(pending);
  const expiresAt=Date.now()+days*24*3600*1000;
  if(!S.ads)S.ads=[];
  S.ads.push({id:Date.now(),userId,commId,days,price,expiresAt,createdAt:new Date().toLocaleDateString('ko-KR')});
  save();
  sessionStorage.removeItem('pendingAd');
  toast(`광고가 등록되었습니다! ${days}일간 홈에 노출됩니다. 🎉`,'ok');
  window.history.replaceState({},'',window.location.pathname);
  renderAds();
}

// ── 신고 — 모든 유저에 공유 (state에 저장) ──
// reports가 이미 state에 있는지 확인 후 없으면 초기화
if(!S.reports)S.reports=[];

// ── 신고 처리 ──
function renderReportsTab(){
  const rptList=document.getElementById('admRptList');
  if(!rptList)return;
  if(!(S.reports||[]).length){
    rptList.innerHTML='<div class="empty" style="padding:28px 0;"><div class="empty-icon">🚨</div><h3>신고 내역이 없습니다</h3></div>';
    return;
  }
  rptList.innerHTML=(S.reports||[]).map(r=>{
    const rptCnt=(S.reports||[]).filter(x=>x.targetId==r.targetId&&x.status!=='반려').length;
    return`<div style="border:1px solid rgba(200,60,60,0.2);border-radius:9px;padding:13px;margin-bottom:10px;background:rgba(200,60,60,0.03);">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:7px;">
        <div>
          <div style="font-size:13px;font-weight:500;color:var(--ink);">[${r.type}] <span style="color:var(--ink3);">신고자:</span> ${r.reporterName} → <span style="color:#e87;">대상:</span> ${r.targetName}</div>
          <div style="font-size:10.5px;color:var(--ink3);">${r.date}</div>
        </div>
        <span style="padding:3px 9px;border-radius:6px;font-size:11px;background:${r.status==='대기 중'?'rgba(212,160,23,0.15)':r.status==='처리완료'?'rgba(49,144,112,0.12)':'rgba(60,90,80,0.1)'};color:${r.status==='대기 중'?'var(--g200)':r.status==='처리완료'?'var(--tc)':'var(--ink3)'};">${r.status}</span>
      </div>
      <div style="font-size:12px;color:var(--ink3);margin-bottom:7px;">${r.desc}</div>
      <div style="font-size:11px;background:var(--sf2);border-radius:6px;padding:6px 10px;margin-bottom:9px;">
        누적 신고: <strong style="color:${rptCnt>=3?'#e55':'var(--ink2)'};">${rptCnt}건</strong>
        <span style="color:var(--ink3);margin-left:8px;">기준: 1건=경고 · 3건=7일 정지 · 5건=영구 정지</span>
      </div>
      <div style="display:flex;gap:7px;flex-wrap:wrap;">
        <button class="btn btn-teal btn-sm" onclick="resolveReport(${r.id},'처리완료')">✓ 처리완료 + 자동처벌</button>
        <button class="btn btn-ghost btn-sm" style="color:#e55;border-color:rgba(200,50,50,.3);" onclick="resolveReport(${r.id},'반려')">✕ 반려</button>
        <button class="btn btn-ghost btn-sm" style="color:#e87;" onclick="adminBanUser(${r.targetId},false)">7일 정지</button>
        <button class="btn btn-ghost btn-sm" style="color:#e55;border-color:rgba(200,50,50,.3);" onclick="adminBanUser(${r.targetId},true)">영구 정지</button>
      </div>
    </div>`;}).join('');
}


// injectAdminExtraTabs 제거 (탭이 HTML에 직접 내장됨)
function injectAdminExtraTabs(){/* no-op: tabs are built into HTML */}

function renderAdminAds(){
  const list=document.getElementById('admAdList');if(!list)return;
  const now=Date.now();
  if(!(S.ads||[]).length){list.innerHTML='<div class="empty" style="padding:24px 0;"><div class="empty-icon">📢</div><h3>등록된 광고가 없습니다</h3></div>';return;}
  list.innerHTML=`<div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:12px;">
    <thead><tr>${['광고주','커미션','기간','금액','상태','만료일','관리'].map(h=>`<th style="text-align:left;padding:8px 10px;color:var(--ink3);font-size:10.5px;border-bottom:1px solid var(--bd);">${h}</th>`).join('')}</tr></thead>
    <tbody>${(S.ads||[]).map(a=>{
      const u=S.users.find(x=>x.id===a.userId);
      const c=S.commissions.find(x=>x.id===a.commId);
      const active=a.expiresAt>now;
      return`<tr style="border-bottom:1px solid var(--bd);">
        <td style="padding:9px 10px;">${u?.name||'—'}</td>
        <td style="padding:9px 10px;color:var(--ink2);">${c?.title||'—'}</td>
        <td style="padding:9px 10px;color:var(--ink3);">${a.days}일</td>
        <td style="padding:9px 10px;color:var(--g200);">₩${(a.price||0).toLocaleString()}</td>
        <td style="padding:9px 10px;"><span style="padding:2px 7px;border-radius:5px;font-size:10.5px;background:${active?'rgba(49,144,112,0.15)':'rgba(60,90,80,0.1)'};color:${active?'var(--tc)':'var(--ink3)'};">${active?'진행중':'만료'}</span></td>
        <td style="padding:9px 10px;font-size:10.5px;color:var(--ink3);">${new Date(a.expiresAt).toLocaleDateString('ko-KR')}</td>
        <td style="padding:9px 10px;"><button class="btn btn-ghost btn-sm" style="color:#e55;" onclick="adminDelAd(${a.id})">삭제</button></td>
      </tr>`;}).join('')}</tbody></table></div>`;
}

function adminDelAd(id){
  S.ads=(S.ads||[]).filter(a=>a.id!==id);save();toast('광고 삭제됨','ok');renderAdminAds();renderAds();
}

// ── renderAdmin override ──
// ── renderHome 광고 렌더 포함// ── renderHome 광고 렌더 포함 ──
const _baseRenderHome=renderHome;
window.renderHome=function(){
  _baseRenderHome();
  renderAds();
};

// ── BOOT extras ──
if(!S.ads)S.ads=[];
if(!S.reports)S.reports=[];
handleAdPaymentSuccess();
renderAds();

// ══════════════════════════════
//  BOOT
// ══════════════════════════════
load();
// 로드 후 로그인 상태 복원
if(S.currentUser){
  updateNav();
  restoreUserPrefs();
}
updateStats();renderHome();renderFAQ();
</script>

<!-- 토스페이먼츠 SDK -->
<script src="https://js.tosspayments.com/v1/payment"></script>
<script>
// ══════════════════════════════════════════════════════
//  KEYS & CONFIG
// ══════════════════════════════════════════════════════
const TOSS_CLIENT_KEY = 'test_ck_KNbdOvk5rkWZYXQA1Nj4rn07xlzm';
const TOSS_SECRET_KEY = 'test_sk_ALnQvDd2VJoNz6GRdeRnrMj7X41m'; // 실제 서버에서만 사용
// OWNER_DISCORD_WEBHOOK은 런타임에 getOwnerWebhook()으로 대체됨
// const OWNER_DISCORD_WEBHOOK 제거 (S가 아직 로드되지 않은 시점에서 참조 불가)

// 수수료율 (플랜별, 운영자가 가져가는 %)
const FEE_RATE = { free: 0.07, pro: 0.05, ultra: 0.035 };

// ══════════════════════════════════════════════════════
//  DISCORD 웹훅 전송 (문의 / 신고 / 결제 알림)
// ══════════════════════════════════════════════════════
async function sendDiscord(webhookUrl, embed) {
  if(!webhookUrl||!webhookUrl.startsWith('https://discord.com/api/webhooks/'))return;
  try{
    // Discord 웹훅은 CORS를 지원하므로 Content-Type 설정
    const res=await fetch(webhookUrl,{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({embeds:[{
        ...embed,
        // color가 없으면 기본값
        color:embed.color||0x4fbd95,
        // footer 기본값
        footer:embed.footer||{text:'KIMAS 커미션 플랫폼'},
        timestamp:embed.timestamp||new Date().toISOString()
      }]})
    });
    if(!res.ok){
      const txt=await res.text().catch(()=>'');
      console.warn('[KIMAS Discord] 전송 실패:', res.status, txt);
      return false;
    }
    return true;
  }catch(e){
    console.warn('[KIMAS Discord] fetch 오류:', e.message);
    // 브라우저 CORS 정책으로 차단된 경우 — 실제 서버 배포 환경에서는 정상 작동
    return false;
  }
}

function getOwnerWebhook(){
  const owner=S.users.find(u=>u.isOwner);
  const wh=owner?.webhookUrl||'';
  if(!wh)console.warn('[KIMAS] Discord 웹훅 URL이 설정되지 않았습니다. 관리자 패널 > Discord 탭에서 설정해주세요.');
  return wh;
}

// 문의 Discord 알림
async function notifyDiscordInquiry(inq) {
  const from = S.users.find(u => u.id === inq.fromUserId);
  const artist = S.users.find(u => u.id === inq.toArtistId);
  const webhook = getOwnerWebhook();
  if (!webhook) return;
  await sendDiscord(webhook, {
    title: '💬 새 커미션 문의 접수',
    color: 0x319070,
    fields: [
      { name: '의뢰인', value: from?.name || '알 수 없음', inline: true },
      { name: '작가', value: artist?.name || '알 수 없음', inline: true },
      { name: '타입', value: inq.type, inline: true },
      { name: '예산', value: `₩${inq.budget}`, inline: true },
      { name: '내용', value: inq.content.slice(0, 200) },
    ],
    timestamp: new Date().toISOString(),
    footer: { text: 'Sōkin 커미션 플랫폼' }
  });
}

// 신고 Discord 알림
async function notifyDiscordReport(report) {
  const webhook = getOwnerWebhook();
  if (!webhook) return;
  await sendDiscord(webhook, {
    title: '🚨 신고 접수',
    color: 0xe74c3c,
    fields: [
      { name: '신고자', value: report.reporterName, inline: true },
      { name: '대상', value: report.targetName, inline: true },
      { name: '유형', value: report.type, inline: true },
      { name: '내용', value: report.desc },
    ],
    timestamp: new Date().toISOString(),
    footer: { text: 'Sōkin 커미션 플랫폼' }
  });
}

// 결제 완료 Discord 알림 (수수료 포함)
async function notifyDiscordPayment(order) {
  const webhook = getOwnerWebhook();
  if (!webhook) return;
  const artist = S.users.find(u => u.id === order.artistId);
  const client = S.users.find(u => u.id === order.clientId);
  const feeRate = FEE_RATE[artist?.plan || 'free'];
  const fee = Math.round(order.amount * feeRate);
  await sendDiscord(webhook, {
    title: '💰 결제 완료 — 수수료 발생',
    color: 0xd4a017,
    fields: [
      { name: '작가', value: `${artist?.name} (${artist?.plan?.toUpperCase()})`, inline: true },
      { name: '의뢰인', value: client?.name || '—', inline: true },
      { name: '결제 금액', value: `₩${order.amount.toLocaleString()}`, inline: true },
      { name: '수수료율', value: `${(feeRate*100).toFixed(1)}%`, inline: true },
      { name: '🏦 운영자 수수료', value: `₩${fee.toLocaleString()}`, inline: true },
      { name: '작가 정산액', value: `₩${(order.amount - fee).toLocaleString()}`, inline: true },
      { name: '커미션 타입', value: order.type },
    ],
    timestamp: new Date().toISOString(),
    footer: { text: 'Sōkin 커미션 플랫폼' }
  });
}

// ══════════════════════════════════════════════════════
//  토스페이먼츠 결제
// ══════════════════════════════════════════════════════
let _pendingOrder = null; // 결제 대기 중인 주문 정보

function openPayment(inqId) {
  const inq = S.inquiries.find(i => i.id === inqId);
  if (!inq) return;
  const artist = S.users.find(u => u.id === inq.toArtistId);
  const amount = parseInt(inq.budget.replace(/[^0-9]/g, '')) || 0;
  if (!amount) { toast('금액을 확인할 수 없습니다.', 'err'); return; }

  // 수수료 계산
  const feeRate = FEE_RATE[artist?.plan || 'free'];
  const fee = Math.round(amount * feeRate);
  const artistAmount = amount - fee;

  // 결제 모달 표시
  document.getElementById('payAmount').textContent = amount.toLocaleString();
  document.getElementById('payFeeRate').textContent = (feeRate * 100).toFixed(1);
  document.getElementById('payFee').textContent = fee.toLocaleString();
  document.getElementById('payArtistAmount').textContent = artistAmount.toLocaleString();
  document.getElementById('payArtistName').textContent = artist?.name || '—';
  document.getElementById('payType').textContent = inq.type;
  _pendingOrder = { inqId, artistId: inq.toArtistId, clientId: inq.fromUserId, amount, fee, artistAmount, type: inq.type, feeRate };
  openM('mPayment');
}

async function doTossPayment() {
  if (!_pendingOrder) return;
  if (!S.currentUser) { toast('로그인이 필요합니다.', 'err'); return; }

  const tossPayments = TossPayments(TOSS_CLIENT_KEY);
  const orderId = 'sokin_' + Date.now();
  const orderName = `[Sōkin] ${_pendingOrder.type} 커미션`;

  try {
    await tossPayments.requestPayment('카드', {
      amount: _pendingOrder.amount,
      orderId,
      orderName,
      customerName: S.currentUser.name,
      successUrl: window.location.href + '?payment=success&orderId=' + orderId,
      failUrl: window.location.href + '?payment=fail',
    });
  } catch(e) {
    if (e.code !== 'USER_CANCEL') {
      toast('결제 중 오류가 발생했습니다: ' + e.message, 'err');
    }
  }
}

// 결제 성공 처리 (successUrl 리다이렉트 후)
async function handlePaymentSuccess() {
  const params = new URLSearchParams(window.location.search);
  if (params.get('payment') !== 'success') return;
  if (!_pendingOrder) return;

  // 주문 저장
  const order = {
    id: Date.now(),
    ..._pendingOrder,
    status: '진행 중',
    date: new Date().toLocaleDateString('ko-KR'),
    paidAt: new Date().toISOString(),
  };
  S.orders.push(order);

  // 문의 상태 업데이트
  const inq = S.inquiries.find(i => i.id === _pendingOrder.inqId);
  if (inq) inq.status = '결제완료';

  save();
  toast('결제가 완료되었습니다! 작업이 시작됩니다. 🎨', 'ok');

  // Discord 알림
  await notifyDiscordPayment(order);

  _pendingOrder = null;
  // URL 파라미터 제거
  window.history.replaceState({}, '', window.location.pathname);
}

// ══════════════════════════════════════════════════════
//  처벌 시스템 (자동 + 수동)
// ══════════════════════════════════════════════════════
// resolveReport 최종 버전 (이전 중복 제거)
function resolveReport(id,status){
  const r=(S.reports||[]).find(x=>x.id===id);if(!r)return;
  r.status=status;
  if(status==='처리완료')autoPenalty(r.targetId);
  save();
  toast(`신고 ${status} 처리됨`,'ok');
  renderReportsTab();
  renderAdmin();
};

// ══════════════════════════════════════════════════════
//  문의함 결제 버튼 + showDash 패치
// ══════════════════════════════════════════════════════
const _origShowDash2=showDash;
window.showDash=function(tab,btn){
  _origShowDash2(tab,btn);
  if(tab==='inquiries'){
    const u=S.currentUser;if(!u)return;
    const myOutgoing=S.inquiries.filter(i=>i.fromUserId===u.id&&i.status==='수락됨');
    if(!myOutgoing.length)return;
    const main=document.getElementById('dashMain');if(!main)return;
    let extra='<div class="cc" style="margin-bottom:15px;border-color:var(--bdg);"><div class="cct" style="color:var(--g200);">💳 결제 대기 중</div>';
    myOutgoing.forEach(i=>{
      const artist=S.users.find(x=>x.id===i.toArtistId);
      const feeRate=FEE_RATE[artist?.plan||'free'];
      const amt=parseInt((i.budget||'').replace(/[^0-9]/g,''))||0;
      const fee=Math.round(amt*feeRate);
      extra+=`<div style="display:flex;align-items:center;gap:12px;padding:12px 14px;background:var(--sf2);border:1px solid var(--bdg);border-radius:9px;margin-bottom:8px;flex-wrap:wrap;">
        <div style="flex:1;min-width:150px;">
          <div style="font-size:13px;font-weight:500;">${artist?.name||'—'} · ${i.type}</div>
          <div style="font-size:11px;color:var(--ink3);">₩${amt.toLocaleString()} · 수수료 ${(feeRate*100).toFixed(1)}% (₩${fee.toLocaleString()})</div>
        </div>
        <button class="btn btn-gold" onclick="openPayment(${i.id})">💳 결제하기</button>
      </div>`;
    });
    extra+='</div>';
    main.insertAdjacentHTML('afterbegin',extra);
  }
};


// ── 신고 접수 함수 ──
function openReport(targetId, targetName, type){
  if(!S.currentUser){toast('로그인이 필요합니다.','err');return;}
  const el=document.getElementById('rptTarget');
  if(el)el.value=targetId;
  const tn=document.getElementById('rptTargetName');
  if(tn)tn.textContent=targetName;
  const rt=document.getElementById('rptType');
  if(rt)rt.value=type||'기타';
  const rd=document.getElementById('rptDesc');
  if(rd)rd.value='';
  openM('mReport');
}

async function submitReport(){
  if(!S.currentUser){toast('로그인이 필요합니다.','err');return;}
  const targetId=document.getElementById('rptTarget').value;
  const targetName=document.getElementById('rptTargetName').textContent;
  const type=document.getElementById('rptType').value;
  const desc=document.getElementById('rptDesc').value.trim();
  if(!desc){toast('신고 내용을 입력해주세요.','err');return;}
  const report={
    id:Date.now(),
    reporterId:S.currentUser.id,
    reporterName:S.currentUser.name,
    targetId,targetName,type,desc,
    status:'대기 중',
    date:new Date().toLocaleDateString('ko-KR')
  };
  if(!S.reports)S.reports=[];
  S.reports.push(report);
  save();
  closeM('mReport');
  toast('신고가 접수되었습니다. 운영팀이 검토합니다.','ok');
  // Discord 알림
  const webhook=getOwnerWebhook();
  if(webhook){
    await sendDiscord(webhook,{
      title:'🚨 신고 접수',color:0xe74c3c,
      fields:[
        {name:'신고자',value:report.reporterName,inline:true},
        {name:'대상',value:report.targetName,inline:true},
        {name:'유형',value:report.type,inline:true},
        {name:'내용',value:report.desc},
      ],
      timestamp:new Date().toISOString(),
      footer:{text:'KIMAS 신고 시스템'}
    });
  }
}

// ── 문의 버튼에서 신고 버튼도 커미션 카드에 추가 ──
function renderAdminQnA(){
  const list=document.getElementById('admQnaList');if(!list)return;
  const qnas=S.qnas||[];
  if(!qnas.length){list.innerHTML='<div class="empty" style="padding:28px 0;"><div class="empty-icon">📩</div><h3>접수된 Q&A가 없습니다</h3></div>';return;}
  list.innerHTML=qnas.map(q=>`
    <div style="border:1px solid var(--bd);border-radius:9px;padding:14px;margin-bottom:10px;background:var(--sf2);">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:8px;">
        <div>
          <span style="font-size:11px;padding:2px 7px;border-radius:5px;background:rgba(49,144,112,0.12);color:var(--tc);margin-right:7px;">${q.type}</span>
          <span style="font-size:13px;font-weight:500;color:var(--ink);">${q.title}</span>
        </div>
        <span style="padding:3px 9px;border-radius:6px;font-size:11px;background:${q.status==='대기 중'?'rgba(212,160,23,0.15)':'rgba(49,144,112,0.12)'};color:${q.status==='대기 중'?'var(--g200)':'var(--tc)'};">${q.status}</span>
      </div>
      <div style="font-size:12px;color:var(--ink3);line-height:1.7;margin-bottom:9px;">${q.content}</div>
      <div style="font-size:11px;color:var(--ink3);margin-bottom:9px;">
        작성자: <strong>${q.userName}</strong> · ${q.date}
        ${q.email?` · 연락: <a href="mailto:${q.email}" style="color:var(--ta);">${q.email}</a>`:''}
      </div>
      <div style="display:flex;gap:7px;">
        <button class="btn btn-teal btn-sm" onclick="resolveQnA(${q.id})">✓ 처리완료</button>
        <button class="btn btn-ghost btn-sm" onclick="replyQnA('${q.email||''}','${q.title}')">📧 이메일 답장</button>
      </div>
    </div>`).join('');
}

function resolveQnA(id){
  const q=(S.qnas||[]).find(x=>x.id===id);if(!q)return;
  q.status='처리완료';save();toast('처리완료로 변경됨','ok');renderAdminQnA();
}

function replyQnA(email, title){
  if(!email){toast('연락 이메일이 없습니다.','err');return;}
  window.open(`mailto:${email}?subject=Re: ${encodeURIComponent(title)}&body=안녕하세요, KIMAS 운영팀입니다.%0A%0A문의해주셔서 감사합니다.%0A%0A`);
}

function renderAdminQnA(){
  const list=document.getElementById('admQnaList');if(!list)return;
  const qnas=S.qnas||[];
  if(!qnas.length){list.innerHTML='<div class="empty" style="padding:28px 0;"><div class="empty-icon">📩</div><h3>접수된 Q&A가 없습니다</h3></div>';return;}
  list.innerHTML=qnas.map(q=>`
    <div style="border:1px solid var(--bd);border-radius:9px;padding:14px;margin-bottom:10px;background:var(--sf2);">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:8px;">
        <div>
          <span style="font-size:11px;padding:2px 7px;border-radius:5px;background:rgba(49,144,112,0.12);color:var(--tc);margin-right:7px;">${q.type}</span>
          <span style="font-size:13px;font-weight:500;color:var(--ink);">${q.title}</span>
        </div>
        <span style="padding:3px 9px;border-radius:6px;font-size:11px;background:${q.status==='대기 중'?'rgba(212,160,23,0.15)':'rgba(49,144,112,0.12)'};color:${q.status==='대기 중'?'var(--g200)':'var(--tc)'};">${q.status}</span>
      </div>
      <div style="font-size:12px;color:var(--ink3);line-height:1.7;margin-bottom:9px;">${q.content}</div>
      <div style="font-size:11px;color:var(--ink3);margin-bottom:9px;">
        작성자: <strong>${q.userName}</strong> · ${q.date}
        ${q.email?` · 연락: <a href="mailto:${q.email}" style="color:var(--ta);">${q.email}</a>`:''}
      </div>
      <div style="display:flex;gap:7px;">
        <button class="btn btn-teal btn-sm" onclick="resolveQnA(${q.id})">✓ 처리완료</button>
        <button class="btn btn-ghost btn-sm" onclick="replyQnA('${q.email||''}','${q.title}')">📧 이메일 답장</button>
        <button class="btn btn-ghost btn-sm" style="color:#e55;border-color:rgba(200,50,50,.3);" onclick="openAdminDelete('qna',${q.id},'Q&A: ${q.title.replace(/'/g,"\\'")}')">🗑️ 삭제</button>
      </div>
    </div>`).join('');
}

// ── 커미션 테이블 렌더 (검색/필터 포함) ──
function renderAdminCommTable(){
  const body=document.getElementById('admCommTableBody');if(!body)return;
  const q=(document.getElementById('admCommSearch')?.value||'').toLowerCase();
  const st=document.getElementById('admCommStatus')?.value||'';
  const fl=document.getElementById('admCommFlag')?.value||'';
  let comms=[...S.commissions];
  if(q)comms=comms.filter(c=>{const a=S.users.find(u=>u.id===c.artistId);return c.title.toLowerCase().includes(q)||(a&&a.name.toLowerCase().includes(q));});
  if(st)comms=comms.filter(c=>c.status===st);
  if(fl==='flagged')comms=comms.filter(c=>(S.reports||[]).some(r=>r.targetId==c.artistId&&r.status!=='반려'));
  if(fl==='hidden')comms=comms.filter(c=>c.hidden);
  if(!comms.length){body.innerHTML='<p style="color:var(--ink3);padding:14px;font-size:12px;">해당 조건의 커미션이 없습니다.</p>';return;}
  const sMap={open:'모집 중',waiting:'대기 중',closed:'마감'};
  body.innerHTML=`<div style="overflow-x:auto;"><table class="at"><thead><tr>
    <th>썸네일</th><th>제목</th><th>작가</th><th>타입</th><th>가격</th><th>상태</th><th>신고수</th><th>관리</th>
  </tr></thead><tbody>
  ${comms.map(c=>{
    const a=S.users.find(u=>u.id===c.artistId);
    const rptCnt=(S.reports||[]).filter(r=>r.targetId==c.artistId&&r.status!=='반려').length;
    const hidden=c.hidden;
    return`<tr style="opacity:${hidden?0.5:1};">
      <td>${c.thumbUrl?`<img src="${c.thumbUrl}" style="width:36px;height:36px;object-fit:cover;border-radius:6px;">`:`<span style="font-size:17px;">${EMOJIS[c.id%EMOJIS.length]}</span>`}</td>
      <td style="max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
        <div style="font-weight:500;">${c.title}</div>
        ${hidden?`<div style="font-size:10px;color:#e87;">숨김: ${c.hideReason||'—'}</div>`:''}
      </td>
      <td>${a?`<div style="font-size:12px;">${a.name}</div><div style="font-size:10px;color:var(--ink3);">${a.handle}</div>`:'—'}</td>
      <td style="font-size:10.5px;color:var(--ink3);">${c.types.slice(0,2).join(', ')}</td>
      <td style="color:var(--ta);">₩${c.minPrice.toLocaleString()}~</td>
      <td><span style="font-size:10px;padding:2px 6px;border-radius:4px;background:${c.status==='open'?'rgba(49,144,112,0.15)':'rgba(60,90,80,0.1)'};color:${c.status==='open'?'var(--tc)':'var(--ink3)'};">${sMap[c.status]||c.status}</span></td>
      <td style="font-size:12px;font-weight:${rptCnt>=3?700:400};color:${rptCnt>=3?'#e55':'var(--ink3)'};">${rptCnt}건</td>
      <td>
        <div style="display:flex;gap:4px;flex-wrap:wrap;">
          ${hidden
            ?`<button class="btn btn-ghost btn-sm" style="color:var(--tc);" onclick="adminUnhideContent('commission',${c.id})">복구</button>`
            :`<button class="btn btn-ghost btn-sm" style="color:var(--g300);" onclick="openAdminHide('commission',${c.id})">숨김</button>`}
          <button class="btn btn-ghost btn-sm" style="color:#e55;" onclick="openAdminDelete('commission',${c.id},'커미션: ${c.title.replace(/'/g,"\\'")}')">삭제</button>
        </div>
      </td>
    </tr>`;}).join('')}
  </tbody></table></div>`;
}

// ── 구해요 테이블 렌더 ──
function renderAdminSeekTable(){
  const body=document.getElementById('admST');if(!body)return;
  if(!S.seekingPosts.length){body.innerHTML='<p style="color:var(--ink3);padding:14px;font-size:12px;">게시글이 없습니다.</p>';return;}
  body.innerHTML=`<div style="overflow-x:auto;"><table class="at"><thead><tr>
    <th>작성자</th><th>제목</th><th>카테고리</th><th>예산</th><th>날짜</th><th>상태</th><th>관리</th>
  </tr></thead><tbody>
  ${S.seekingPosts.map(p=>{
    const hidden=p.hidden;
    return`<tr style="opacity:${hidden?0.5:1};">
      <td>${p.userName}</td>
      <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
        <div>${p.title}</div>
        ${hidden?`<div style="font-size:10px;color:#e87;">숨김: ${p.hideReason||'—'}</div>`:''}
      </td>
      <td><span class="tag">${p.cat}</span></td>
      <td style="color:var(--ta);">₩${p.budget}</td>
      <td style="font-size:10.5px;color:var(--ink3);">${p.createdAt}</td>
      <td><span style="font-size:10px;padding:2px 6px;border-radius:4px;background:${hidden?'rgba(200,60,60,0.1)':'rgba(49,144,112,0.1)'};color:${hidden?'#e55':'var(--tc)'};">${hidden?'숨김':'정상'}</span></td>
      <td>
        <div style="display:flex;gap:4px;">
          ${hidden
            ?`<button class="btn btn-ghost btn-sm" style="color:var(--tc);" onclick="adminUnhideContent('seeking',${p.id})">복구</button>`
            :`<button class="btn btn-ghost btn-sm" style="color:var(--g300);" onclick="openAdminHide('seeking',${p.id})">숨김</button>`}
          <button class="btn btn-ghost btn-sm" style="color:#e55;" onclick="openAdminDelete('seeking',${p.id},'구해요: ${p.title.replace(/'/g,"\\'")}')">삭제</button>
        </div>
      </td>
    </tr>`;}).join('')}
  </tbody></table></div>`;
}

// ── 삭제 모달 오픈 ──
function openAdminDelete(type, id, info){
  document.getElementById('delTargetType').value=type;
  document.getElementById('delTargetId').value=id;
  document.getElementById('delTargetInfo').textContent=info;
  document.getElementById('delReasonSelect').value='';
  document.getElementById('delReasonText').value='';
  document.getElementById('delNotifyUser').checked=true;
  openM('mAdminDelete');
}
function updateDelReason(){
  const sel=document.getElementById('delReasonSelect').value;
  if(sel)document.getElementById('delReasonText').value=sel;
}

// ── 삭제 확인 ──
async function confirmAdminDelete(){
  const type=document.getElementById('delTargetType').value;
  const id=parseInt(document.getElementById('delTargetId').value);
  const reason=document.getElementById('delReasonText').value.trim();
  const notify=document.getElementById('delNotifyUser').checked;
  if(!reason){toast('삭제 사유를 입력해주세요.','err');return;}

  let targetName='', authorId=null;

  if(type==='commission'){
    const c=S.commissions.find(x=>x.id===id);
    if(c){targetName=c.title;authorId=c.artistId;}
    S.commissions=S.commissions.filter(x=>x.id!==id);
    // 자동 처벌 기록도 업데이트
  } else if(type==='seeking'){
    const p=S.seekingPosts.find(x=>x.id===id);
    if(p){targetName=p.title;authorId=p.userId;}
    S.seekingPosts=S.seekingPosts.filter(x=>x.id!==id);
  } else if(type==='qna'){
    const q=(S.qnas||[]).find(x=>x.id===id);
    if(q){targetName=q.title;}
    S.qnas=(S.qnas||[]).filter(x=>x.id!==id);
  }

  // 삭제 로그 저장
  if(!S.deleteLogs)S.deleteLogs=[];
  S.deleteLogs.unshift({
    id:Date.now(),type,targetId:id,targetName,reason,
    deletedBy:'운영자',date:new Date().toLocaleDateString('ko-KR')
  });
  save();
  closeM('mAdminDelete');
  toast(`"${targetName}" 삭제 완료 (사유: ${reason})`,'ok');

  // Discord 알림
  if(notify){
    await sendDiscord(getOwnerWebhook(),{
      title:`🗑️ 콘텐츠 삭제 처리`,color:0xe74c3c,
      fields:[
        {name:'유형',value:{commission:'커미션',seeking:'구해요',qna:'Q&A'}[type]||type,inline:true},
        {name:'제목',value:targetName,inline:true},
        {name:'삭제 사유',value:reason},
      ],
      timestamp:new Date().toISOString(),footer:{text:'KIMAS 관리자 시스템'}
    });
  }

  renderAdmin();
  if(type==='seeking')renderAdminSeekTable();
  if(type==='qna')renderAdminQnA();
}

// ── 숨김 처리 ──
function openAdminHide(type,id){
  document.getElementById('hideTargetType').value=type;
  document.getElementById('hideTargetId').value=id;
  document.getElementById('hideReasonText').value='';
  openM('mAdminHide');
}
function confirmAdminHide(){
  const type=document.getElementById('hideTargetType').value;
  const id=parseInt(document.getElementById('hideTargetId').value);
  const reason=document.getElementById('hideReasonText').value.trim();
  if(!reason){toast('숨김 사유를 입력해주세요.','err');return;}
  if(type==='commission'){const c=S.commissions.find(x=>x.id===id);if(c){c.hidden=true;c.hideReason=reason;}}
  else if(type==='seeking'){const p=S.seekingPosts.find(x=>x.id===id);if(p){p.hidden=true;p.hideReason=reason;}}
  save();closeM('mAdminHide');toast('숨김 처리되었습니다.','ok');
  renderAdminCommTable();renderAdminSeekTable();
}
function adminUnhideContent(type,id){
  if(type==='commission'){const c=S.commissions.find(x=>x.id===id);if(c){c.hidden=false;c.hideReason=null;}}
  else if(type==='seeking'){const p=S.seekingPosts.find(x=>x.id===id);if(p){p.hidden=false;p.hideReason=null;}}
  save();toast('숨김이 해제되었습니다.','ok');
  renderAdminCommTable();renderAdminSeekTable();
}

// ── 자동 숨김: 커미션에 신고 3건 이상 쌓이면 자동 숨김 ──
function autoHideCheck(artistId){
  const rptCnt=(S.reports||[]).filter(r=>r.targetId==artistId&&r.status!=='반려').length;
  if(rptCnt>=3){
    S.commissions.filter(c=>c.artistId==artistId&&!c.hidden).forEach(c=>{
      c.hidden=true;c.hideReason='신고 3건 이상 누적 — 자동 숨김 (관리자 검토 필요)';
    });
    save();
    // Discord 알림
    const u=S.users.find(x=>x.id==artistId);
    sendDiscord(getOwnerWebhook(),{
      title:'⚠️ 자동 숨김 처리',color:0xf39c12,
      fields:[
        {name:'작가',value:u?.name||'—',inline:true},
        {name:'누적 신고',value:`${rptCnt}건`,inline:true},
        {name:'처리',value:'해당 작가의 모든 커미션 자동 숨김 처리'},
      ],
      timestamp:new Date().toISOString(),footer:{text:'KIMAS 자동 관리 시스템 — 관리자 검토 필요'}
    });
    toast(`⚠️ 신고 ${rptCnt}건으로 인해 관련 커미션이 자동 숨김 처리되었습니다.`,'ok');
  }
}

// resolveQnA / replyQnA 정의 (renderAdminQnA에서 사용)
function resolveQnA(id){
  const q=(S.qnas||[]).find(x=>x.id===id);if(!q)return;
  q.status='처리완료';save();toast('처리완료로 변경됨','ok');renderAdminQnA();
}
function replyQnA(email,title){
  if(!email){toast('연락 이메일이 없습니다.','err');return;}
  window.open(`mailto:${email}?subject=Re: ${encodeURIComponent(title)}&body=${encodeURIComponent('안녕하세요, KIMAS 운영팀입니다.\n\n문의해주셔서 감사합니다.\n\n')}`);
}

// submitReport 패치 — 접수 후 자동 숨김 체크
const _origSubmitReport=submitReport;
window.submitReport=async function(){
  await _origSubmitReport();
  // 신고된 대상이 작가인 경우 자동 숨김 체크
  const targetId=document.getElementById('rptTarget')?.value;
  if(targetId)autoHideCheck(targetId);
};

// 삭제 로그 탭 추가 (관리자 패널)
function showDeleteLog(){
  const logs=S.deleteLogs||[];
  return logs.length===0
    ?'<p style="color:var(--ink3);padding:14px;font-size:12px;">삭제 내역이 없습니다.</p>'
    :`<div style="overflow-x:auto;"><table class="at"><thead><tr>
        <th>유형</th><th>콘텐츠</th><th>삭제 사유</th><th>처리자</th><th>날짜</th>
      </tr></thead><tbody>
      ${logs.map(l=>`<tr>
        <td><span class="tag">${{commission:'커미션',seeking:'구해요',qna:'Q&A'}[l.type]||l.type}</span></td>
        <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${l.targetName}</td>
        <td style="font-size:12px;color:var(--ink3);">${l.reason}</td>
        <td style="font-size:12px;">${l.deletedBy}</td>
        <td style="font-size:10.5px;color:var(--ink3);">${l.date}</td>
      </tr>`).join('')}
    </tbody></table></div>`;
}

// renderAdmin — 삭제 로그 탭 업데이트는 renderAdmin 내에서 직접 처리됨
// (window.renderAdmin override 제거 — renderAdmin 본체에 통합)

// ── Q&A ──
function renderQnA(){
  // 로그인 상태면 이메일 자동 입력
  const emailEl=document.getElementById('qnaEmail');
  if(emailEl&&S.currentUser)emailEl.value=S.currentUser.email||'';
}

function toggleQnaDetail(id){
  const el=document.getElementById(id);
  if(!el)return;
  // 다른 거 닫기
  document.querySelectorAll('.qna-detail').forEach(d=>{if(d.id!==id)d.style.display='none';});
  el.style.display=el.style.display==='none'?'block':'none';
  if(el.style.display==='block')el.scrollIntoView({behavior:'smooth',block:'nearest'});
}

async function submitQnA(){
  const type=document.getElementById('qnaType')?.value;
  const title=document.getElementById('qnaTitle')?.value?.trim();
  const content=document.getElementById('qnaContent')?.value?.trim();
  const email=document.getElementById('qnaEmail')?.value?.trim();
  if(!title||!content){toast('제목과 내용을 입력해주세요.','err');return;}
  const btn=document.querySelector('#page-qna .btn-teal');
  if(btn){btn.textContent='전송 중...';btn.disabled=true;}
  // Discord 알림
  const webhook=getOwnerWebhook();
  if(webhook){
    await sendDiscord(webhook,{
      title:`📩 Q&A 문의 — ${type}`,
      color:0x319070,
      fields:[
        {name:'유형',value:type,inline:true},
        {name:'작성자',value:S.currentUser?.name||'비로그인',inline:true},
        {name:'연락 이메일',value:email||'(없음)',inline:true},
        {name:'제목',value:title},
        {name:'내용',value:content.slice(0,500)+(content.length>500?'...':'')},
      ],
      timestamp:new Date().toISOString(),
      footer:{text:'KIMAS Q&A 문의 시스템'}
    });
  }
  // 저장
  if(!S.qnas)S.qnas=[];
  S.qnas.push({id:Date.now(),type,title,content,email,userName:S.currentUser?.name||'비로그인',status:'대기 중',date:new Date().toLocaleDateString('ko-KR')});
  save();
  if(btn){btn.textContent='📩 문의 보내기';btn.disabled=false;}
  // 폼 초기화
  document.getElementById('qnaTitle').value='';
  document.getElementById('qnaContent').value='';
  toast('문의가 접수되었습니다! 24시간 내 답변드립니다. 💚','ok');
}

// ══════════════════════════════════════════════════════
//  캐시 시스템
// ══════════════════════════════════════════════════════
const TOSS_CLIENT_KEY2 = 'test_ck_KNbdOvk5rkWZYXQA1Nj4rn07xlzm';

function getCash(){ return S.currentUser?.cash||0; }
function addCash(u, amount){ u.cash=(u.cash||0)+amount; const idx=S.users.findIndex(x=>x.id===u.id);if(idx>=0)S.users[idx].cash=u.cash;save(); }
function spendCash(amount){
  const u=S.currentUser;if(!u)return false;
  if((u.cash||0)<amount){toast('캐시가 부족합니다.','err');return false;}
  u.cash=(u.cash||0)-amount;
  const idx=S.users.findIndex(x=>x.id===u.id);if(idx>=0)S.users[idx].cash=u.cash;
  save();return true;
}

let _cashPending={amount:0,cash:0};
function selCash(el){
  document.querySelectorAll('.cash-opt').forEach(e=>e.classList.remove('on'));
  el.classList.add('on');
  _cashPending={amount:parseInt(el.dataset.amount),cash:parseInt(el.dataset.cash)};
  const el2=document.getElementById('cashPayAmt');if(el2)el2.textContent=_cashPending.amount.toLocaleString();
}
async function buyCash(){
  if(!S.currentUser){toast('로그인 필요','err');return;}
  if(!_cashPending.amount){toast('충전 금액을 선택해주세요.','err');return;}
  const tp=TossPayments(TOSS_CLIENT_KEY2);
  const orderId='cash_'+Date.now();
  sessionStorage.setItem('pendingCash',JSON.stringify({amount:_cashPending.amount,cash:_cashPending.cash,userId:S.currentUser.id}));
  try{
    await tp.requestPayment('카드',{amount:_cashPending.amount,orderId,orderName:`[KIMAS] 캐시 ${_cashPending.cash.toLocaleString()}K`,
      customerName:S.currentUser.name,
      successUrl:window.location.href+'?cashpay=success&orderId='+orderId,
      failUrl:window.location.href+'?cashpay=fail'});
  }catch(e){if(e.code!=='USER_CANCEL')toast('결제 오류: '+e.message,'err');}
}
function handleCashPayment(){
  const p=new URLSearchParams(window.location.search);
  if(p.get('cashpay')!=='success')return;
  const d=sessionStorage.getItem('pendingCash');if(!d)return;
  const {cash,userId}=JSON.parse(d);
  const u=S.users.find(x=>x.id==userId);if(!u)return;
  addCash(u,cash);if(S.currentUser?.id==userId)S.currentUser.cash=u.cash;
  sessionStorage.removeItem('pendingCash');
  toast(`캐시 ${cash.toLocaleString()}K 충전 완료! 🪙`,'ok');
  window.history.replaceState({},'',window.location.pathname);
  updateCashDisplay();
}
function updateCashDisplay(){
  const el=document.getElementById('shopCashDisplay');
  if(el)el.textContent=(getCash()||0).toLocaleString()+' K';
}

// ══════════════════════════════════════════════════════
//  상점 아이템 데이터 & 렌더
// ══════════════════════════════════════════════════════
const PROFILE_ITEMS=[
  {id:'frame_gold',name:'황금 프레임',desc:'프로필에 황금 테두리',icon:'👑',price:500,type:'frame',value:'gold',badge:'HOT'},
  {id:'frame_teal',name:'청록 프레임',desc:'청록빛 빛나는 테두리',icon:'💎',price:300,type:'frame',value:'teal'},
  {id:'frame_rainbow',name:'레인보우 프레임',desc:'무지개 애니메이션 테두리',icon:'🌈',price:800,type:'frame',value:'rainbow',badge:'NEW'},
  {id:'frame_night',name:'나이트 프레임',desc:'별빛 야경 테두리',icon:'🌙',price:600,type:'frame',value:'night'},
  {id:'bg_sakura',name:'벚꽃 배경',desc:'프로필 배경 벚꽃 패턴',icon:'🌸',price:400,type:'bg',value:'sakura'},
  {id:'bg_galaxy',name:'은하수 배경',desc:'우주 은하수 배경',icon:'🌌',price:700,type:'bg',value:'galaxy',badge:'BEST'},
  {id:'bg_ocean',name:'오션 배경',desc:'깊은 바다 배경',icon:'🌊',price:400,type:'bg',value:'ocean'},
        ];
const SLOT_ITEMS=[
  {id:'slot_crystal',name:'크리스탈 슬롯',desc:'투명 크리스탈 슬롯 디자인',icon:'💠',price:400,type:'slotSkin',value:'crystal'},
  {id:'slot_fire',name:'파이어 슬롯',desc:'불꽃 슬롯 디자인',icon:'🔥',price:500,type:'slotSkin',value:'fire',badge:'HOT'},
  {id:'slot_night',name:'나이트 슬롯',desc:'밤하늘 별빛 슬롯',icon:'🌃',price:450,type:'slotSkin',value:'night'},
  {id:'slot_sakura',name:'벚꽃 슬롯',desc:'벚꽃 슬롯 디자인',icon:'🌸',price:380,type:'slotSkin',value:'sakura'},
];

function renderShop(){
  updateCashDisplay();
  const pi=document.getElementById('shopProfileItems');
  if(pi)pi.innerHTML=PROFILE_ITEMS.map(item=>shopItemCard(item)).join('');
  const si=document.getElementById('shopSlotItems');
  if(si)si.innerHTML=SLOT_ITEMS.map(item=>shopItemCard(item)).join('');
}

function shopItemCard(item){
  const owned=(S.currentUser?.items||[]).includes(item.id);
  const equipped=S.currentUser?.equipped||{};
  const isEquipped=Object.values(equipped).includes(item.id);
  const badgeHtml=item.badge?`<div class="item-badge ${item.badge==='HOT'?'hot':item.badge==='NEW'?'new':'best'}">${item.badge}</div>`:'';

  // 아이템 타입별 카드 배경 미리보기
  const cardBgMap={
    bg_sakura:`background:linear-gradient(135deg,rgba(255,150,200,0.18),rgba(255,100,150,0.1));`,
    bg_galaxy:`background:radial-gradient(ellipse at center,rgba(100,50,200,0.25),rgba(50,100,200,0.15));`,
    bg_ocean:`background:linear-gradient(180deg,rgba(0,100,200,0.2),rgba(0,150,200,0.12));`,
    frame_gold:`border:2px solid #fcd94a!important;box-shadow:0 0 14px rgba(252,217,74,0.4)!important;`,
    frame_teal:`border:2px solid #56c9ac!important;box-shadow:0 0 14px rgba(86,201,172,0.4)!important;`,
    frame_rainbow:`border:2px solid #a78bfa!important;box-shadow:0 0 14px rgba(167,139,250,0.4)!important;`,
    frame_night:`border:2px solid #818cf8!important;box-shadow:0 0 14px rgba(129,140,248,0.4)!important;`,
  };
  const cardStyle=cardBgMap[item.id]||'';

  return`<div class="shop-item-card" style="${cardStyle}${isEquipped?'outline:2px solid var(--tc);outline-offset:2px;':''}" >
    ${badgeHtml}
    ${isEquipped?`<div style="position:absolute;top:8px;right:8px;background:var(--tc);color:#fff;font-size:9px;font-weight:700;padding:2px 6px;border-radius:5px;z-index:1;">장착중</div>`:''}
    <div style="font-size:36px;margin-bottom:9px;">${item.icon}</div>
    <div style="font-family:var(--fs);font-size:14px;font-weight:600;color:var(--tc);margin-bottom:4px;">${item.name}</div>
    <div style="font-size:11.5px;color:var(--ink3);margin-bottom:12px;">${item.desc}</div>
    <div style="font-family:var(--fs);font-size:18px;font-weight:700;color:var(--g200);margin-bottom:12px;">🪙 ${item.price.toLocaleString()} K</div>
    ${owned
      ?`<button class="btn btn-sm" style="width:100%;justify-content:center;background:${isEquipped?'rgba(86,201,172,0.15)':'var(--sf3)'};color:${isEquipped?'var(--tc)':'var(--ink2)'};border:1px solid ${isEquipped?'var(--tc)':'var(--bd)'};" onclick="equipItem('${item.id}')">${isEquipped?'✓ 장착 중 (해제)':'▶ 장착하기'}</button>`
      :`<button class="btn btn-teal btn-sm" style="width:100%;justify-content:center;" onclick="buyItem('${item.id}')">구매하기</button>`}
  </div>`;
}

function buyItem(itemId){
  if(!S.currentUser){toast('로그인 필요','err');return;}
  const item=[...PROFILE_ITEMS,...SLOT_ITEMS].find(x=>x.id===itemId);if(!item)return;
  if(!S.currentUser.isOwner){
    if(!spendCash(item.price))return;
  }
  if(!S.currentUser.items)S.currentUser.items=[];
  S.currentUser.items.push(itemId);
  const idx=S.users.findIndex(x=>x.id===S.currentUser.id);if(idx>=0)S.users[idx].items=S.currentUser.items;
  save();
  toast(`${item.name} 구매 완료! 바로 장착할까요? 🎉`,'ok');
  // 구매하면 바로 장착
  equipItem(itemId);
}

function equipItem(itemId){
  if(!S.currentUser)return;
  const item=[...PROFILE_ITEMS,...SLOT_ITEMS].find(x=>x.id===itemId);if(!item)return;
  if(!S.currentUser.equipped)S.currentUser.equipped={};

  // 같은 아이템 다시 누르면 해제
  if(S.currentUser.equipped[item.type]===itemId){
    delete S.currentUser.equipped[item.type];
    const idx=S.users.findIndex(x=>x.id===S.currentUser.id);
    if(idx>=0)S.users[idx].equipped=S.currentUser.equipped;
    save();toast(`${item.name} 장착 해제됨`,'ok');
    // 해제 시 원상복구
    if(item.type==='bg')clearProfileBg();
    if(item.type==='frame')clearProfileFrame();
    if(item.type==='slotSkin')applySlotSkin(null);
    renderShop();
    return;
  }

  S.currentUser.equipped[item.type]=itemId;
  const idx=S.users.findIndex(x=>x.id===S.currentUser.id);
  if(idx>=0)S.users[idx].equipped={...S.users[idx].equipped,...S.currentUser.equipped};
  save();
  toast(`${item.name} 장착 완료! ✨`,'ok');
  if(item.type==='slotSkin')applySlotSkin(item.value);
  if(item.type==='frame')applyProfileFrame(item.value);
  if(item.type==='bg')applyProfileBg(item.value);
  renderShop();
  // 대시보드 프로필 박스 리렌더
  if(document.querySelector('.pbox'))renderPbox();
}

