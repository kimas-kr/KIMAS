    </div>

    <!-- 삭제 로그 탭 -->
    <div id="adm-dellog" class="tab-content">
      <div class="cc"><div class="cct">🗑️ 삭제 처리 내역</div><div id="admDelLog"></div></div>
    </div>
  </div>
