<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KIMAS — 그림 커미션 플랫폼</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;400;600;700&family=Noto+Sans+KR:wght@300;400;500;700&family=Cinzel:wght@400;600&display=swap" rel="stylesheet">

<!-- ══ 파비콘 (탭 로고) ══ -->
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%230c1525'/%3E%3Cpath d='M16 1.5 L29 8.5 L29 23.5 L16 30.5 L3 23.5 L3 8.5 Z' fill='%23111c2e' stroke='%2356c9ac' stroke-width='1.5'/%3E%3Ctext x='16' y='22' font-family='Georgia%2Cserif' font-size='17' font-weight='700' text-anchor='middle' fill='%2356c9ac'%3EK%3C/text%3E%3Ccircle cx='16' cy='1.5' r='2.5' fill='%2356c9ac'/%3E%3Ccircle cx='29' cy='8.5' r='2.5' fill='%2360a5fa'/%3E%3Ccircle cx='29' cy='23.5' r='2.5' fill='%23a78bfa'/%3E%3Ccircle cx='16' cy='30.5' r='2.5' fill='%23fcd94a'/%3E%3Ccircle cx='3' cy='23.5' r='2.5' fill='%2356c9ac'/%3E%3Ccircle cx='3' cy='8.5' r='2.5' fill='%23fcd94a'/%3E%3C/svg%3E">
<link rel="shortcut icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%230c1525'/%3E%3Cpath d='M16 1.5 L29 8.5 L29 23.5 L16 30.5 L3 23.5 L3 8.5 Z' fill='%23111c2e' stroke='%2356c9ac' stroke-width='1.5'/%3E%3Ctext x='16' y='22' font-family='Georgia%2Cserif' font-size='17' font-weight='700' text-anchor='middle' fill='%2356c9ac'%3EK%3C/text%3E%3Ccircle cx='16' cy='1.5' r='2.5' fill='%2356c9ac'/%3E%3Ccircle cx='29' cy='8.5' r='2.5' fill='%2360a5fa'/%3E%3Ccircle cx='29' cy='23.5' r='2.5' fill='%23a78bfa'/%3E%3Ccircle cx='16' cy='30.5' r='2.5' fill='%23fcd94a'/%3E%3Ccircle cx='3' cy='23.5' r='2.5' fill='%2356c9ac'/%3E%3Ccircle cx='3' cy='8.5' r='2.5' fill='%23fcd94a'/%3E%3C/svg%3E">

<!-- ══ Firebase SDK ══ -->
<script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-auth-compat.js"></script>
<script>
const firebaseConfig = {
  apiKey: "AIzaSyBSfSbvmvRyJMNnlo3TiPLGrFuO-QiDXF0",
  authDomain: "kimas-654bf.firebaseapp.com",
  projectId: "kimas-654bf",
  storageBucket: "kimas-654bf.firebasestorage.app",
  messagingSenderId: "766894602090",
  appId: "1:766894602090:web:600d3dfe3e8b83be199713",
  measurementId: "G-TL730CDFEC"
};

let _firebaseApp = null;
let _firebaseAuth = null;

// Firebase가 로드된 후 초기화 — 재시도 로직 포함
function initFirebase(){
  try{
    if(typeof firebase === 'undefined'){
      // SDK 아직 안 로드됨 — 500ms 후 재시도
      setTimeout(initFirebase, 500);
      return;
    }
    if(!firebase.apps.length){
      _firebaseApp = firebase.initializeApp(firebaseConfig);
    } else {
      _firebaseApp = firebase.apps[0];
    }
    _firebaseAuth = firebase.auth();
    // Firebase 로그인 상태 감지 — 페이지 새로고침 후 자동 복원
    _firebaseAuth.onAuthStateChanged(gUser=>{
      if(gUser && !S.currentUser){
        const existing = S.users.find(u=>u.googleUid===gUser.uid||u.email===gUser.email);
        if(existing){
          S.currentUser=existing;
          save(); updateNav(); restoreUserPrefs();
          toast(`${existing.name}님, 환영합니다!`,'ok');
        }
      }
    });
    console.log('[KIMAS] Firebase 초기화 완료 ✅');
  }catch(e){
    console.warn('[KIMAS] Firebase 초기화 실패:', e.message);
  }
}
// window.onload로 SDK 로드 완전히 기다린 후 실행
window.addEventListener('load', initFirebase);
</script>

<style>
:root{
  /* ── 청록 (기본 포인트) ── */
  --t50:#061210;--t100:#0c1e1a;--t200:#112a24;--t300:#17372e;--t400:#1d4438;
  --t500:#235243;--t600:#296050;--t700:#306e5d;--t800:#377d6b;--t900:#3e8c79;
  --ta:#46a08a;--tb:#4eb49b;--tc:#56c9ac;
  /* ── 금색 (동양풍 포인트) ── */
  --g100:#fff8dc;--g200:#ffd966;--g300:#e8a800;--g400:#c88c00;--g500:#a07000;--g600:#785200;
  /* ── 파랑 계열 ── */
  --b1:#0f1f3d;--b2:#1a3a6b;--b3:#2563eb;--b4:#3b82f6;--b5:#60a5fa;--b6:#93c5fd;
  /* ── 보라 계열 ── */
  --v1:#1a0f3d;--v2:#3b1f8c;--v3:#6d28d9;--v4:#8b5cf6;--v5:#a78bfa;--v6:#c4b5fd;
  /* ── 주홍 (동양풍 보조) ── */
  --r1:#3d0f0f;--r2:#7c1a1a;--r3:#c0392b;--r4:#e05a4e;--r5:#f08070;
  /* ── 텍스트 ── */
  --ink:#eef2f0;--ink2:#b4ccc4;--ink3:#6e9e92;
  /* ── 배경 ── */
  --bg:#0e1117;--bg2:#131720;--bg3:#181e28;
  /* ── 서피스 ── */
  --sf:#18202c;--sf2:#1d2535;--sf3:#222b3e;
  /* ── 보더 ── */
  --bd:rgba(255,255,255,0.07);
  --bd2:rgba(86,201,172,0.2);
  --bdg:rgba(232,168,0,0.28);
  --bdb:rgba(59,130,246,0.22);
  --bdv:rgba(139,92,246,0.22);
  /* ── 글로우 ── */
  --glow:0 0 32px rgba(70,160,138,0.16);
  --glowg:0 0 20px rgba(232,168,0,0.14);
  --glowb:0 0 20px rgba(59,130,246,0.16);
  --glowv:0 0 20px rgba(139,92,246,0.16);
  /* ── 기타 ── */
  --r:10px;--rl:16px;--tr:all 0.24s cubic-bezier(.4,0,.2,1);
  --fs:'Noto Serif KR',serif;--fn:'Noto Sans KR',sans-serif;--fd:'Cinzel',serif;
}

/* ── 전역 리셋 ── */
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}

/* ── 바디 + 배경 패턴 (동양풍) ── */
body{
  font-family:var(--fn);
  background:var(--bg);
  color:var(--ink);
  min-height:100vh;
  overflow-x:hidden;
}
body::before{
  content:'';
  position:fixed;inset:0;
  background:
    /* 청록 왼쪽 상단 */
    radial-gradient(ellipse 50% 40% at 0% 0%,rgba(70,160,138,0.09) 0%,transparent 55%),
    /* 금색 오른쪽 하단 */
    radial-gradient(ellipse 45% 50% at 100% 100%,rgba(232,168,0,0.07) 0%,transparent 55%),
    /* 파랑 오른쪽 상단 */
    radial-gradient(ellipse 35% 35% at 100% 0%,rgba(59,130,246,0.06) 0%,transparent 50%),
    /* 보라 왼쪽 하단 */
    radial-gradient(ellipse 35% 35% at 0% 100%,rgba(139,92,246,0.05) 0%,transparent 50%),
    /* 중앙 미세 청록 */
    radial-gradient(ellipse 25% 50% at 50% 50%,rgba(70,160,138,0.03) 0%,transparent 60%);
  pointer-events:none;z-index:0;
}
/* 전통 한국풍 문창살 패턴 오버레이 */
body::after{
  content:'';
  position:fixed;inset:0;
  background-image:
    url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%23e8a800' stroke-opacity='0.022' stroke-width='0.6'%3E%3Crect x='5' y='5' width='70' height='70' rx='2'/%3E%3Crect x='15' y='15' width='50' height='50' rx='1'/%3E%3Cline x1='40' y1='5' x2='40' y2='75'/%3E%3Cline x1='5' y1='40' x2='75' y2='40'/%3E%3Ccircle cx='40' cy='40' r='12'/%3E%3Ccircle cx='40' cy='40' r='4'/%3E%3C/g%3E%3C/svg%3E"),
    url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%2356c9ac' stroke-opacity='0.018' stroke-width='0.5'%3E%3Cpath d='M0 20 Q10 0 20 20 Q30 40 40 20'/%3E%3Cpath d='M20 0 Q40 10 20 20 Q0 30 20 40'/%3E%3C/g%3E%3C/svg%3E");
  pointer-events:none;z-index:0;opacity:1;
}
.z1{position:relative;z-index:1;}

/* ── 스크롤바 ── */
::-webkit-scrollbar{width:5px;background:var(--bg2);}
::-webkit-scrollbar-thumb{
  background:linear-gradient(to bottom,var(--tc),var(--b4));
  border-radius:3px;
}


/* ── NAV ── */
nav{
  position:sticky;top:0;z-index:900;
  background:rgba(14,17,23,0.93);
  backdrop-filter:blur(24px);
  border-bottom:1px solid transparent;
  /* 동양풍 테두리: 금색 + 청록 그라디언트 */
  border-bottom:1px solid rgba(232,168,0,0.2);
  box-shadow:0 2px 0 rgba(86,201,172,0.08),0 4px 0 rgba(139,92,246,0.04);
}
.nav-inner{display:flex;align-items:center;height:60px;max-width:1240px;margin:0 auto;padding:0 20px;gap:10px;}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0;cursor:pointer;}
/* 로고 마크 — 동양풍 원형, 청록+파랑+연보라+금 */
.logo-mark{
  width:34px;height:34px;border-radius:50%;
  background:conic-gradient(from 0deg,
    #56c9ac 0deg,
    #60a5fa 80deg,
    #a78bfa 150deg,
    #fcd94a 220deg,
    #56c9ac 360deg
  );
  display:flex;align-items:center;justify-content:center;
  font-family:var(--fs);color:#fff;font-size:14px;font-weight:700;
  box-shadow:
    0 0 14px rgba(86,201,172,0.3),
    0 0 28px rgba(167,139,250,0.15);
  position:relative;
}
.logo-mark::after{
  content:'';position:absolute;inset:2.5px;border-radius:50%;
  background:var(--bg);
}
.logo-mark span{position:relative;z-index:1;
  background:linear-gradient(135deg,var(--tc),var(--b5),var(--v5));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.logo-main{
  font-family:var(--fd);font-size:14px;font-weight:700;letter-spacing:3px;line-height:1.1;
  background:linear-gradient(90deg,var(--tc) 0%,var(--b5) 45%,var(--v5) 80%,var(--g200) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.logo-sub{font-size:8.5px;color:var(--v5);letter-spacing:1.5px;opacity:.8;}
/* 네비 링크 */
.nav-links{display:flex;align-items:center;gap:2px;list-style:none;flex:1;margin-left:8px;}
.nav-links a{display:flex;align-items:center;gap:5px;padding:6px 11px;font-size:12.5px;color:var(--ink3);text-decoration:none;border-radius:8px;transition:var(--tr);white-space:nowrap;cursor:pointer;position:relative;}
.nav-links a::after{content:'';position:absolute;bottom:2px;left:50%;right:50%;height:2px;border-radius:1px;background:linear-gradient(90deg,var(--tc),var(--b4));transition:var(--tr);opacity:0;}
.nav-links a:hover,.nav-links a.active{background:rgba(86,201,172,0.1);color:var(--tc);}
.nav-links a:hover::after,.nav-links a.active::after{left:8px;right:8px;opacity:1;}
.nav-actions{display:flex;align-items:center;gap:7px;flex-shrink:0;}

/* ── 버튼 ── */
.btn{padding:7px 17px;border-radius:9px;font-size:12.5px;font-weight:500;cursor:pointer;border:none;transition:var(--tr);text-decoration:none;display:inline-flex;align-items:center;gap:6px;white-space:nowrap;font-family:var(--fn);}
.btn-ghost{background:transparent;color:var(--ink2);border:1px solid var(--bd2);}
.btn-ghost:hover{background:rgba(86,201,172,0.09);border-color:var(--tc);color:var(--tc);}
/* 청록 버튼 — 동양풍 그라디언트 */
.btn-teal{
  background:linear-gradient(135deg,var(--t900),var(--ta),var(--tc));
  color:#fff;border:1px solid rgba(86,201,172,0.4);
  box-shadow:0 2px 16px rgba(70,160,138,0.28);
}
.btn-teal:hover{background:linear-gradient(135deg,var(--ta),var(--tc),var(--tb));box-shadow:0 4px 24px rgba(70,160,138,0.4);transform:translateY(-1px);}
/* 금색 버튼 */
.btn-gold{background:linear-gradient(135deg,var(--g300),var(--g200));color:var(--g600);border:1px solid var(--g400);font-weight:600;}
.btn-gold:hover{transform:translateY(-1px);box-shadow:var(--glowg);}
/* 파랑 버튼 */
.btn-blue{background:linear-gradient(135deg,var(--b2),var(--b3));color:#fff;border:1px solid rgba(59,130,246,0.4);box-shadow:0 2px 14px rgba(59,130,246,0.25);}
.btn-blue:hover{transform:translateY(-1px);box-shadow:var(--glowb);}
/* 보라 버튼 */
.btn-purple{background:linear-gradient(135deg,var(--v2),var(--v3));color:#fff;border:1px solid rgba(139,92,246,0.4);box-shadow:0 2px 14px rgba(139,92,246,0.25);}
.btn-purple:hover{transform:translateY(-1px);box-shadow:var(--glowv);}
.btn-sm{padding:5px 11px;font-size:11.5px;}
.hamburger{display:none;flex-direction:column;gap:4px;cursor:pointer;padding:7px;background:none;border:none;margin-left:auto;}
.hamburger span{width:20px;height:1.5px;background:var(--ink2);border-radius:1px;transition:var(--tr);}

/* ── PAGE ── */
.page{display:none;}
.page.active{display:block;animation:fadeUp .3s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.container{max-width:1240px;margin:0 auto;padding:0 20px;position:relative;z-index:1;}

/* ── HERO — 동양풍 ── */
.hero{padding:84px 0 60px;text-align:center;position:relative;overflow:hidden;}
/* 배경 원형 장식 */
.hero::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(circle 300px at 20% 50%,rgba(70,160,138,0.08) 0%,transparent 70%),
    radial-gradient(circle 250px at 80% 30%,rgba(59,130,246,0.07) 0%,transparent 70%),
    radial-gradient(circle 200px at 60% 80%,rgba(139,92,246,0.06) 0%,transparent 70%),
    radial-gradient(circle 180px at 10% 80%,rgba(232,168,0,0.05) 0%,transparent 70%);
  pointer-events:none;
}
.hero-badge{
  display:inline-flex;align-items:center;gap:7px;
  background:linear-gradient(90deg,rgba(232,168,0,0.08),rgba(86,201,172,0.08));
  border:1px solid;
  border-image:linear-gradient(90deg,var(--bdg),var(--bd2)) 1;
  border-radius:100px;padding:6px 18px;font-size:11px;color:var(--g300);margin-bottom:28px;letter-spacing:.6px;
}
.hero h1{font-family:var(--fs);font-size:clamp(30px,5vw,56px);font-weight:600;line-height:1.26;margin-bottom:18px;
  background:linear-gradient(135deg,var(--tc) 0%,var(--g200) 40%,var(--b5) 70%,var(--v5) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hero h1 em{font-style:normal;}
.hero p{font-size:14px;color:var(--ink3);max-width:460px;margin:0 auto 34px;line-height:1.82;}
.hero-deco{position:absolute;font-family:var(--fs);font-size:160px;font-weight:700;opacity:.022;pointer-events:none;user-select:none;}
.hero-deco.l{left:-16px;top:0;color:var(--tc);}
.hero-deco.r{right:-16px;bottom:0;color:var(--g300);}

/* ── STAT BAR ── */
.stat-bar{
  background:linear-gradient(90deg,rgba(70,160,138,0.06),rgba(59,130,246,0.04),rgba(139,92,246,0.04),rgba(232,168,0,0.05));
  border-top:1px solid var(--bd);border-bottom:1px solid var(--bd);
}
.stat-row{display:grid;grid-template-columns:repeat(4,1fr);text-align:center;}
.sib{padding:18px 10px;border-right:1px solid var(--bd);}
.sib:last-child{border-right:none;}
/* 각 통계마다 다른 색 */
.sib:nth-child(1) .sib-num{color:var(--tc);}
.sib:nth-child(2) .sib-num{color:var(--g200);}
.sib:nth-child(3) .sib-num{color:var(--b5);}
.sib:nth-child(4) .sib-num{color:var(--v5);}
.sib-num{font-family:var(--fs);font-size:23px;font-weight:700;}
.sib-lbl{font-size:10.5px;color:var(--ink3);margin-top:3px;}

/* ── SECTION TITLE — 동양풍 장식 ── */
.sec-hdr{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:22px;gap:10px;flex-wrap:wrap;}
.sec-ttl{font-family:var(--fs);font-size:18px;font-weight:600;color:var(--tc);display:flex;align-items:center;gap:10px;}
/* 다색 왼쪽 장식 바 */
.sec-ttl::before{
  content:'';width:5px;height:20px;
  background:linear-gradient(to bottom,var(--g300) 0%,var(--tc) 40%,var(--b4) 70%,var(--v4) 100%);
  border-radius:2px;flex-shrink:0;
  box-shadow:0 0 8px rgba(86,201,172,0.3);
}
section{padding:48px 0;}

/* ── COMMISSION CARD ── */
.card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:14px;}
.comm-card{
  background:var(--sf);
  border:1px solid var(--bd);
  border-radius:var(--rl);overflow:hidden;transition:var(--tr);cursor:pointer;display:flex;flex-direction:column;
  position:relative;
}
/* 카드 상단 컬러 라인 */
.comm-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--tc),var(--b4),var(--v4),var(--g300));
  opacity:0;transition:var(--tr);
}
.comm-card:hover{transform:translateY(-4px);box-shadow:var(--glow);border-color:rgba(86,201,172,0.3);}
.comm-card:hover::before{opacity:1;}
.card-thumb{aspect-ratio:3/2;background:linear-gradient(135deg,var(--t300),var(--sf2));display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;flex-shrink:0;}
.card-thumb img{width:100%;height:100%;object-fit:cover;}
/* 동양풍 격자 패턴 카드 배경 */
.card-pat{
  position:absolute;inset:0;
  background:url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%2356c9ac' stroke-opacity='0.08' stroke-width='0.5'%3E%3Crect x='4' y='4' width='32' height='32'/%3E%3Crect x='10' y='10' width='20' height='20'/%3E%3Cline x1='4' y1='20' x2='36' y2='20'/%3E%3Cline x1='20' y1='4' x2='20' y2='36'/%3E%3Ccircle cx='20' cy='20' r='5'/%3E%3C/g%3E%3C/svg%3E");
}
.card-emoji{font-size:44px;position:relative;z-index:1;}
.c-st{position:absolute;top:8px;right:8px;padding:3px 8px;border-radius:14px;font-size:10px;font-weight:600;}
.s-open{background:rgba(86,201,172,0.2);color:var(--tc);border:1px solid rgba(86,201,172,0.35);}
.s-closed{background:rgba(80,80,100,0.2);color:var(--ink3);border:1px solid rgba(80,80,100,0.25);}
.s-wait{background:rgba(232,168,0,0.16);color:var(--g200);border:1px solid rgba(232,168,0,0.3);}
.card-body{padding:12px;display:flex;flex-direction:column;gap:8px;flex:1;}
.card-artist-row{display:flex;align-items:center;gap:8px;}
.av{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--t600),var(--ta));display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:600;flex-shrink:0;border:1.5px solid var(--bdg);overflow:hidden;}
.av img{width:100%;height:100%;object-fit:cover;}
.a-nm{font-size:12.5px;font-weight:500;color:var(--ink);}
.a-sb{font-size:10px;color:var(--ink3);}
.card-title{font-size:13px;font-weight:500;color:var(--ink2);line-height:1.4;}
.type-tags{display:flex;gap:4px;flex-wrap:wrap;}
/* 태그 — 색상 순환 */
.tag{padding:2px 7px;border-radius:5px;font-size:10px;background:rgba(86,201,172,0.08);color:var(--tc);border:1px solid rgba(86,201,172,0.15);}
.card-bot{display:flex;align-items:center;justify-content:space-between;padding-top:8px;border-top:1px solid var(--bd);margin-top:auto;}
.price{font-family:var(--fs);font-size:14px;font-weight:700;
  background:linear-gradient(90deg,var(--tc),var(--g300));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.sdots{display:flex;align-items:center;gap:3px;font-size:10px;color:var(--ink3);}
.dot{width:6px;height:6px;border-radius:50%;border:1.5px solid var(--t500);}
.dot.on{background:linear-gradient(135deg,var(--ta),var(--b4));border-color:var(--ta);}
/* 플랜 뱃지 */
.pb{display:inline-block;padding:1px 6px;border-radius:4px;font-size:8.5px;font-weight:700;margin-left:3px;vertical-align:middle;}
.pb-u{background:linear-gradient(90deg,var(--g300),var(--r4));color:#fff;}
.pb-p{background:linear-gradient(90deg,var(--b3),var(--v4));color:#fff;}

/* ── ARTIST ROW CARD ── */
.artist-list{display:flex;flex-direction:column;gap:10px;}
.artist-row{
  background:var(--sf);border:1px solid var(--bd);border-radius:var(--rl);
  padding:14px 16px;display:flex;align-items:center;gap:14px;cursor:pointer;transition:var(--tr);
  position:relative;overflow:hidden;
}
.artist-row::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:linear-gradient(to bottom,var(--tc),var(--b4),var(--v4));opacity:0;transition:var(--tr);}
.artist-row:hover{border-color:rgba(86,201,172,0.25);box-shadow:var(--glow);}
.artist-row:hover::before{opacity:1;}
.artist-row-av{width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,var(--t600),var(--ta));display:flex;align-items:center;justify-content:center;font-family:var(--fs);font-size:18px;font-weight:600;color:#fff;flex-shrink:0;border:2px solid var(--bdg);overflow:hidden;}
.artist-row-av img{width:100%;height:100%;object-fit:cover;}
.artist-row-info{flex:1;min-width:0;}
.artist-row-name{font-family:var(--fs);font-size:15px;font-weight:600;color:var(--ink);}
.artist-row-handle{font-size:11.5px;color:var(--ink3);margin-bottom:4px;}
.artist-row-tags{display:flex;gap:4px;flex-wrap:wrap;}
.artist-row-stats{display:flex;gap:18px;flex-shrink:0;text-align:center;}
.ars{display:flex;flex-direction:column;align-items:center;}
.ars-n{font-size:14px;font-weight:600;color:var(--ta);}
.ars-l{font-size:9.5px;color:var(--ink3);}

/* ── SEEKING ── */
.sk{
  background:var(--sf);border:1px solid var(--bd);border-radius:var(--r);padding:15px 17px;transition:var(--tr);
  position:relative;overflow:hidden;
}
.sk::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--bdg),transparent);opacity:0;transition:var(--tr);}
.sk:hover{border-color:rgba(232,168,0,0.2);}
.sk:hover::after{opacity:1;}

.sk-head{display:flex;align-items:flex-start;gap:10px;margin-bottom:7px;}
.sk-av{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--g300),var(--g500));display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:var(--g600);flex-shrink:0;overflow:hidden;}
.sk-av img{width:100%;height:100%;object-fit:cover;}

/* ── TAB BAR — 멀티컬러 ── */
.tab-bar{display:flex;gap:3px;background:var(--sf);border-radius:var(--r);padding:3px;margin-bottom:20px;flex-wrap:wrap;border:1px solid var(--bd);position:relative;}
.tab-bar::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--tc),var(--b4),var(--v4),var(--g300));opacity:.35;border-radius:0 0 var(--r) var(--r);}
.tab-btn{flex:1;min-width:65px;padding:7px 12px;border:none;background:transparent;border-radius:7px;font-size:12.5px;font-weight:400;color:var(--ink3);cursor:pointer;transition:var(--tr);font-family:var(--fn);white-space:nowrap;}
.tab-btn.active{background:linear-gradient(135deg,rgba(86,201,172,0.12),rgba(59,130,246,0.08));color:var(--tc);font-weight:600;box-shadow:0 1px 4px rgba(0,0,0,.4);}
.tab-content{display:none;}
.tab-content.active{display:block;animation:fadeUp .26s ease;}

/* ── FILTER BAR ── */
.filter-bar{display:flex;gap:7px;flex-wrap:wrap;align-items:center;margin-bottom:16px;padding:10px 14px;background:var(--sf);border:1px solid var(--bd);border-radius:var(--r);}
.flbl{font-size:11px;color:var(--ink3);font-weight:500;white-space:nowrap;}
.chip{padding:4px 10px;border-radius:16px;border:1px solid var(--bd);background:transparent;font-size:11.5px;color:var(--ink3);cursor:pointer;transition:var(--tr);font-family:var(--fn);white-space:nowrap;}
.chip:hover,.chip.on{background:rgba(86,201,172,0.12);border-color:var(--tc);color:var(--tc);}
.sbox{display:flex;align-items:center;gap:7px;background:var(--bg2);border:1px solid var(--bd);border-radius:8px;padding:7px 12px;flex:1;min-width:140px;}
.sbox input{border:none;outline:none;font-size:12.5px;color:var(--ink);background:transparent;width:100%;font-family:var(--fn);}
.sbox input::placeholder{color:var(--ink3);}

/* ── PRICING ── */
.pricing-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px;margin-top:32px;}
.pc{background:var(--sf);border:1px solid var(--bd);border-radius:var(--rl);padding:24px;padding-top:30px;position:relative;transition:var(--tr);}
.pc::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:var(--rl) var(--rl) 0 0;}
.pc:hover{transform:translateY(-3px);box-shadow:var(--glow);}
.pc:first-child::before{background:linear-gradient(90deg,var(--tc),var(--tb));}
.pc.feat::before{background:linear-gradient(90deg,var(--b3),var(--v4));}
.pc.ultra-c::before{background:linear-gradient(90deg,var(--g300),var(--r4));}
.pc.feat{border:1.5px solid rgba(59,130,246,0.25);background:linear-gradient(155deg,rgba(59,130,246,0.05),var(--sf));}
.pc.ultra-c{border:1.5px solid rgba(232,168,0,0.3);background:linear-gradient(155deg,rgba(232,168,0,0.06),var(--sf));}
.pbadge{position:absolute;top:-11px;left:50%;transform:translateX(-50%);padding:3px 12px;border-radius:18px;font-size:10px;font-weight:600;white-space:nowrap;}
.pbadge.pop{background:linear-gradient(90deg,var(--b3),var(--v4));color:#fff;}
.pbadge.prm{background:linear-gradient(90deg,var(--g300),var(--r4));color:#fff;}
.plan-n{font-family:var(--fs);font-size:18px;font-weight:600;color:var(--ink);margin-bottom:4px;}
.plan-price{display:flex;align-items:baseline;gap:4px;margin-bottom:5px;}
.pamt{font-family:var(--fs);font-size:28px;font-weight:700;color:var(--tc);}
.pper{font-size:11.5px;color:var(--ink3);}
.pdesc{font-size:11.5px;color:var(--ink3);margin-bottom:16px;line-height:1.55;}
.div{height:1px;background:var(--bd);margin:13px 0;}
.hlr{display:flex;justify-content:space-between;background:var(--bg2);border-radius:6px;padding:6px 10px;margin-bottom:5px;font-size:12px;color:var(--ink2);}
.hlv{font-weight:600;color:var(--tc);}
.fl{list-style:none;display:flex;flex-direction:column;gap:7px;margin-bottom:18px;}
.fl li{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--ink2);}
.fic{width:16px;height:16px;border-radius:50%;background:rgba(49,144,112,0.16);display:flex;align-items:center;justify-content:center;font-size:9px;color:var(--ta);flex-shrink:0;}
.fic.g{background:rgba(232,168,0,0.13);color:var(--g300);}.fic.b{background:rgba(59,130,246,0.13);color:var(--b5);}

/* ── DASHBOARD ── */
.dash-layout{display:grid;grid-template-columns:220px 1fr;gap:16px;padding:28px 0 56px;}
.sidebar{position:sticky;top:72px;height:fit-content;}
.pbox{background:var(--sf);border:1px solid var(--bd);border-radius:var(--rl);padding:17px;text-align:center;margin-bottom:12px;}
.pav{width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--t600),var(--ta));display:flex;align-items:center;justify-content:center;font-family:var(--fs);font-size:20px;color:#fff;font-weight:600;margin:0 auto 10px;border:2.5px solid var(--bdg);position:relative;overflow:hidden;}
.pav img{width:100%;height:100%;object-fit:cover;}
.pp{position:absolute;bottom:-5px;left:50%;transform:translateX(-50%);padding:2px 7px;border-radius:7px;font-size:8.5px;font-weight:700;white-space:nowrap;}
.pp-free{background:var(--sf3);color:var(--ink3);}
.pp-pro{background:linear-gradient(90deg,var(--b3),var(--v4));color:#fff;}
.pp-ultra{background:linear-gradient(90deg,var(--g300),var(--r4));color:#fff;}
.sm{background:var(--sf);border:1px solid var(--bd);border-radius:var(--rl);overflow:hidden;}
.si{display:flex;align-items:center;gap:8px;padding:11px 13px;font-size:12.5px;color:var(--ink3);cursor:pointer;transition:var(--tr);border:none;background:none;width:100%;text-align:left;font-family:var(--fn);border-bottom:1px solid var(--bd);}
.si:last-child{border-bottom:none;}
.si:hover,.si.active{background:rgba(86,201,172,0.09);color:var(--tc);}
.cc{background:var(--sf);border:1px solid var(--bd);border-radius:var(--rl);padding:19px;margin-bottom:15px;}
.cct{font-family:var(--fs);font-size:15px;font-weight:600;color:var(--tc);margin-bottom:13px;display:flex;align-items:center;gap:7px;}
.sg{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:10px;margin-bottom:14px;}
.sc2{background:var(--sf2);border:1px solid var(--bd);border-radius:var(--r);padding:12px;}
.sc-l{font-size:10px;color:var(--ink3);margin-bottom:3px;letter-spacing:.3px;}
.sc-v{font-family:var(--fs);font-size:20px;font-weight:700;color:var(--ta);}.sc2:nth-child(4n+1){border-left:3px solid var(--tc);}.sc2:nth-child(4n+2){border-left:3px solid var(--g300);}.sc2:nth-child(4n+3){border-left:3px solid var(--b4);}.sc2:nth-child(4n+4){border-left:3px solid var(--v4);}
.sc-s{font-size:10px;color:var(--ink3);margin-top:2px;}

/* ── SLOTS ── */
/* ══════════════════════════════════════════
   슬롯 기본 + 스킨별 디자인 (빈칸·채운칸)
══════════════════════════════════════════ */
.slot{
  flex:1;min-width:100px;border-radius:10px;padding:14px 8px 12px;
  text-align:center;border:1.5px dashed rgba(255,255,255,0.1);
  transition:all 0.3s;position:relative;overflow:hidden;
  background:var(--sf2);cursor:default;
}
.slot.on{
  border-style:solid;border-color:var(--ta);
  background:rgba(86,201,172,0.07);
}

/* ── 기본 슬롯 빈칸 장식 ── */
.slot:not(.on)::before{
  content:'○';position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);
  font-size:22px;color:rgba(255,255,255,0.06);pointer-events:none;
}

/* ══ 크리스탈 스킨 ══ */
.slot-skin-crystal .slot:not(.on){
  background:linear-gradient(135deg,rgba(30,80,120,0.15),rgba(60,160,220,0.06)) !important;
  border-color:rgba(100,200,255,0.3) !important;
  border-style:dashed !important;
  box-shadow:inset 0 0 12px rgba(100,200,255,0.04) !important;
}
.slot-skin-crystal .slot:not(.on)::before{
  content:'◇';font-size:20px;
  color:rgba(100,200,255,0.22);
  animation:crystalEmptyPulse 3s ease-in-out infinite;
}
@keyframes crystalEmptyPulse{0%,100%{opacity:0.4;transform:translate(-50%,-50%) scale(0.9);}50%{opacity:1;transform:translate(-50%,-50%) scale(1.1);}}
.slot-skin-crystal .slot.on{
  background:linear-gradient(135deg,rgba(100,200,255,0.15),rgba(79,189,149,0.08)) !important;
  border-color:#64c8ff !important;border-style:solid !important;
  box-shadow:0 0 14px rgba(100,200,255,0.35),inset 0 0 10px rgba(100,200,255,0.06) !important;
}
.slot-skin-crystal .slot.on::before{
  content:'';
  background:linear-gradient(45deg,transparent 30%,rgba(200,240,255,0.18) 50%,transparent 70%);
  background-size:200% 200%;animation:crystalShine 2s linear infinite;
  inset:0;transform:none;font-size:0;
}
@keyframes crystalShine{0%{background-position:200% 200%;}100%{background-position:-200% -200%;}}
.slot-skin-crystal .slot.on::after{
  content:'💎';position:absolute;top:3px;right:5px;font-size:9px;
  animation:crystalFloat 2s ease-in-out infinite;
  filter:drop-shadow(0 0 4px #64c8ff);
}
@keyframes crystalFloat{0%,100%{transform:translateY(0);}50%{transform:translateY(-2px);}}

/* ══ 파이어 스킨 ══ */
.slot-skin-fire .slot:not(.on){
  background:linear-gradient(180deg,rgba(40,15,5,0.2),rgba(80,30,5,0.1)) !important;
  border-color:rgba(180,60,10,0.3) !important;
  border-style:dashed !important;
}
.slot-skin-fire .slot:not(.on)::before{
  content:'🔥';font-size:16px;color:inherit;
  opacity:0.18;animation:fireEmptyFlicker 1.2s ease-in-out infinite alternate;
}
@keyframes fireEmptyFlicker{0%{opacity:0.1;transform:translate(-50%,-50%) scale(0.9);}100%{opacity:0.28;transform:translate(-50%,-50%) scale(1.05);}}
.slot-skin-fire .slot.on{
  background:linear-gradient(180deg,rgba(255,60,0,0.05),rgba(255,150,0,0.12),rgba(255,200,0,0.06)) !important;
  border-color:#ff6432 !important;border-style:solid !important;
  box-shadow:0 0 16px rgba(255,100,50,0.45),inset 0 -4px 8px rgba(255,150,0,0.08) !important;
  animation:fireGlow 0.6s ease-in-out infinite alternate !important;
}
@keyframes fireGlow{0%{box-shadow:0 0 10px rgba(255,80,0,0.4);}100%{box-shadow:0 0 20px rgba(255,120,0,0.6);}}
.slot-skin-fire .slot.on::before{
  content:'';position:absolute;bottom:0;left:50%;transform:translateX(-50%);
  width:60%;height:40%;font-size:0;
  background:radial-gradient(ellipse at bottom,rgba(255,150,0,0.25),transparent 70%);
  animation:fireRise 0.8s ease-in-out infinite alternate;
}
@keyframes fireRise{0%{height:30%;opacity:0.6;}100%{height:50%;opacity:1;}}
.slot-skin-fire .slot.on::after{
  content:'🔥';position:absolute;top:3px;right:5px;font-size:9px;
  animation:fireShake 0.5s ease-in-out infinite alternate;
  filter:drop-shadow(0 0 4px #ff6432);
}
@keyframes fireShake{0%{transform:rotate(-8deg);}100%{transform:rotate(8deg);}}

/* ══ 나이트 스킨 ══ */
.slot-skin-night .slot:not(.on){
  background:linear-gradient(135deg,rgba(10,5,30,0.3),rgba(25,12,60,0.15)) !important;
  border-color:rgba(100,50,200,0.25) !important;
  border-style:dashed !important;
}
.slot-skin-night .slot:not(.on)::before{
  content:'✦';font-size:18px;
  color:rgba(160,130,220,0.25);
  animation:nightEmptyTwinkle 2s ease-in-out infinite;
}
@keyframes nightEmptyTwinkle{0%,100%{opacity:0.2;transform:translate(-50%,-50%) scale(0.8);}50%{opacity:0.6;transform:translate(-50%,-50%) scale(1.15);}}
.slot-skin-night .slot.on{
  background:linear-gradient(135deg,rgba(20,10,60,0.4),rgba(50,30,120,0.2)) !important;
  border-color:#6432c8 !important;border-style:solid !important;
  box-shadow:0 0 14px rgba(100,50,200,0.4),inset 0 0 12px rgba(100,50,200,0.06) !important;
}
.slot-skin-night .slot.on::before{
  content:'★ ✦ ☽ ✦ ★';
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  font-size:7px;color:rgba(200,180,255,0.4);white-space:nowrap;letter-spacing:3px;
  animation:nightScroll 4s linear infinite;background:none;width:auto;height:auto;
}
@keyframes nightScroll{0%{letter-spacing:3px;opacity:0.3;}50%{letter-spacing:5px;opacity:0.7;}100%{letter-spacing:3px;opacity:0.3;}}
.slot-skin-night .slot.on::after{
  content:'🌙';position:absolute;top:3px;right:5px;font-size:9px;
  animation:moonPulse 2s ease-in-out infinite;
  filter:drop-shadow(0 0 4px #6432c8);
}
@keyframes moonPulse{0%,100%{opacity:0.6;transform:scale(0.9);}50%{opacity:1;transform:scale(1.1);}}

/* ══ 벚꽃 스킨 ══ */
.slot-skin-sakura .slot:not(.on){
  background:linear-gradient(135deg,rgba(255,180,220,0.08),rgba(255,140,190,0.04)) !important;
  border-color:rgba(255,150,200,0.28) !important;
  border-style:dashed !important;
}
.slot-skin-sakura .slot:not(.on)::before{
  content:'🌸';font-size:16px;color:inherit;
  opacity:0.2;animation:sakuraEmptyFloat 3s ease-in-out infinite;
}
@keyframes sakuraEmptyFloat{0%,100%{opacity:0.15;transform:translate(-50%,-50%) rotate(-10deg) scale(0.9);}50%{opacity:0.3;transform:translate(-50%,-50%) rotate(10deg) scale(1.1);}}
.slot-skin-sakura .slot.on{
  background:linear-gradient(135deg,rgba(255,180,220,0.18),rgba(255,150,200,0.08)) !important;
  border-color:#ff96c8 !important;border-style:solid !important;
  box-shadow:0 0 12px rgba(255,150,200,0.35),inset 0 0 8px rgba(255,180,220,0.05) !important;
}
.slot-skin-sakura .slot.on::before{
  content:'🌸';position:absolute;
  animation:petalFall 2.5s ease-in-out infinite;
  font-size:11px;background:none;width:auto;height:auto;
  filter:drop-shadow(0 0 3px #ff96c8);
}
@keyframes petalFall{
  0%{top:-6px;left:20%;opacity:0;transform:rotate(0deg);}
  30%{opacity:1;}
  100%{top:calc(100% + 6px);left:75%;opacity:0;transform:rotate(200deg);}
}
.slot-skin-sakura .slot.on::after{
  content:'🌸';position:absolute;top:3px;right:5px;font-size:9px;
  animation:petalSpin 3s linear infinite;
  filter:drop-shadow(0 0 4px #ff96c8);
}
@keyframes petalSpin{0%{transform:rotate(0deg);}100%{transform:rotate(360deg);}}

/* ── DISCORD ── */
.dc-box{background:linear-gradient(135deg,#32357a,#282c6e);border-radius:var(--rl);padding:17px 21px;display:flex;align-items:center;gap:15px;margin-bottom:13px;flex-wrap:wrap;}
.dc-box h3{font-size:14px;font-weight:600;margin-bottom:2px;}
.dc-box p{font-size:11.5px;opacity:.8;line-height:1.5;}
.btn-dc{background:#fff;color:#4752c4;padding:7px 15px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;border:none;transition:var(--tr);font-family:var(--fn);}

/* ── REVIEW / RATING ── */
.review-card{background:var(--sf2);border:1px solid var(--bd);border-radius:var(--r);padding:14px 16px;margin-bottom:10px;}
.stars{color:var(--g300);font-size:13px;letter-spacing:2px;}

/* ── NOTICE ── */
.nc{display:flex;gap:10px;padding:13px 15px;background:var(--sf);border:1px solid var(--bd);border-radius:var(--r);transition:var(--tr);cursor:pointer;}
.nc:hover{border-color:var(--t800);}
.ni{width:33px;height:33px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;background:rgba(49,144,112,0.1);}

/* ── MODAL ── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,0.72);backdrop-filter:blur(8px);z-index:2000;display:flex;align-items:center;justify-content:center;padding:16px;opacity:0;pointer-events:none;transition:opacity .22s;}
.overlay.open{opacity:1;pointer-events:all;}
.modal{background:var(--bg2);border:1px solid rgba(86,201,172,0.2);position:relative;border-radius:var(--rl);padding:22px;max-width:520px;width:100%;max-height:92vh;overflow-y:auto;transform:scale(.97) translateY(6px);transition:transform .22s;box-shadow:0 24px 64px rgba(0,0,0,.65);}
.overlay.open .modal{transform:scale(1) translateY(0);}
.mh{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:16px;gap:10px;}
.mt{font-family:var(--fs);font-size:16px;font-weight:600;background:linear-gradient(90deg,var(--tc),var(--b5));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.mc{width:28px;height:28px;border-radius:7px;border:1px solid var(--bd);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;color:var(--ink3);transition:var(--tr);}
.mc:hover{background:var(--sf3);color:var(--ink);}

/* ── FORMS ── */
.fg{margin-bottom:12px;}
.fl2{display:block;font-size:12px;font-weight:500;color:var(--ink2);margin-bottom:5px;}
.freq{color:var(--g300);margin-left:2px;}
.fi2,.fs2,.ft2{width:100%;padding:9px 12px;border:1px solid var(--bd);border-radius:8px;font-size:12.5px;color:var(--ink);background:var(--bg3);font-family:var(--fn);transition:var(--tr);outline:none;}
.fi2:focus,.fs2:focus,.ft2:focus{border-color:var(--ta);box-shadow:0 0 0 3px rgba(49,144,112,0.11);}
.fi2::placeholder,.ft2::placeholder{color:var(--ink3);}
.ft2{min-height:86px;resize:vertical;}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:9px;}

/* ── IMAGE UPLOAD ── */
.img-upload-box{border:2px dashed var(--bd2);border-radius:var(--r);padding:28px 20px;text-align:center;cursor:pointer;transition:var(--tr);position:relative;overflow:hidden;background:var(--bg3);}
.img-upload-box:hover{border-color:var(--ta);background:rgba(49,144,112,0.05);}
.img-upload-box.dragover{border-color:var(--tc);background:rgba(49,144,112,0.08);}
.img-upload-box input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.img-upload-box .upload-icon{font-size:28px;margin-bottom:8px;opacity:.6;}
.img-upload-box p{font-size:12px;color:var(--ink3);line-height:1.6;}
.img-preview-wrap{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;}
.img-preview{width:80px;height:80px;border-radius:8px;object-fit:cover;border:1px solid var(--bd2);position:relative;}
.img-preview-item{position:relative;display:inline-block;}
.img-preview-item .del-img{position:absolute;top:-4px;right:-4px;width:18px;height:18px;border-radius:50%;background:#e55;border:none;cursor:pointer;font-size:10px;color:#fff;display:flex;align-items:center;justify-content:center;line-height:1;}
.thumb-preview{width:100%;height:130px;border-radius:var(--r);object-fit:cover;border:1px solid var(--bd2);margin-top:8px;display:none;}

/* ── PORTFOLIO GRID ── */
.portfolio-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:10px;}
.port-item{aspect-ratio:1;border-radius:var(--r);border:1px solid var(--bd);overflow:hidden;cursor:pointer;transition:var(--tr);position:relative;background:var(--sf2);}
.port-item:hover{border-color:var(--ta);transform:scale(1.03);}
.port-item img{width:100%;height:100%;object-fit:cover;}
.port-item .port-emoji{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:36px;}
.port-overlay{position:absolute;inset:0;background:rgba(0,0,0,.6);display:flex;align-items:center;justify-content:center;opacity:0;transition:var(--tr);font-size:11.5px;color:#fff;}
.port-item:hover .port-overlay{opacity:1;}

/* ── TYPE SELECTOR ── */
.type-selector{display:grid;grid-template-columns:repeat(auto-fill,minmax(112px,1fr));gap:7px;margin-top:5px;}
.type-opt{padding:8px;border-radius:7px;border:1px solid var(--bd);background:transparent;cursor:pointer;transition:var(--tr);text-align:center;font-size:11.5px;color:var(--ink2);font-family:var(--fn);}
.type-opt:hover,.type-opt.on{border-color:var(--ta);background:rgba(49,144,112,0.1);color:var(--tc);}

/* ── COMM WRITE PREVIEW ── */
.comm-preview-card{background:var(--sf2);border:1px solid var(--bd);border-radius:var(--r);overflow:hidden;margin-top:10px;}
.comm-preview-thumb{width:100%;height:110px;object-fit:cover;background:linear-gradient(135deg,var(--t300),var(--t400));display:flex;align-items:center;justify-content:center;font-size:36px;}

/* ── LIGHTBOX ── */
.lightbox{position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:3000;display:flex;align-items:center;justify-content:center;cursor:pointer;opacity:0;pointer-events:none;transition:opacity .22s;}
.lightbox.open{opacity:1;pointer-events:all;}
.lightbox img{max-width:90vw;max-height:90vh;border-radius:var(--r);box-shadow:0 20px 60px rgba(0,0,0,.8);}

/* ── TOAST ── */
.tw{position:fixed;bottom:20px;right:20px;z-index:4000;display:flex;flex-direction:column;gap:7px;}
.toast{background:var(--sf3);border:1px solid var(--bd2);color:var(--ink);padding:10px 14px;border-radius:8px;font-size:12.5px;max-width:280px;animation:slideUp .26s ease;display:flex;align-items:center;gap:8px;}
.toast.ok{border-color:rgba(49,144,112,.4);background:rgba(49,144,112,.1);}
.toast.err{border-color:rgba(200,60,60,.4);background:rgba(200,60,60,.08);}
@keyframes slideUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* ── DECO ── */
.deco-div{display:flex;align-items:center;gap:10px;margin:36px 0 28px;}
.deco-div::before,.deco-div::after{content:'';flex:1;height:1px;background:linear-gradient(to right,transparent,rgba(232,168,0,0.35),transparent);}

/* ── EMPTY ── */
.empty{text-align:center;padding:68px 20px;}
.empty-icon{font-size:46px;opacity:.28;margin-bottom:13px;}
.empty h3{font-size:15px;font-weight:500;color:var(--ink2);margin-bottom:6px;}
.empty p{font-size:12px;color:var(--ink3);line-height:1.7;}

/* ── ADMIN TABLE ── */
.at{width:100%;border-collapse:collapse;font-size:12px;}
.at th{text-align:left;padding:8px 10px;font-size:10.5px;font-weight:600;color:var(--ink3);letter-spacing:.4px;border-bottom:1px solid var(--bd);white-space:nowrap;}
.at td{padding:9px 10px;border-bottom:1px solid var(--bd);vertical-align:middle;}
.at tr:hover td{background:rgba(49,144,112,.05);}
.tbl{overflow-x:auto;}

/* ── FOOTER ── */
footer{background:linear-gradient(135deg,rgba(14,17,23,0.98),rgba(18,22,30,0.98));border-top:1px solid transparent;border-image:linear-gradient(90deg,rgba(139,92,246,0.2),rgba(86,201,172,0.3),rgba(232,168,0,0.2)) 1;padding:42px 0 24px;margin-top:56px;position:relative;z-index:1;}
.foot-inner{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:24px;max-width:1240px;margin:0 auto;padding:0 20px;}
.foot-brand h3{font-family:var(--fd);font-size:15px;letter-spacing:2px;margin-bottom:6px;background:linear-gradient(90deg,var(--tc),var(--g200));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.foot-brand p{font-size:11px;color:var(--t900);line-height:1.65;}
.foot-col h4{font-size:10px;font-weight:600;color:var(--t800);letter-spacing:1px;text-transform:uppercase;margin-bottom:9px;}
.foot-col a{display:block;font-size:11px;color:var(--t700);text-decoration:none;margin-bottom:5px;cursor:pointer;transition:var(--tr);}
.foot-col a:hover{color:var(--g200);}
.foot-bot{display:flex;align-items:center;justify-content:space-between;padding:15px 20px 0;max-width:1240px;margin:0 auto;border-top:1px solid rgba(255,255,255,.04);font-size:10px;color:var(--t600);flex-wrap:wrap;gap:5px;}

/* ── RICH EDITOR ── */
.editor-tool{padding:4px 8px;border-radius:5px;border:1px solid var(--bd);background:var(--bg3);color:var(--ink2);cursor:pointer;font-size:12px;transition:var(--tr);font-family:var(--fn);}
.editor-tool:hover{background:rgba(49,144,112,0.12);border-color:var(--ta);color:var(--tc);}
#richEditor:empty:before{content:attr(placeholder);color:var(--ink3);pointer-events:none;font-size:13px;line-height:1.75;}
#richEditor img{max-width:100%;border-radius:var(--r);margin:6px 0;cursor:pointer;transition:var(--tr);}
#richEditor img:hover{opacity:.85;}
#richEditor h2{font-family:var(--fs);font-size:17px;font-weight:600;color:var(--tc);margin:12px 0 6px;padding-bottom:5px;border-bottom:1px solid var(--bd);}
#richEditor hr{border:none;border-top:1px solid var(--bd);margin:14px 0;}
#richEditor ul,#richEditor ol{padding-left:20px;margin:6px 0;}
#richEditor li{margin-bottom:3px;}
.cr-tab.active{color:var(--tc)!important;border-bottom:2px solid var(--tc)!important;background:rgba(49,144,112,0.06);}
.cr-tab:hover{color:var(--ink2)!important;background:rgba(49,144,112,0.05);}


/* ── 태그 자동완성 ── */
.tag-suggest-wrap{position:relative;}
.tag-suggest-box{display:none;position:absolute;top:100%;left:0;right:0;background:var(--bg2);border:1px solid var(--bd2);border-radius:8px;z-index:200;flex-wrap:wrap;gap:5px;padding:8px;max-height:120px;overflow-y:auto;box-shadow:0 8px 24px rgba(0,0,0,.4);}
.tag-suggest-btn{padding:4px 10px;border-radius:16px;border:1px solid var(--bd);background:rgba(79,189,149,0.08);color:var(--tc);font-size:11.5px;cursor:pointer;transition:var(--tr);font-family:var(--fn);}
.tag-suggest-btn:hover{background:rgba(79,189,149,0.2);border-color:var(--ta);}
/* ── AD PLAN ── */
.ad-plan-opt{padding:14px;border-radius:9px;border:1.5px solid var(--bd);background:var(--sf2);cursor:pointer;text-align:center;transition:var(--tr);}
.ad-plan-opt:hover,.ad-plan-opt.on{border-color:var(--g400);background:rgba(212,160,23,0.06);}

/* ── CASH OPT ── */
.cash-opt{padding:14px;border-radius:9px;border:1.5px solid var(--bd);background:var(--sf2);cursor:pointer;text-align:center;transition:var(--tr);}
.cash-opt:hover,.cash-opt.on{border-color:var(--g400);background:rgba(232,168,0,0.06);}

/* ── RESPONSIVE ── */
@media(max-width:900px){.dash-layout{grid-template-columns:1fr;}.sidebar{position:static;}.foot-inner{grid-template-columns:1fr 1fr;}}
@media(max-width:640px){
  .nav-links,.nav-actions{display:none;}
  .hamburger{display:flex;}
  .stat-row{grid-template-columns:1fr 1fr;}
  .sib:nth-child(2){border-right:none;}
  .frow{grid-template-columns:1fr;}
  .hero{padding:50px 0 36px;}
  .hero-deco{display:none;}
  .foot-inner{grid-template-columns:1fr;}
  .pricing-grid{grid-template-columns:1fr;}
  .artist-row-stats{display:none;}
  nav.mob-open .nav-links{display:flex;flex-direction:column;position:absolute;top:58px;left:0;right:0;background:rgba(4,11,9,.97);border-bottom:1px solid var(--bd);padding:8px;z-index:800;}
  nav.mob-open .nav-actions{display:flex;flex-direction:column;position:absolute;top:58px;left:0;right:0;background:rgba(4,11,9,.97);border-bottom:1px solid var(--bd);padding:0 8px 8px;z-index:800;margin-top:170px;}
}
</style>
</head>
<body>

<!-- NAV -->
<nav id="nb">
  <div class="nav-inner">
    <div class="logo" onclick="goto('home')">
      <!-- 한국 전통풍 로고 마크 — 태극·단청 모티프 -->
      <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="kl1" x1="0" y1="0" x2="36" y2="36"><stop offset="0%" stop-color="#56c9ac"/><stop offset="100%" stop-color="#1a3040"/></linearGradient>
          <linearGradient id="kl2" x1="0" y1="0" x2="36" y2="36"><stop offset="0%" stop-color="#60a5fa"/><stop offset="50%" stop-color="#a78bfa"/><stop offset="100%" stop-color="#fcd94a"/></linearGradient>
          <filter id="kglow"><feGaussianBlur stdDeviation="1.2" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        </defs>
        <!-- 배경 육각형 (단청 느낌) -->
        <path d="M18 2 L32 10 L32 26 L18 34 L4 26 L4 10 Z" fill="#0c1525" stroke="url(#kl2)" stroke-width="1.2"/>
        <!-- 내부 문창살 패턴 -->
        <line x1="4" y1="18" x2="32" y2="18" stroke="rgba(86,201,172,0.2)" stroke-width="0.6"/>
        <line x1="18" y1="2" x2="18" y2="34" stroke="rgba(232,168,0,0.18)" stroke-width="0.6"/>
        <path d="M4 10 L32 26 M32 10 L4 26" stroke="rgba(167,139,250,0.12)" stroke-width="0.5"/>
        <!-- 중앙 단청 원 -->
        <circle cx="18" cy="18" r="8" fill="none" stroke="url(#kl2)" stroke-width="1.5" filter="url(#kglow)"/>
        <!-- K 문자 -->
        <text x="18" y="22.5" font-family="Georgia,serif" font-size="11" font-weight="700" text-anchor="middle" fill="url(#kl2)" filter="url(#kglow)">K</text>
        <!-- 꼭짓점 장식 (단청 매듭) -->
        <circle cx="18" cy="3.5" r="1.2" fill="#56c9ac" opacity="0.9"/>
        <circle cx="31" cy="10.5" r="1.2" fill="#60a5fa" opacity="0.9"/>
        <circle cx="31" cy="25.5" r="1.2" fill="#a78bfa" opacity="0.9"/>
        <circle cx="18" cy="32.5" r="1.2" fill="#fcd94a" opacity="0.9"/>
        <circle cx="5" cy="25.5" r="1.2" fill="#56c9ac" opacity="0.6"/>
        <circle cx="5" cy="10.5" r="1.2" fill="#fcd94a" opacity="0.6"/>
      </svg>
      <div>
        <div class="logo-main">KIMAS</div>
        <div class="logo-sub">커미션 플랫폼</div>
      </div>
    </div>
    <ul class="nav-links" id="navLinks">
      <li><a class="active" onclick="goto('home');setNav(this)">🏠 홈</a></li>
      <li><a onclick="goto('artists');setNav(this)">🎨 작가 찾기</a></li>
      <li><a onclick="goto('seeking');setNav(this)">📋 구해요</a></li>
      <li><a onclick="goto('pricing');setNav(this)">💎 구독</a></li>
      <li><a onclick="goto('notice');setNav(this)">📢 공지</a></li>
      <li><a onclick="goto('community');setNav(this)">🖼️ 커뮤니티</a></li>
      <li><a onclick="goto('shop');setNav(this)" style="color:var(--g300);">🪙 상점</a></li>
      <li><a onclick="goto('qna');setNav(this)" style="color:var(--g300);">❓ Q&amp;A</a></li>
    </ul>
    <div class="nav-actions" id="navAct">
      <button class="btn btn-ghost" id="loginBtn" onclick="openM('mLogin')">로그인</button>
      <button class="btn btn-teal" id="signupBtn" onclick="openM('mSignup')">회원가입</button>
      <button class="btn btn-ghost" id="dashBtn" style="display:none" onclick="goto('dashboard')">대시보드</button>
      <button class="btn btn-ghost" id="logoutBtn" style="display:none" onclick="doLogout()">로그아웃</button>
    </div>
    <button class="hamburger" onclick="toggleMob()"><span></span><span></span><span></span></button>
  </div>
</nav>

<!-- ═══ HOME ═══ -->
<div id="page-home" class="page active z1">
  <div class="container">
    <div class="hero" style="position:relative;overflow:visible;padding:88px 20px 96px;background:#07080f;min-height:520px;">
      <svg style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;" viewBox="0 0 1200 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="j1" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#d8ecff"/><stop offset="35%" stop-color="#e8d8ff"/>
            <stop offset="65%" stop-color="#c0eef8"/><stop offset="100%" stop-color="#f0d8f8"/>
          </linearGradient>
          <linearGradient id="j2" x1="100%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#c8d8ff"/><stop offset="40%" stop-color="#e8c8f8"/>
            <stop offset="70%" stop-color="#b8eef8"/><stop offset="100%" stop-color="#d8f0e8"/>
          </linearGradient>
          <radialGradient id="cglow" cx="50%" cy="50%" r="50%">
            <stop offset="0%"   stop-color="#56c9ac" stop-opacity="0.07"/>
            <stop offset="60%"  stop-color="#60a5fa" stop-opacity="0.03"/>
            <stop offset="100%" stop-color="#000" stop-opacity="0"/>
          </radialGradient>
          <filter id="glo"><feGaussianBlur stdDeviation="2.5" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          <filter id="glo2"><feGaussianBlur stdDeviation="7" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          <filter id="glo3"><feGaussianBlur stdDeviation="1.2" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          <filter id="star"><feGaussianBlur stdDeviation="1.5" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        </defs>

        <!-- ══ 글로우 링 (달 자리) ══ -->
        <circle cx="600" cy="290" r="145" fill="none" stroke="#56c9ac" stroke-width="0.5" stroke-opacity="0.12" filter="url(#glo2)"/>
        <circle cx="600" cy="290" r="130" fill="none" stroke="#56c9ac" stroke-width="0.8" stroke-opacity="0.18" filter="url(#glo2)"/>
        <circle cx="600" cy="290" r="115" fill="none" stroke="#56c9ac" stroke-width="2" stroke-opacity="0.65" filter="url(#glo)"/>
        <circle cx="600" cy="290" r="110" fill="none" stroke="#60a5fa" stroke-width="0.8" stroke-opacity="0.35" filter="url(#glo)"/>
        <circle cx="600" cy="290" r="104" fill="none" stroke="#a78bfa" stroke-width="0.5" stroke-opacity="0.2"/>
        <circle cx="600" cy="290" r="96"  fill="none" stroke="#56c9ac" stroke-width="0.4" stroke-opacity="0.15"/>
        <circle cx="600" cy="290" r="115" fill="url(#cglow)"/>

        <!-- ══ 별들 — 전체 ══ -->
        <!-- 큰 4각별 -->
        <g filter="url(#star)">
          <path d="M120 85 L123 96 L134 96 L125 103 L128 114 L120 107 L112 114 L115 103 L106 96 L117 96Z" fill="#a78bfa" fill-opacity="0.85"/>
          <path d="M1068 72 L1071 83 L1082 83 L1073 90 L1076 101 L1068 94 L1060 101 L1063 90 L1054 83 L1065 83Z" fill="#60a5fa" fill-opacity="0.85"/>
          <path d="M692 42 L695 53 L706 53 L697 60 L700 71 L692 64 L684 71 L687 60 L678 53 L689 53Z" fill="#d8ecff" fill-opacity="0.8"/>
          <path d="M418 38 L421 48 L432 48 L424 54 L427 64 L418 58 L410 64 L413 54 L404 48 L415 48Z" fill="#e8d8ff" fill-opacity="0.7"/>
          <!-- 다이아몬드 별 -->
          <path d="M200 140 L206 154 L200 168 L194 154Z" fill="#56c9ac" fill-opacity="0.7"/>
          <path d="M1000 130 L1006 144 L1000 158 L994 144Z" fill="#a78bfa" fill-opacity="0.7"/>
          <path d="M350 60 L354 70 L350 80 L346 70Z" fill="#60a5fa" fill-opacity="0.6"/>
          <path d="M850 55 L854 65 L850 75 L846 65Z" fill="#d8ecff" fill-opacity="0.6"/>
        </g>
        <!-- 작은 점별 -->
        <g fill="url(#j1)" filter="url(#glo3)">
          <circle cx="55"  cy="55"  r="2.5" fill="#d8ecff" fill-opacity="0.6"/>
          <circle cx="310" cy="40"  r="2"   fill="#a78bfa"  fill-opacity="0.55"/>
          <circle cx="480" cy="28"  r="1.8" fill="#56c9ac"  fill-opacity="0.5"/>
          <circle cx="555" cy="50"  r="1.5" fill="#c0eef8"  fill-opacity="0.5"/>
          <circle cx="645" cy="45"  r="1.5" fill="#e8d8ff"  fill-opacity="0.5"/>
          <circle cx="720" cy="30"  r="2"   fill="#60a5fa"  fill-opacity="0.55"/>
          <circle cx="880" cy="38"  r="1.8" fill="#a78bfa"  fill-opacity="0.5"/>
          <circle cx="960" cy="55"  r="2"   fill="#d8ecff"  fill-opacity="0.55"/>
          <circle cx="1140" cy="48" r="2.5" fill="#56c9ac"  fill-opacity="0.6"/>
          <circle cx="160" cy="175" r="1.5" fill="#60a5fa"  fill-opacity="0.45"/>
          <circle cx="1040" cy="170" r="1.5" fill="#a78bfa" fill-opacity="0.45"/>
          <circle cx="260" cy="100" r="1.5" fill="#d8ecff"  fill-opacity="0.4"/>
          <circle cx="940" cy="95"  r="1.5" fill="#c0eef8"  fill-opacity="0.4"/>
          <!-- 반짝이 (십자) -->
          <line x1="80"  y1="160" x2="80"  y2="172" stroke="#56c9ac" stroke-width="1" stroke-opacity="0.5"/>
          <line x1="74"  y1="166" x2="86"  y2="166" stroke="#56c9ac" stroke-width="1" stroke-opacity="0.5"/>
          <line x1="1118" y1="155" x2="1118" y2="167" stroke="#a78bfa" stroke-width="1" stroke-opacity="0.5"/>
          <line x1="1112" y1="161" x2="1124" y2="161" stroke="#a78bfa" stroke-width="1" stroke-opacity="0.5"/>
