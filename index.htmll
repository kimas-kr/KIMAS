<div id="home-extra">
  <!-- ── 곡두문(뇌문) 단청 장식띠 ── -->
  <div style="width:100%;overflow:hidden;line-height:0;margin:0;">
    <svg width="100%" height="18" viewBox="0 0 1200 18" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <!-- 뇌문(곡두문) 반복 패턴 -->
      <defs>
        <pattern id="noemu" x="0" y="0" width="60" height="18" patternUnits="userSpaceOnUse">
          <!-- 뇌문 단위: ㄱ자 반복 -->
          <rect x="0" y="0" width="60" height="18" fill="none"/>
          <path d="M2 4 L2 14 L10 14 L10 8 L18 8 L18 14 L26 14 L26 4 L18 4 L18 8 L10 8 L10 4 Z" fill="none" stroke="#fcd94a" stroke-width="1" stroke-opacity="0.45"/>
          <path d="M30 4 L30 14 L38 14 L38 8 L46 8 L46 14 L54 14 L54 4 L46 4 L46 8 L38 8 L38 4 Z" fill="none" stroke="#56c9ac" stroke-width="1" stroke-opacity="0.35"/>
        </pattern>
      </defs>
      <rect width="100%" height="18" fill="url(#noemu)"/>
    </svg>
  </div>

  <div class="stat-bar z1"><div class="stat-row container">
    <div class="sib"><div class="sib-num" id="statA">0</div><div class="sib-lbl">등록 작가</div></div>
    <div class="sib"><div class="sib-num" id="statC">0</div><div class="sib-lbl">등록 커미션</div></div>
    <div class="sib"><div class="sib-num">3.5%~</div><div class="sib-lbl">최저 수수료</div></div>
    <div class="sib"><div class="sib-num">30h</div><div class="sib-lbl">끌올 쿨타임</div></div>
  </div></div>
  <div class="container">
    <!-- ── 광고 배너 슬라이더 ── -->
    <div id="adBannerWrap" style="display:none;margin-top:36px;">
      <div class="sec-hdr" style="margin-bottom:12px;">
        <div style="display:flex;align-items:center;gap:8px;font-size:11px;color:var(--ink3);">
          <span style="padding:2px 8px;background:rgba(212,160,23,0.12);border:1px solid var(--bdg);border-radius:5px;font-size:10px;color:var(--g300);font-weight:600;">AD</span>
          스폰서 커미션
        </div>
        <button class="btn btn-ghost btn-sm" onclick="requireLogin(()=>openM('mAdPurchase'))">📢 광고 등록하기</button>
      </div>
      <div style="position:relative;overflow:hidden;border-radius:var(--rl);">
        <div id="adSlider" style="display:flex;transition:transform 0.5s cubic-bezier(.4,0,.2,1);will-change:transform;"></div>
        <button id="adPrev" onclick="slideAd(-1)" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);width:32px;height:32px;border-radius:50%;background:rgba(4,11,9,.7);border:1px solid var(--bd2);color:var(--ink);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;z-index:10;backdrop-filter:blur(8px);">‹</button>
        <button id="adNext" onclick="slideAd(1)" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);width:32px;height:32px;border-radius:50%;background:rgba(4,11,9,.7);border:1px solid var(--bd2);color:var(--ink);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;z-index:10;backdrop-filter:blur(8px);">›</button>
        <div id="adDots" style="position:absolute;bottom:10px;left:50%;transform:translateX(-50%);display:flex;gap:5px;"></div>
      </div>
    </div>
    <!-- 광고 없을 때 등록 유도 -->
    <div id="adEmptyWrap" style="margin-top:36px;padding:18px 20px;background:rgba(212,160,23,0.04);border:1px dashed var(--bdg);border-radius:var(--rl);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
      <div><div style="font-size:13px;font-weight:500;color:var(--g300);margin-bottom:3px;">📢 이 자리에 내 커미션 광고를 올려보세요!</div><div style="font-size:11.5px;color:var(--ink3);">기본 4일 · 연장 가능 · 메인 홈 상단 노출</div></div>
      <button class="btn btn-gold btn-sm" onclick="requireLogin(()=>openM('mAdPurchase'))">광고 등록하기</button>
    </div>

    <section>
      <div class="sec-hdr"><div class="sec-ttl">최신 커미션</div><button class="btn btn-ghost btn-sm" onclick="goto('artists')">전체 보기 →</button></div>
      <div id="homeGrid"></div>
    </section>
    <div class="deco-div">❖</div>
    <section style="padding:36px 0 46px;text-align:center;">
      <div class="sec-ttl" style="justify-content:center;margin-bottom:6px;">이용 방법</div>
      <p style="font-size:12px;color:var(--ink3);margin-bottom:28px;">4단계로 소중한 그림을 받아보세요</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:13px;">
        <div style="padding:18px;background:var(--sf);border:1px solid var(--bd);border-radius:var(--rl);"><div style="font-size:26px;margin-bottom:8px;">🔍</div><div style="font-family:var(--fs);font-size:13px;font-weight:600;color:var(--tc);margin-bottom:3px;">1. 작가 탐색</div><p style="font-size:11.5px;color:var(--ink3);line-height:1.6;">스타일·타입별로 원하는 작가를 검색하고 포트폴리오를 확인하세요</p></div>
        <div style="padding:18px;background:var(--sf);border:1px solid var(--bd);border-radius:var(--rl);"><div style="font-size:26px;margin-bottom:8px;">💬</div><div style="font-family:var(--fs);font-size:13px;font-weight:600;color:var(--tc);margin-bottom:3px;">2. 문의 · 신청</div><p style="font-size:11.5px;color:var(--ink3);line-height:1.6;">작가에게 직접 문의하고 참고 이미지를 첨부해 원하는 그림을 설명하세요</p></div>
        <div style="padding:18px;background:var(--sf);border:1px solid var(--bd);border-radius:var(--rl);"><div style="font-size:26px;margin-bottom:8px;">💳</div><div style="font-family:var(--fs);font-size:13px;font-weight:600;color:var(--tc);margin-bottom:3px;">3. 에스크로 결제</div><p style="font-size:11.5px;color:var(--ink3);line-height:1.6;">안전한 에스크로 방식으로 결제, 플랫폼이 금액을 보관합니다</p></div>
        <div style="padding:18px;background:var(--sf);border:1px solid var(--bd);border-radius:var(--rl);"><div style="font-size:26px;margin-bottom:8px;">✨</div><div style="font-family:var(--fs);font-size:13px;font-weight:600;color:var(--tc);margin-bottom:3px;">4. 완성 · 수령</div><p style="font-size:11.5px;color:var(--ink3);line-height:1.6;">완성 작품을 확인하고 최종 승인, 작가에게 대금이 지급됩니다</p></div>
      </div>
    </section>
  </div>
</div>

<!-- ═══ ARTISTS ═══ -->
</div><!-- home-extra -->
<div id="page-artists" class="page z1">
  <div class="container" style="padding-top:32px;padding-bottom:56px;">
    <div style="margin-bottom:20px;"><h1 style="font-family:var(--fs);font-size:23px;font-weight:600;color:var(--tc);margin-bottom:3px;">작가 찾기</h1><p style="font-size:12px;color:var(--ink3);">원하는 스타일의 작가를 찾아 커미션을 의뢰하세요</p></div>
    <div class="tab-bar">
      <button class="tab-btn active" onclick="switchTab('ca',this)">전체 커미션</button>
      <button class="tab-btn" onclick="switchTab('co',this)">모집 중</button>
      <button class="tab-btn" onclick="switchTab('cal',this)">작가 목록</button>
    </div>
    <div class="filter-bar">
      <span class="flbl">타입</span>
      <button class="chip on" onclick="setF(this,'type','전체')">전체</button>
      <button class="chip" onclick="setF(this,'type','일러스트')">일러스트</button>
      <button class="chip" onclick="setF(this,'type','캐릭터')">캐릭터</button>
      <button class="chip" onclick="setF(this,'type','배경')">배경</button>
      <button class="chip" onclick="setF(this,'type','SD·치비')">SD·치비</button>
      <button class="chip" onclick="setF(this,'type','버추얼')">버추얼</button>
      <div class="sbox" style="margin-left:auto;"><span style="color:var(--ink3);">🔍</span><input type="text" id="aSearch" placeholder="작가명, 태그 검색..." oninput="renderAP()"></div>
    </div>
    <div id="tab-ca" class="tab-content active"><div class="card-grid" id="gAll"></div></div>
    <div id="tab-co" class="tab-content"><div class="card-grid" id="gOpen"></div></div>
    <div id="tab-cal" class="tab-content"><div class="artist-list" id="gArtists"></div></div>
  </div>
</div>

<!-- ═══ SEEKING ═══ -->
<div id="page-seeking" class="page z1">
  <div class="container" style="padding-top:32px;padding-bottom:56px;">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:20px;flex-wrap:wrap;">
      <div><h1 style="font-family:var(--fs);font-size:23px;font-weight:600;color:var(--tc);margin-bottom:3px;">구해요 게시판</h1><p style="font-size:12px;color:var(--ink3);">원하는 작가를 찾고 있다면 여기에 올려보세요</p></div>
      <button class="btn btn-teal" onclick="requireLogin(()=>openM('mSeeking'))">✏️ 글쓰기</button>
      <button class="btn btn-ghost btn-sm" id="adultSeekBtn" onclick="toggleAdultSeeking(this)">🔞 성인글 보기</button>
    </div>
    <div class="filter-bar">
      <span class="flbl">카테고리</span>
      <button class="chip on" onclick="setF(this,'seek','전체')">전체</button>
      <button class="chip" onclick="setF(this,'seek','일러스트')">일러스트</button>
      <button class="chip" onclick="setF(this,'seek','캐릭터')">캐릭터</button>
      <button class="chip" onclick="setF(this,'seek','배경')">배경</button>
      <button class="chip" onclick="setF(this,'seek','기타')">기타</button>
    </div>
    <div id="seekList" style="display:flex;flex-direction:column;gap:9px;"></div>
  </div>
</div>

<!-- ═══ PRICING ═══ -->
<div id="page-pricing" class="page z1">
  <div class="container" style="padding-top:52px;padding-bottom:56px;">
    <div style="text-align:center;margin-bottom:10px;"><h1 style="font-family:var(--fs);font-size:27px;font-weight:600;color:var(--tc);margin-bottom:6px;">구독 플랜</h1><p style="font-size:12.5px;color:var(--ink3);">작가 활동에 최적화된 플랜을 선택하세요</p></div>
    <div class="pricing-grid">
      <div class="pc"><div style="font-size:22px;margin-bottom:8px;">🖌️</div><div class="plan-n">Free</div><div class="plan-price"><span class="pamt" style="color:var(--ink3);">무료</span></div><p class="pdesc">처음 시작하는 작가를 위한 기본 플랜</p><div class="div"></div>
        <div class="hlr"><span>커미션 슬롯</span><span class="hlv">4개</span></div><div class="hlr"><span>수수료</span><span class="hlv" style="color:#e87;">7%</span></div><div class="hlr"><span>커미션 타입</span><span class="hlv">4개</span></div><div class="hlr"><span>끌올 쿨타임</span><span class="hlv">30시간</span></div>
        <ul class="fl"><li><div class="fic">✓</div>기본 프로필 페이지</li><li><div class="fic">✓</div>포트폴리오 이미지 등록</li><li><div class="fic">✓</div>구해요 게시판 이용</li><li><div class="fic">✓</div>에스크로 결제</li></ul>
        <button class="btn btn-ghost" style="width:100%;justify-content:center;" onclick="openM('mSignup')">무료로 시작하기</button></div>
      <div class="pc feat"><div class="pbadge pop">✦ 인기</div><div style="font-size:22px;margin-bottom:8px;">🎨</div><div class="plan-n" style="color:var(--tc);">Pro</div><div class="plan-price"><span class="pamt">3,990</span><span class="pper">원 / 월</span></div><p class="pdesc">활발하게 활동하는 작가를 위한 전문가 플랜</p><div class="div"></div>
        <div class="hlr"><span>커미션 슬롯</span><span class="hlv">9개 <span style="font-size:10px;color:var(--t900);">(+5)</span></span></div><div class="hlr"><span>수수료</span><span class="hlv">5%</span></div><div class="hlr"><span>커미션 타입</span><span class="hlv">9개 <span style="font-size:10px;color:var(--t900);">(+5)</span></span></div><div class="hlr"><span>끌올 쿨타임</span><span class="hlv">30시간</span></div>
        <ul class="fl"><li><div class="fic">✓</div>PRO 배지 표시</li><li><div class="fic">✓</div>상단 노출 가산점</li><li><div class="fic">✓</div>수익 통계 대시보드</li><li><div class="fic">✓</div>우선 고객 지원</li></ul>
        <button class="btn btn-teal" style="width:100%;justify-content:center;" onclick="openM('mSubscribe')">Pro 구독하기</button></div>
      <div class="pc ultra-c"><div class="pbadge prm">★ ULTRA</div><div style="font-size:22px;margin-bottom:8px;">👑</div><div class="plan-n" style="color:var(--g200);">Ultra</div><div class="plan-price"><span class="pamt" style="color:var(--g200);">5,990</span><span class="pper">원 / 월</span></div><p class="pdesc">최고 수준의 혜택을 원하는 전문 작가 플랜</p><div class="div"></div>
        <div class="hlr"><span>커미션 슬롯</span><span class="hlv" style="color:var(--g200);">15개 <span style="font-size:10px;color:var(--g300);">(+11)</span></span></div><div class="hlr"><span>수수료</span><span class="hlv" style="color:var(--g200);">3.5%</span></div><div class="hlr"><span>커미션 타입</span><span class="hlv" style="color:var(--g200);">15개 <span style="font-size:10px;color:var(--g300);">(+11)</span></span></div><div class="hlr"><span>끌올 쿨타임</span><span class="hlv" style="color:var(--g200);">30시간</span></div>
        <ul class="fl"><li><div class="fic g">✓</div>ULTRA 특별 배지</li><li><div class="fic g">✓</div>최상단 노출 우선권</li><li><div class="fic g">✓</div>고급 수익 분석</li><li><div class="fic g">✓</div>Discord 알림 연동</li><li><div class="fic g">✓</div>월간 피처드 작가 후보</li></ul>
        <button class="btn btn-gold" style="width:100%;justify-content:center;" onclick="openM('mSubscribe')">Ultra 구독하기</button></div>
    </div>
