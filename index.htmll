</svg>`
};

function applyProfileFrame(value){
  // 모든 .pav에서 기존 SVG 프레임 제거
  document.querySelectorAll('.pav-frame-svg,.frame-particle,.frame-teal-ring,.frame-teal-ring2,.frame-night-star,.frame-rainbow-orb,.frame-gold-particles').forEach(el=>el.remove());
  document.querySelectorAll('.pav').forEach(el=>{
    el.classList.remove('frame-gold','frame-teal','frame-rainbow','frame-night');
    el.style.border=''; el.style.boxShadow=''; el.style.animation='';
  });
  if(!value||!FRAME_SVGS[value])return;
  // 각 .pav 부모에 SVG 삽입
  document.querySelectorAll('.pav').forEach(el=>{
    const wrap=el.parentElement;
    if(!wrap)return;
    wrap.style.position='relative';
    const temp=document.createElement('div');
    temp.innerHTML=FRAME_SVGS[value];
    const svg=temp.firstElementChild;
    if(svg)wrap.appendChild(svg);
  });
}
function clearProfileFrame(){
  document.querySelectorAll('.pav-frame-svg').forEach(el=>el.remove());
  document.querySelectorAll('.pav').forEach(el=>{
    el.classList.remove('frame-gold','frame-teal','frame-rainbow','frame-night');
    el.style.border=''; el.style.boxShadow=''; el.style.animation='';
  });
}

// ══════════════════════════════════════════════════════
//  Discord 스타일 배경 — Canvas 애니메이션
// ══════════════════════════════════════════════════════
const BG_CANVASES={
  sakura(canvas){
    if(!canvas)return;
    canvas.width=canvas.offsetWidth||220; canvas.height=canvas.offsetHeight||180;
    const ctx=canvas.getContext('2d'); const W=canvas.width; const H=canvas.height;
    const petals=Array.from({length:22},()=>({x:Math.random()*W,y:Math.random()*H-H,r:Math.random()*3+2,s:Math.random()*0.7+0.3,rot:Math.random()*Math.PI*2,dr:(Math.random()-0.5)*0.05,dx:(Math.random()-0.5)*0.5,op:Math.random()*0.5+0.3}));
    let alive=true; canvas._stopAnim=()=>alive=false;
    (function draw(){
      if(!alive)return;
      ctx.clearRect(0,0,W,H);
      const g=ctx.createRadialGradient(W/2,H/2,0,W/2,H/2,W/2);
      g.addColorStop(0,'rgba(255,180,220,0.2)'); g.addColorStop(1,'rgba(255,100,150,0.05)');
      ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
      petals.forEach(p=>{
        ctx.save(); ctx.translate(p.x,p.y); ctx.rotate(p.rot); ctx.globalAlpha=p.op;
        ctx.beginPath(); ctx.ellipse(0,0,p.r*1.6,p.r,0,0,Math.PI*2); ctx.fillStyle='#ffb8d8'; ctx.fill();
        ctx.beginPath(); ctx.ellipse(p.r*0.5,0,p.r,p.r*0.6,0.4,0,Math.PI*2); ctx.fillStyle='#ff96c8'; ctx.fill();
        ctx.restore();
        p.y+=p.s; p.x+=p.dx; p.rot+=p.dr;
        if(p.y>H+8){p.y=-8; p.x=Math.random()*W;}
      });
      requestAnimationFrame(draw);
    })();
  },
  galaxy(canvas){
    if(!canvas)return;
    canvas.width=canvas.offsetWidth||220; canvas.height=canvas.offsetHeight||180;
    const ctx=canvas.getContext('2d'); const W=canvas.width; const H=canvas.height;
    const stars=Array.from({length:50},()=>({x:Math.random()*W,y:Math.random()*H,r:Math.random()*1.5+0.3,t:Math.random()*Math.PI*2,ts:Math.random()*0.04+0.02}));
    let rot=0; let alive=true; canvas._stopAnim=()=>alive=false;
    (function draw(){
      if(!alive)return;
      ctx.clearRect(0,0,W,H);
      const g=ctx.createRadialGradient(W/2,H/2,0,W/2,H/2,W*0.7);
      g.addColorStop(0,'rgba(60,20,120,0.28)'); g.addColorStop(0.5,'rgba(30,10,80,0.15)'); g.addColorStop(1,'rgba(10,5,40,0.08)');
      ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
      ctx.save(); ctx.translate(W/2,H/2); ctx.rotate(rot);
      [[167,139,250],[96,165,250],[86,201,172]].forEach(([r,g2,b],i)=>{
        ctx.beginPath();
        for(let a=0;a<Math.PI*5;a+=0.1){const rad=a*Math.min(W,H)*0.06; ctx.lineTo(Math.cos(a+i*Math.PI*2/3)*rad,Math.sin(a+i*Math.PI*2/3)*rad);}
        ctx.strokeStyle=`rgba(${r},${g2},${b},0.14)`; ctx.lineWidth=1.2; ctx.stroke();
      });
      ctx.restore(); rot+=0.003;
      stars.forEach(s=>{s.t+=s.ts; const op=0.3+Math.sin(s.t)*0.65; ctx.beginPath(); ctx.arc(s.x,s.y,s.r,0,Math.PI*2); ctx.fillStyle=`rgba(220,210,255,${op})`; ctx.fill();});
      requestAnimationFrame(draw);
    })();
  },
  ocean(canvas){
    if(!canvas)return;
    canvas.width=canvas.offsetWidth||220; canvas.height=canvas.offsetHeight||180;
    const ctx=canvas.getContext('2d'); const W=canvas.width; const H=canvas.height;
    const bubbles=Array.from({length:10},()=>({x:Math.random()*W,y:H+Math.random()*H,r:Math.random()*2+1,s:Math.random()*0.5+0.3}));
    let t=0; let alive=true; canvas._stopAnim=()=>alive=false;
    (function draw(){
      if(!alive)return;
      ctx.clearRect(0,0,W,H);
      const g=ctx.createLinearGradient(0,0,0,H);
      g.addColorStop(0,'rgba(0,80,180,0.22)'); g.addColorStop(0.5,'rgba(0,120,200,0.14)'); g.addColorStop(1,'rgba(0,60,120,0.18)');
      ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
      [[0.15,6,'rgba(56,189,248,0.35)'],[0.11,8,'rgba(86,201,172,0.28)'],[0.08,5,'rgba(96,165,250,0.22)']].forEach(([amp,spd,col],i)=>{
        ctx.beginPath();
        for(let x=0;x<=W;x++){const y=H*0.35+i*9+Math.sin((x/W*2+t*spd)*Math.PI)*H*amp+Math.sin((x/W*3.5+t*(spd*0.6))*Math.PI)*H*0.04; x===0?ctx.moveTo(x,y):ctx.lineTo(x,y);}
        ctx.lineTo(W,H); ctx.lineTo(0,H); ctx.closePath(); ctx.fillStyle=col; ctx.fill();
      });
      bubbles.forEach(b=>{ctx.beginPath();ctx.arc(b.x,b.y,b.r,0,Math.PI*2);ctx.strokeStyle='rgba(200,240,255,0.55)';ctx.lineWidth=0.8;ctx.stroke();b.y-=b.s;if(b.y<-8){b.y=H+8;b.x=Math.random()*W;}});
      t+=0.008; requestAnimationFrame(draw);
    })();
  }
};

function applyProfileBg(value){
  // 기존 캔버스 전부 정리
  document.querySelectorAll('.pbox-bg-canvas,.global-bg-canvas').forEach(c=>{c._stopAnim?.();c.remove();});
  if(!value||!BG_CANVASES[value])return;

  // pbox에 캔버스 삽입
  document.querySelectorAll('.pbox').forEach(el=>{
    const canvas=document.createElement('canvas');
    canvas.className='pbox-bg-canvas';
    canvas.style.cssText='position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;opacity:0.85;';
    el.style.position='relative';el.insertBefore(canvas,el.firstChild);
    setTimeout(()=>{canvas.width=el.offsetWidth||220;canvas.height=el.offsetHeight||200;BG_CANVASES[value](canvas);},60);
  });

  // 전체 화면 배경 캔버스 (극히 은은하게)
  let globalCanvas=document.getElementById('globalBgCanvas');
  if(!globalCanvas){
    globalCanvas=document.createElement('canvas');
    globalCanvas.id='globalBgCanvas';
    globalCanvas.className='global-bg-canvas';
    globalCanvas.style.cssText='position:fixed;inset:0;width:100vw;height:100vh;pointer-events:none;z-index:0;opacity:0.13;';
    document.body.insertBefore(globalCanvas,document.body.firstChild);
  }
  globalCanvas.width=window.innerWidth;globalCanvas.height=window.innerHeight;
  // 전체 배경은 더 느리고 연하게
  const origCanvas={width:globalCanvas.width,height:globalCanvas.height};
  BG_CANVASES[value](globalCanvas);
}

function clearProfileBg(){
  document.querySelectorAll('.pbox-bg-canvas,.global-bg-canvas').forEach(c=>{c._stopAnim?.();c.remove();});
  const gc=document.getElementById('globalBgCanvas');if(gc){gc._stopAnim?.();gc.remove();}
}

function refreshDashboard(){
  if(S.currentUser&&document.getElementById('page-dashboard')?.classList.contains('active'))
    showDash('overview');
}

function applySlotSkin(skin){
  const body=document.body;
  ['crystal','fire','night','sakura'].forEach(s=>body.classList.remove('slot-skin-'+s));
  if(skin){
    body.classList.add('slot-skin-'+skin);
    // 동적 생성 슬롯 컨테이너에도 직접 적용
    setTimeout(()=>{
      document.querySelectorAll('[id*="slot"],[class*="slots"],.slot').forEach(el=>{
        const parent=el.closest('[class*="slot-container"],[class*="slots-wrap"],.cc,.sg');
        if(parent){
          ['crystal','fire','night','sakura'].forEach(s=>parent.classList.remove('slot-skin-'+s));
          parent.classList.add('slot-skin-'+skin);
        }
      });
    },100);
  }
}




// 슬롯 확장권 구매
async function buySlotExtension(){
  if(!S.currentUser){toast('로그인 필요','err');return;}
  if(S.currentUser.isOwner){grantSlotExtension(S.currentUser.id);toast('슬롯 확장권이 무료로 적용됐습니다! 👑','ok');return;}
  if(!spendCash(2000)){
    // 캐시 부족 시 토스로 바로 결제
    toast('캐시가 부족합니다. 토스페이먼츠로 직접 결제합니다.','ok');
    const tp=TossPayments(TOSS_CLIENT_KEY2);
    const orderId='slotExt_'+Date.now();
    sessionStorage.setItem('pendingSlotExt',JSON.stringify({userId:S.currentUser.id}));
    try{
      await tp.requestPayment('카드',{amount:2000,orderId,orderName:'[KIMAS] 슬롯 확장권 30일',
        customerName:S.currentUser.name,
        successUrl:window.location.href+'?slotpay=success&orderId='+orderId,
        failUrl:window.location.href+'?slotpay=fail'});
    }catch(e){if(e.code!=='USER_CANCEL')toast('결제 오류','err');}
    return;
  }
  grantSlotExtension(S.currentUser.id);
}

function handleSlotExtPayment(){
  const p=new URLSearchParams(window.location.search);
  if(p.get('slotpay')!=='success')return;
  const d=sessionStorage.getItem('pendingSlotExt');if(!d)return;
  const {userId}=JSON.parse(d);
  grantSlotExtension(userId);
  sessionStorage.removeItem('pendingSlotExt');
  window.history.replaceState({},'',window.location.pathname);
}

function grantSlotExtension(userId){
  const u=S.users.find(x=>x.id===userId);if(!u)return;
  u.slotExtUntil=Date.now()+30*86400000;
  if(S.currentUser?.id===userId)S.currentUser.slotExtUntil=u.slotExtUntil;
  save();toast('슬롯 확장권 30일 적용 완료! 🎉','ok');
}

function getEffectiveSlots(user){
  const u=user||S.currentUser;if(!u)return 4;
  if(u.slotExtUntil&&u.slotExtUntil>Date.now())return PLAN_SLOTS['ultra'];
  return PLAN_SLOTS[u.plan||'free'];
}

// ══════════════════════════════════════════════════════
//  커뮤니티
// ══════════════════════════════════════════════════════
let _postMediaData=null;

async function handlePostMedia(input){
  const file=input.files[0];if(!file)return;
  if(file.size>10*1024*1024*1024){toast('10GB 이하 파일만 업로드 가능합니다.','err');return;}
  let data=await readFileAsDataURL(file);

  // 이미지면 업로드 시점에 바로 워터마크 적용
  const isImg = file.type.startsWith('image/');
  if(isImg && S.currentUser && S.currentUser.watermark!==false){
    toast('워터마크 적용 중...','ok');
    data = await applyWatermark(data, S.currentUser.handle||S.currentUser.name);
    toast('워터마크 적용 완료 ✅','ok');
  }

  _postMediaData={data,type:file.type,name:file.name};
  const prev=document.getElementById('postImgPreview');
  if(prev){
    if(file.type.startsWith('video/')){
      prev.innerHTML=`<video src="${data}" controls style="max-width:100%;border-radius:var(--r);max-height:200px;"></video>`;
    } else {
      prev.innerHTML=`<img src="${data}" style="max-width:100%;border-radius:var(--r);max-height:200px;object-fit:contain;">`;
    }
  }
}

async function submitCommunityPost(){
  if(!S.currentUser)return;
  if(!_postMediaData){toast('이미지나 영상을 업로드해주세요.','err');return;}
  const desc=document.getElementById('postDesc')?.value?.trim()||'';
  const tags=document.getElementById('postTags')?.value?.split(',').map(t=>t.trim()).filter(Boolean)||[];
  const saveAllow=document.getElementById('postSaveAllow')?.checked||false;
  const adult=document.getElementById('postAdult')?.checked||false;

  // 이미지면 워터마크 적용
  let mediaData = _postMediaData.data;
  if(_postMediaData.type==='image' && S.currentUser.watermark!==false){
    toast('워터마크 적용 중...','ok');
    mediaData = await applyWatermark(mediaData, S.currentUser.handle||S.currentUser.name);
  }

  const post={
    id:Date.now(),userId:S.currentUser.id,userName:S.currentUser.name,
    userAvatar:S.currentUser.avatarUrl,userInitial:S.currentUser.name[0],
    mediaData,mediaType:_postMediaData.type,
    desc,tags,saveAllow,adult,hearts:[],comments:[],
    views:0,createdAt:new Date().toLocaleDateString('ko-KR')
  };
  if(!S.communityPosts)S.communityPosts=[];
  S.communityPosts.unshift(post);
  save();closeM('mCommunityPost');_postMediaData=null;
  toast('게시물이 올라갔습니다! 🎨','ok');
  renderCommunity();
}

function renderCommunity(){
  const showAdult=S.currentUser?.adultVerified&&S.showAdultContent;
  const posts=(S.communityPosts||[]).filter(p=>showAdult?true:!p.adult);
  renderCommunityGrid('communityGrid', posts);
  // 팔로잉
  const following=S.currentUser?.following||[];
  renderCommunityGrid('communityFollowGrid', posts.filter(p=>following.includes(p.userId)));
  // 인기
  const popular=[...posts].sort((a,b)=>(b.hearts?.length||0)-(a.hearts?.length||0));
  renderCommunityGrid('communityPopGrid', popular);
}

function renderCommunityGrid(gridId, posts){
  const grid=document.getElementById(gridId);if(!grid)return;
  if(!posts.length){grid.innerHTML='<div class="empty" style="grid-column:1/-1;"><div class="empty-icon">🖼️</div><h3>게시물이 없습니다</h3></div>';return;}
  grid.innerHTML=posts.map(p=>communityCard(p)).join('');
}

function communityCard(p){
  const liked=p.hearts?.includes(S.currentUser?.id);
  const isVideo=p.mediaType?.startsWith('video/');
  const mediaHtml=p.mediaData
    ? (isVideo
        ? `<video src="${p.mediaData}" style="width:100%;height:100%;object-fit:cover;" ${p.saveAllow?'controls':'controls controlsList="nodownload"'}></video>`
        : `<img src="${p.mediaData}" style="width:100%;height:100%;object-fit:cover;" ${p.saveAllow?'':'oncontextmenu="return false;" draggable="false"'}>`)
    : `<div style="font-size:48px;display:flex;align-items:center;justify-content:center;height:100%;">🖼️</div>`;
  return`<div class="comm-post-card" data-post-id="${p.id}">
    <div class="comm-post-img" style="position:relative;cursor:zoom-in;" onclick="openPostLightbox(${p.id})">
      ${mediaHtml}
      ${!p.saveAllow?`<div class="protect-overlay" oncontextmenu="return false;"></div>`:''}
      ${p.adult?`<div style="position:absolute;top:8px;right:8px;background:rgba(200,50,50,.8);color:white;font-size:9.5px;font-weight:700;padding:2px 6px;border-radius:4px;">🔞 성인</div>`:''}
    </div>
    <div class="comm-post-body">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:7px;">
        <div class="av" style="width:28px;height:28px;font-size:10px;cursor:pointer;" onclick="viewUserProfile(${p.userId})">${p.userAvatar?`<img src="${p.userAvatar}">`:`${p.userInitial}`}</div>
        <div style="font-size:12.5px;font-weight:500;cursor:pointer;" onclick="viewUserProfile(${p.userId})">${p.userName}</div>
        <div style="font-size:10.5px;color:var(--ink3);margin-left:auto;">${p.createdAt} · 👁 ${p.views||0}</div>
      </div>
      ${p.desc?`<div style="font-size:12.5px;color:var(--ink2);line-height:1.6;margin-bottom:7px;">${p.desc}</div>`:''}
      <div style="display:flex;gap:4px;flex-wrap:wrap;">${(p.tags||[]).map(t=>`<span class="tag">${t}</span>`).join('')}</div>
    </div>
    <div class="comm-post-actions">
      <button class="heart-btn" onclick="toggleHeart(${p.id})">${liked?'❤️':'🤍'}</button>
      <span style="font-size:12px;color:var(--ink3);">${(p.hearts||[]).length}</span>
      <button style="background:none;border:none;cursor:pointer;font-size:16px;margin-left:8px;" onclick="openComments(${p.id})">💬</button>
      <span style="font-size:12px;color:var(--ink3);">${(p.comments||[]).length}</span>
      <button style="background:none;border:none;cursor:pointer;font-size:16px;margin-left:auto;" onclick="openSharePost(${p.id})">🔗</button>
      ${S.currentUser?.id===p.userId||S.currentUser?.isOwner
        ?`<button style="background:none;border:none;cursor:pointer;font-size:14px;color:#e55;" onclick="deleteCommunityPost(${p.id})">🗑</button>`:''}
    </div>
  </div>`;
}

// ══════════════════════════════════════════════════════
//  인스타그램 스타일 게시물 뷰어
// ══════════════════════════════════════════════════════
let _pvPostId=null;

function openPostLightbox(postId){
  const p=(S.communityPosts||[]).find(x=>x.id===postId);
  if(!p)return;
  _pvPostId=postId;
  p.views=(p.views||0)+1;
  save();
  const viewer=document.getElementById('postViewer');
  if(viewer){viewer.style.display='flex';document.body.style.overflow='hidden';}
  renderPostViewer(p);
}

function renderPostViewer(p){
  if(!p)return;
  const liked=p.hearts?.includes(S.currentUser?.id);
  const author=S.users.find(u=>u.id===p.userId);
  const isOwnerOrMe=S.currentUser&&(S.currentUser.id===p.userId||S.currentUser.isOwner);

  // 미디어
  const mediaEl=document.getElementById('pv-media');
  if(mediaEl){
    if(p.mediaData){
      if(p.mediaType?.startsWith('video/')){
        mediaEl.innerHTML=`<video src="${p.mediaData}" controls autoplay loop
          style="max-width:100%;max-height:92vh;object-fit:contain;"
          ${p.saveAllow?'':'controlsList="nodownload"'}></video>`;
      } else {
        mediaEl.innerHTML=`<img src="${p.mediaData}"
          style="max-width:100%;max-height:92vh;object-fit:contain;display:block;${!p.saveAllow?'-webkit-user-drag:none;user-select:none;':''}"
          ${!p.saveAllow?'oncontextmenu="return false;" draggable="false"':''}>`;
      }
    } else {
      mediaEl.innerHTML=`<div style="font-size:72px;color:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;width:100%;height:100%;">🖼️</div>`;
    }
  }

  // 헤더
  const header=document.getElementById('pv-header');
  if(header){
    const avHtml=author?.avatarUrl
      ?`<img src="${author.avatarUrl}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`
      :`${(author?.name||'?')[0]}`;
    header.innerHTML=`
      <div class="av" style="width:36px;height:36px;font-size:13px;cursor:pointer;" onclick="closePostViewer();viewUserProfile(${p.userId})">${avHtml}</div>
      <div style="flex:1;min-width:0;">
        <div style="font-size:13.5px;font-weight:600;color:var(--ink);cursor:pointer;" onclick="closePostViewer();viewUserProfile(${p.userId})">${author?.name||'알 수 없음'}</div>
        <div style="font-size:10.5px;color:var(--ink3);">${p.createdAt||''}</div>
      </div>
      <div style="display:flex;gap:6px;">
        ${!isOwnerOrMe?`<button class="btn btn-ghost btn-sm" onclick="requireLogin(()=>openInquiryFor(${p.userId}))">💬 문의</button>`:''}
        ${isOwnerOrMe?`<button class="btn btn-ghost btn-sm" style="color:#e55;" onclick="if(confirm('삭제하시겠습니까?')){deleteCommunityPost(${p.id});closePostViewer();}">🗑 삭제</button>`:''}
      </div>`;
  }

  // 설명
  const desc=document.getElementById('pv-desc');
  if(desc){
    desc.innerHTML=`
      ${p.desc?`<div style="font-size:13px;color:var(--ink2);line-height:1.7;margin-bottom:8px;"><span style="font-weight:600;color:var(--ink);margin-right:6px;">${author?.name||''}</span>${p.desc}</div>`:''}
      ${(p.tags||[]).length?`<div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:4px;">${p.tags.map(t=>`<span style="font-size:11px;color:var(--b5);">#${t.replace(/^#/,'')}</span>`).join('')}</div>`:``}`;
  }

  // 댓글 목록
  renderPVComments(p);

  // 액션바
  const actions=document.getElementById('pv-actions');
  if(actions){
    actions.innerHTML=`
      <button onclick="pvToggleHeart(${p.id})"
        style="background:none;border:none;cursor:pointer;font-size:24px;transition:.15s;line-height:1;"
        onmouseover="this.style.transform='scale(1.25)'" onmouseout="this.style.transform='scale(1)'"
        title="좋아요">${liked?'❤️':'🤍'}</button>
      <span style="font-size:13px;font-weight:600;color:var(--ink2);" id="pv-heart-count">${(p.hearts||[]).length}</span>
      <span style="color:var(--bd);font-size:18px;margin:0 2px;">·</span>
      <span style="font-size:15px;">👁</span>
      <span style="font-size:12.5px;color:var(--ink3);margin-left:2px;">${p.views||0}</span>
      <span style="color:var(--bd);font-size:18px;margin:0 2px;">·</span>
      <button onclick="openSharePost(${p.id})"
        style="background:none;border:none;cursor:pointer;font-size:19px;line-height:1;"
        title="공유">🔗</button>
      <span style="margin-left:auto;font-size:10.5px;color:var(--ink3);opacity:.55;">${!p.saveAllow?'💾 저장불가':'💾 저장허용'}</span>`;
  }

  // 댓글 입력 아바타
  const avEl=document.getElementById('pv-commenter-av');
  if(avEl){
    avEl.innerHTML=S.currentUser
      ?(S.currentUser.avatarUrl
        ?`<img src="${S.currentUser.avatarUrl}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`
        :S.currentUser.name[0])
      :'👤';
  }
  const inp=document.getElementById('pv-comment-input');
  if(inp)inp.value='';
}

function renderPVComments(p){
  const list=document.getElementById('pv-comment-list');
  if(!list)return;
  const comments=p.comments||[];
  if(!comments.length){
    list.innerHTML=`<div style="text-align:center;padding:28px 0;color:var(--ink3);font-size:12.5px;">아직 댓글이 없습니다.<br>첫 댓글을 달아보세요 ✨</div>`;
    return;
  }
  list.innerHTML=comments.map(c=>{
    const from=S.users.find(u=>u.id===c.userId);
    const isMe=S.currentUser?.id===c.userId||S.currentUser?.isOwner;
    const avHtml=from?.avatarUrl
      ?`<img src="${from.avatarUrl}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`
      :`${(from?.name||'?')[0]}`;
    const liked=(c.likes||[]).includes(S.currentUser?.id);
    return`<div style="display:flex;gap:9px;align-items:flex-start;">
      <div class="av" style="width:30px;height:30px;font-size:10px;flex-shrink:0;">${avHtml}</div>
      <div style="flex:1;min-width:0;">
        <div style="font-size:12.5px;line-height:1.65;color:var(--ink2);">
          <span style="font-weight:600;color:var(--ink);margin-right:5px;">${from?.name||'알 수 없음'}</span>${c.text}
        </div>
        <div style="display:flex;align-items:center;gap:12px;margin-top:5px;">
          <span style="font-size:10.5px;color:var(--ink3);">${c.date||''}</span>
          <button onclick="pvLikeComment(${p.id},${c.id})"
            style="background:none;border:none;cursor:pointer;font-size:11.5px;color:${liked?'#e74c3c':'var(--ink3)'};padding:0;display:flex;align-items:center;gap:3px;">
            ${liked?'❤️':'🤍'} <span>${(c.likes||[]).length||''}</span>
          </button>
          ${isMe?`<button onclick="pvDeleteComment(${p.id},${c.id})"
            style="background:none;border:none;cursor:pointer;font-size:10.5px;color:var(--ink3);padding:0;opacity:.6;">삭제</button>`:''}
        </div>
      </div>
    </div>`;
  }).join('');
  // 댓글 영역 스크롤 아래로
  const wrap=document.getElementById('pv-comments-wrap');
  if(wrap)setTimeout(()=>wrap.scrollTop=wrap.scrollHeight,60);
}

function pvSubmitComment(){
  if(!S.currentUser){toast('로그인 후 댓글을 달 수 있습니다.','err');return;}
  const inp=document.getElementById('pv-comment-input');
  const text=inp?.value?.trim();
  if(!text)return;
  const p=(S.communityPosts||[]).find(x=>x.id===_pvPostId);
  if(!p)return;
  if(!p.comments)p.comments=[];
  p.comments.push({
    id:Date.now(),userId:S.currentUser.id,userName:S.currentUser.name,
    text,likes:[],date:new Date().toLocaleDateString('ko-KR')
  });
  save();
  if(inp)inp.value='';
  renderPVComments(p);
  renderCommunity();
}

function pvToggleHeart(postId){
  if(!S.currentUser){toast('로그인이 필요합니다.','err');return;}
  const p=(S.communityPosts||[]).find(x=>x.id===postId);if(!p)return;
  if(!p.hearts)p.hearts=[];
  const idx=p.hearts.indexOf(S.currentUser.id);
  if(idx>=0)p.hearts.splice(idx,1);else p.hearts.push(S.currentUser.id);
  save();renderPostViewer(p);renderCommunity();
}

function pvLikeComment(postId,commentId){
  if(!S.currentUser){toast('로그인이 필요합니다.','err');return;}
  const p=(S.communityPosts||[]).find(x=>x.id===postId);if(!p)return;
  const c=(p.comments||[]).find(x=>x.id===commentId);if(!c)return;
  if(!c.likes)c.likes=[];
  const idx=c.likes.indexOf(S.currentUser.id);
  if(idx>=0)c.likes.splice(idx,1);else c.likes.push(S.currentUser.id);
  save();renderPVComments(p);
}

function pvDeleteComment(postId,commentId){
  const p=(S.communityPosts||[]).find(x=>x.id===postId);if(!p)return;
  p.comments=(p.comments||[]).filter(c=>c.id!==commentId);
  save();renderPVComments(p);renderCommunity();
}

function closePostViewer(){
  const viewer=document.getElementById('postViewer');
  if(viewer)viewer.style.display='none';
  document.body.style.overflow='';
  const video=document.querySelector('#pv-media video');
  if(video)video.pause();
  _pvPostId=null;
}

// ESC로 닫기
document.addEventListener('keydown',e=>{if(e.key==='Escape'&&_pvPostId!==null)closePostViewer();});
// 배경 클릭으로 닫기
setTimeout(()=>{
  document.getElementById('postViewer')?.addEventListener('click',function(e){
    if(e.target===this)closePostViewer();
  });
},500);

// 기존 함수 호환
function openComments(postId){openPostLightbox(postId);}
function submitComment(){pvSubmitComment();}

function toggleHeart(postId){
  if(!S.currentUser){toast('로그인 필요','err');return;}
  const p=(S.communityPosts||[]).find(x=>x.id===postId);if(!p)return;
  if(!p.hearts)p.hearts=[];
  const idx=p.hearts.indexOf(S.currentUser.id);
  if(idx>=0)p.hearts.splice(idx,1);else p.hearts.push(S.currentUser.id);
  save();renderCommunity();
}

function deleteCommunityPost(id){
  S.communityPosts=(S.communityPosts||[]).filter(p=>p.id!==id);
  save();toast('게시물이 삭제되었습니다.','ok');renderCommunity();
}

function openLB(src){
  const lb=document.getElementById('lightbox');
  if(!lb)return;
  lb.innerHTML=`<img src="${src}" alt="" style="max-width:90vw;max-height:90vh;border-radius:var(--r);box-shadow:0 20px 60px rgba(0,0,0,.8);" onclick="event.stopPropagation()">`;
  lb.classList.add('open');
}
function closeLB(){
  const lb=document.getElementById('lightbox');
  if(lb){lb.classList.remove('open');lb.innerHTML='';}
}



// ══════════════════════════════════════════════════════
//  팔로우 시스템
// ══════════════════════════════════════════════════════
function toggleFollow(targetId){
  if(!S.currentUser){toast('로그인 필요','err');return;}
  if(!S.currentUser.following)S.currentUser.following=[];
  const idx=S.currentUser.following.indexOf(targetId);
  const target=S.users.find(x=>x.id===targetId);
  if(idx>=0){
    S.currentUser.following.splice(idx,1);
    if(target)target.followers=Math.max(0,(target.followers||0)-1);
    toast('팔로우 취소','ok');
  } else {
    S.currentUser.following.push(targetId);
    if(target)target.followers=(target.followers||0)+1;
    toast(`${target?.name||''}님을 팔로우했습니다! 💚`,'ok');
  }
  const idx2=S.users.findIndex(x=>x.id===S.currentUser.id);
  if(idx2>=0)S.users[idx2].following=S.currentUser.following;
  save();
}

function isFollowing(targetId){ return (S.currentUser?.following||[]).includes(targetId); }

// ══════════════════════════════════════════════════════
//  유저 프로필 페이지
// ══════════════════════════════════════════════════════
function viewMyPublicProfile(){
  if(!S.currentUser)return;
  S.selectedUserId=S.currentUser.id;
  goto('userprofile');
  setTimeout(()=>applyUserProfileDecorations(S.currentUser),150);
}
function viewUserProfile(userId){
  S.selectedUserId=userId;goto('userprofile');
}

function renderUserProfile(){
  const cont=document.getElementById('userProfileContent');if(!cont)return;
  const u=S.users.find(x=>x.id===S.selectedUserId);
  if(!u){cont.innerHTML='<p style="color:var(--ink3);padding:30px;">유저를 찾을 수 없습니다.</p>';return;}
  const myComms=S.commissions.filter(c=>c.artistId===u.id&&!c.hidden);
  const posts=(S.communityPosts||[]).filter(p=>p.userId===u.id&&!p.adult);
  const following=isFollowing(u.id);
  const isSelf=S.currentUser?.id===u.id;
  // 커미션 타입별 작업 수 집계
  const typeCounts={};
  myComms.forEach(c=>c.types.forEach(t=>{typeCounts[t]=(typeCounts[t]||0)+c.filledSlots;}));
  const equipped=u.equipped||{};
  cont.innerHTML=`
    <button onclick="goBack()" style="display:inline-flex;align-items:center;gap:5px;background:none;border:none;cursor:pointer;font-size:12px;color:var(--ink3);margin-bottom:18px;font-family:var(--fn);">← 뒤로</button>
    <!-- 프로필 헤더 -->
    <div style="background:var(--sf);border:1px solid var(--bd);border-radius:var(--rl);padding:24px;margin-bottom:20px;position:relative;overflow:hidden;" id="uprofHeader">
      <!-- 배경 캔버스 자리 (JS가 삽입) -->
      <div style="display:flex;align-items:flex-start;gap:16px;flex-wrap:wrap;position:relative;z-index:1;">
        <div style="position:relative;width:72px;height:72px;flex-shrink:0;">
          <div class="pav" style="width:72px;height:72px;font-size:22px;margin:0;font-family:var(--fs);" id="uprofAv">${u.avatarUrl?`<img src="${u.avatarUrl}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`:`${u.name[0]}`}</div>
          <!-- 프레임 SVG 자리 (JS가 삽입) -->
        </div>
        <div style="flex:1;min-width:160px;position:relative;z-index:2;">
          <div style="font-family:var(--fs);font-size:20px;font-weight:600;color:var(--ink);margin-bottom:2px;text-shadow:0 1px 4px rgba(0,0,0,0.5);">${u.name}${u.plan!=='free'?`<span class="pb ${u.plan==='ultra'?'pb-u':'pb-p'}">${u.plan.toUpperCase()}</span>`:''}</div>
          <div style="font-size:11.5px;color:var(--ink2);margin-bottom:8px;">${u.handle} · 가입일 ${u.createdAt}</div>
          ${u.bio?`<div style="font-size:12.5px;color:var(--ink2);line-height:1.6;margin-bottom:8px;background:rgba(0,0,0,0.25);border-radius:6px;padding:6px 9px;">${u.bio}</div>`:''}
          <div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:10px;">${(u.tags||[]).map(t=>`<span class="tag">${t}</span>`).join('')}</div>
          <div style="display:flex;gap:16px;">
            <div style="text-align:center;"><div style="font-size:16px;font-weight:700;color:var(--ta);">${u.done}</div><div style="font-size:9.5px;color:var(--ink3);">완료</div></div>
            <div style="text-align:center;"><div style="font-size:16px;font-weight:700;color:var(--ta);">${u.followers||0}</div><div style="font-size:9.5px;color:var(--ink3);">팔로워</div></div>
            <div style="text-align:center;"><div style="font-size:16px;font-weight:700;color:var(--ta);">${myComms.length}</div><div style="font-size:9.5px;color:var(--ink3);">커미션</div></div>
          </div>
        </div>
        ${!isSelf?`<div style="display:flex;flex-direction:column;gap:7px;">
          <button class="btn ${following?'btn-ghost':'btn-teal'}" onclick="toggleFollow(${u.id});renderUserProfile();">${following?'✓ 팔로잉':'+ 팔로우'}</button>
          ${(u.role==='artist'||u.role==='both')?`<button class="btn btn-ghost btn-sm" onclick="requireLogin(()=>{openInquiryFor(${u.id});})">💬 문의</button>`:''}
          <button class="btn btn-ghost btn-sm" style="color:#e87;" onclick="requireLogin(()=>openReport(${u.id},'${u.name}','기타'))">🚨 신고</button>
          <button class="btn btn-ghost btn-sm" onclick="openShare('user',${u.id},'${u.name}')">🔗 공유</button>
        </div>`:''}
      </div>
    </div>
    <!-- 슬롯 현황 (작가 본인 또는 다른 사람이 볼 때) -->
    ${(u.role==='artist'||u.role==='both')?`
    <div class="cc" style="margin-bottom:14px;">
      <div class="cct">🔢 슬롯 현황</div>
      <div style="font-size:12px;color:var(--ink3);margin-bottom:8px;">현재 슬롯 <span style="color:var(--tc);font-weight:600;">${myComms.reduce((s,c)=>s+c.filledSlots,0)}/${getEffectiveSlots(u)}</span> 사용 중</div>
      <div style="display:flex;gap:4px;flex-wrap:wrap;">
        ${Array.from({length:getEffectiveSlots(u)},(_,i)=>{const used=i<myComms.reduce((s,c)=>s+c.filledSlots,0);return`<div style="width:18px;height:9px;border-radius:3px;background:${used?'linear-gradient(90deg,var(--ta),var(--b4))':'var(--bd)'};border:1px solid ${used?'var(--ta)':'var(--bd2)'}"></div>`}).join('')}
      </div>
    </div>`:''}
    <!-- 커미션 타입별 작업 수 -->
    ${(u.role==='artist'||u.role==='both')&&myComms.length?`
    <div class="cc" style="margin-bottom:16px;">
      <div class="cct">🎨 커미션 타입</div>
      <div style="display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;">
        ${[...new Set(myComms.flatMap(c=>c.types))].map(t=>`
          <div style="padding:6px 12px;background:rgba(86,201,172,0.08);border:1px solid rgba(86,201,172,0.2);border-radius:20px;font-size:12px;color:var(--tc);">
            ${t}
          </div>`).join('')}
      </div>
      <div style="display:flex;flex-direction:column;gap:8px;">
        ${Object.entries(typeCounts).map(([type,cnt])=>`
          <div style="display:flex;align-items:center;gap:10px;">
            <span style="font-size:12px;color:var(--ink2);min-width:130px;">${type}</span>
            <div style="flex:1;height:6px;background:var(--bg2);border-radius:3px;overflow:hidden;">
              <div style="width:${Math.min(100,cnt*15)}%;height:100%;background:linear-gradient(90deg,var(--ta),var(--b4));border-radius:3px;transition:.4s;"></div>
            </div>
            <span style="font-size:11.5px;font-weight:600;color:var(--tc);min-width:28px;text-align:right;">${cnt}건</span>
          </div>`).join('')}
      </div>
    </div>`:''}
    <!-- 등록 커미션 -->
    ${myComms.length?`<div class="sec-ttl" style="margin-bottom:14px;">🎨 등록 커미션 (${myComms.length})</div><div class="card-grid" style="margin-bottom:20px;">${myComms.slice(0,4).map(c=>commCard(c,true)).join('')}</div>`:''}
    <!-- 커뮤니티 게시물 -->
    ${posts.length?`<div class="sec-ttl" style="margin-bottom:14px;">🖼️ 게시물 (${posts.length})</div><div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;">${posts.slice(0,6).map(p=>communityCard(p)).join('')}</div>`:''}
  `;
}

// ══════════════════════════════════════════════════════
//  공유 기능
// ══════════════════════════════════════════════════════
function openShare(type, id, name){
  const base=window.location.href.split('?')[0];
  const url=`${base}?share=${type}&id=${id}`;
  document.getElementById('shareUrl').value=url;
  openM('mShare');
  window._shareUrl=url;
  window._shareName=name;
}
function openSharePost(postId){
  openShare('post',postId,'커뮤니티 게시물');
}
function copyShareUrl(){
  const url=document.getElementById('shareUrl')?.value;
  if(!url)return;
  navigator.clipboard.writeText(url).then(()=>toast('링크가 복사되었습니다! 🔗','ok')).catch(()=>{
    document.getElementById('shareUrl').select();document.execCommand('copy');
    toast('링크가 복사되었습니다! 🔗','ok');
  });
}
function shareToTwitter(){
  const url=encodeURIComponent(window._shareUrl||'');
  const text=encodeURIComponent((window._shareName||'KIMAS')+'을 확인해보세요!');
  window.open(`https://twitter.com/intent/tweet?text=${text}&url=${url}`,'_blank');
}
function shareToKakao(){
  copyShareUrl();toast('링크를 복사했습니다. 카카오톡에 붙여넣기 하세요.','ok');
}

// 커미션/작가 공유 버튼 (commCard에서 사용)
function shareComm(commId, title){
  openShare('commission',commId,title);
}
function shareArtist(artistId, name){
  openShare('artist',artistId,name);
}

// 공유 링크로 접근 시 처리
function handleShareRoute(){
  const p=new URLSearchParams(window.location.search);
  const type=p.get('share'),id=parseInt(p.get('id'));
  if(!type||!id)return;
  window.history.replaceState({},'',window.location.pathname);
  if(type==='artist'||type==='commission'){
    S.selectedArtistId=id;
    setTimeout(()=>goto('artist-detail'),100);
  } else if(type==='user'){
    S.selectedUserId=id;
    setTimeout(()=>goto('userprofile'),100);
  } else if(type==='post'){
    // 커뮤니티 페이지 이동 후 해당 게시물 뷰어 자동 열기
    setTimeout(()=>{
      goto('community');
      setTimeout(()=>{
        const post=(S.communityPosts||[]).find(x=>x.id===id);
        if(post){
          openPostLightbox(id);
        } else {
          // 게시물이 없으면 카드 강조
          const el=document.querySelector(`[data-post-id="${id}"]`);
          if(el){
            el.scrollIntoView({behavior:'smooth',block:'center'});
            el.style.outline='2px solid var(--tc)';
            setTimeout(()=>el.style.outline='',3000);
          } else {
            toast('게시물을 찾을 수 없습니다. 삭제되었거나 비공개 게시물입니다.','err');
          }
        }
      },400);
    },100);
  }
}

// ══════════════════════════════════════════════════════
//  테마 설정
// ══════════════════════════════════════════════════════
const THEMES={
  dark:{bg:'#111418',bg2:'#161b20',bg3:'#1b2028',sf:'#1a2028',sf2:'#1f2630',sf3:'#242c38'},
  darker:{bg:'#08090c',bg2:'#0c0e12',bg3:'#101318',sf:'#111520',sf2:'#151920',sf3:'#191e28'},
  warm:{bg:'#141210',bg2:'#1a1815',bg3:'#201e1a',sf:'#1e1c18',sf2:'#242018',sf3:'#2a261e'},
  cool:{bg:'#0e1520',bg2:'#121a28',bg3:'#161f30',sf:'#162030',sf2:'#1b2638',sf3:'#202c40'},
  light:{bg:'#f0f2f5',bg2:'#e8eaed',bg3:'#e0e3e8',sf:'#ffffff',sf2:'#f5f6f8',sf3:'#eceef2'},
};
const ACCENTS={
  teal:   {tc:'#4fbd95',ta:'#3da07a',tb:'#44ae87',t900:'#36936e',t800:'#318663',t700:'#2b7958'},
  gold:   {tc:'#fcd94a',ta:'#e8b800',tb:'#f0c800',t900:'#c99e00',t800:'#a08000',t700:'#786000'},
  oriental:{tc:'#d4845a',ta:'#c0603a',tb:'#cc7248',t900:'#a0482a',t800:'#88361e',t700:'#702814'},
  blue:   {tc:'#4d96ff',ta:'#3a7de8',tb:'#4488f0',t900:'#2d66cc',t800:'#2558b8',t700:'#1e4aa4'},
  skyblue:{tc:'#38bdf8',ta:'#0ea5e9',tb:'#22c3f8',t900:'#0284c7',t800:'#0369a1',t700:'#075985'},
  purple: {tc:'#a855f7',ta:'#9333ea',tb:'#a043f0',t900:'#7e22ce',t800:'#6b21a8',t700:'#581c87'},
  violet: {tc:'#818cf8',ta:'#6366f1',tb:'#7577f4',t900:'#4f46e5',t800:'#4338ca',t700:'#3730a3'},
  pink:   {tc:'#f472b6',ta:'#ec4899',tb:'#f060a8',t900:'#be185d',t800:'#9d174d',t700:'#831843'},
  green:  {tc:'#4ade80',ta:'#22c55e',tb:'#38d870',t900:'#15803d',t800:'#166534',t700:'#14532d'},
  orange: {tc:'#fb923c',ta:'#f97316',tb:'#fa8a28',t900:'#c2410c',t800:'#9a3412',t700:'#7c2d12'},
};

function applyTheme(name){
  const t=THEMES[name];if(!t)return;
  const root=document.documentElement;
  Object.entries(t).forEach(([k,v])=>root.style.setProperty('--'+k,v));
  if(name==='light'){
    root.style.setProperty('--ink','#1a2028');
    root.style.setProperty('--ink2','#374151');
    root.style.setProperty('--ink3','#6b7280');
    root.style.setProperty('--bd','rgba(0,0,0,0.1)');
    root.style.setProperty('--bd2','rgba(63,160,122,0.3)');
  } else {
    root.style.setProperty('--ink','#e8f0ed');
    root.style.setProperty('--ink2','#a8c4bb');
    root.style.setProperty('--ink3','#6a9a8e');
    root.style.setProperty('--bd','rgba(255,255,255,0.07)');
    root.style.setProperty('--bd2','rgba(79,189,149,0.22)');
  }
  if(S.currentUser){if(!S.currentUser.prefs)S.currentUser.prefs={};S.currentUser.prefs.theme=name;save();}
  document.querySelectorAll('.theme-swatch').forEach((s,i)=>s.classList.toggle('active',i===['dark','darker','warm','cool','light'].indexOf(name)));
}

function applyAccent(name){
  const a=ACCENTS[name];if(!a)return;
  const root=document.documentElement;
  Object.entries(a).forEach(([k,v])=>root.style.setProperty('--'+k,v));
  // 금색 포인트 별도 처리
  if(name==='gold'){
    root.style.setProperty('--g200','#fcd94a');root.style.setProperty('--g300','#e8b800');
  }
  if(S.currentUser){if(!S.currentUser.prefs)S.currentUser.prefs={};S.currentUser.prefs.accent=name;save();}
}

function setFontSize(size){
  document.documentElement.style.setProperty('font-size',size+'px');
  if(S.currentUser){if(!S.currentUser.prefs)S.currentUser.prefs={};S.currentUser.prefs.fontSize=size;save();}
}

function restoreUserPrefs(){
  const prefs=S.currentUser?.prefs;
  if(prefs){
    if(prefs.theme)applyTheme(prefs.theme);
    if(prefs.accent)applyAccent(prefs.accent);
    if(prefs.fontSize)setFontSize(prefs.fontSize);
  }
  // 장착 아이템 전체 복원
  const eq=S.currentUser?.equipped||{};
  // 슬롯 스킨
  if(eq.slotSkin){const si=SLOT_ITEMS.find(x=>x.id===eq.slotSkin);if(si)applySlotSkin(si.value);}
  // 프레임 (DOM 렌더 후 적용)
  if(eq.frame){const fi=PROFILE_ITEMS.find(x=>x.id===eq.frame);if(fi)setTimeout(()=>applyProfileFrame(fi.value),100);}
  // 배경
  if(eq.bg){const bi=PROFILE_ITEMS.find(x=>x.id===eq.bg);if(bi)setTimeout(()=>applyProfileBg(bi.value),100);}
  // 뱃지
  // 반짝이
}

// ══════════════════════════════════════════════════════
//  성인 인증 시스템
// ══════════════════════════════════════════════════════
function toggleAdultCommunity(){
  if(!S.currentUser){toast('로그인이 필요합니다.','err');return;}
  if(S.showAdultContent){
    S.showAdultContent=false;
    document.getElementById('commAgeBtn').textContent='🔞 성인 콘텐츠 보기';
    renderCommunity();return;
  }
  // 성인 경고 팝업
  document.getElementById('adultWarning').style.display='flex';
}
function closeAdultWarning(){
  document.getElementById('adultWarning').style.display='none';
}
function startPassVerification(){
  closeAdultWarning();
  // PASS 실제 연동은 백엔드 필요
  // 실제 배포 시: https://developers.niceapi.co.kr/ 또는 KT/SKT/LGU+ PASS API 사용
  const modal=document.createElement('div');
  modal.id='passModal';
  modal.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:5001;display:flex;align-items:center;justify-content:center;padding:16px;';
  modal.innerHTML=`<div style="background:var(--bg2);border:1px solid var(--bdg);border-radius:var(--rl);padding:28px;max-width:380px;width:100%;text-align:center;">
    <div style="font-size:40px;margin-bottom:12px;">📱</div>
    <div style="font-family:var(--fs);font-size:17px;font-weight:600;color:var(--tc);margin-bottom:8px;">PASS 본인인증</div>
    <div style="font-size:12.5px;color:var(--ink2);line-height:1.75;margin-bottom:16px;">
      실제 서비스에서는 KT·SKT·LG U+ PASS 앱을 통해 인증합니다.
    </div>
    <div style="background:rgba(232,184,0,0.08);border:1px solid var(--bdg);border-radius:8px;padding:10px 13px;margin-bottom:18px;font-size:11.5px;color:var(--g300);line-height:1.6;">
      ⚠ 실제 배포 시 PASS 인증 API 연동이 필요합니다.<br>
      현재는 테스트 환경입니다.
    </div>
    <div style="display:flex;flex-direction:column;gap:9px;">
      <button style="width:100%;padding:12px;border-radius:9px;background:linear-gradient(135deg,#4fbd95,#3da07a);color:white;border:none;cursor:pointer;font-size:14px;font-weight:600;font-family:var(--fn);" onclick="completeAdultVerification()">✓ 인증 완료 (테스트 환경)</button>
      <button style="width:100%;padding:10px;border-radius:9px;background:transparent;color:var(--ink2);border:1px solid var(--bd);cursor:pointer;font-size:13px;font-family:var(--fn);" onclick="document.getElementById('passModal').remove()">취소</button>
    </div>
  </div>`;
  document.body.appendChild(modal);
}
function completeAdultVerification(){
  const modal=document.getElementById('passModal');
  if(modal)modal.remove();
  if(!S.currentUser)return;
  S.currentUser.adultVerified=true;
  const idx=S.users.findIndex(x=>x.id===S.currentUser.id);if(idx>=0)S.users[idx].adultVerified=true;
  S.showAdultContent=true;
  save();
  toast('성인 인증 완료! 성인 콘텐츠를 이용할 수 있습니다.','ok');
  document.getElementById('commAgeBtn').textContent='🔞 성인 콘텐츠 숨기기';
  renderCommunity();
}

// 구해요 성인글 토글
function toggleAdultSeeking(btn){
  if(!S.currentUser){toast('로그인 필요','err');return;}
  S.showAdultSeeking=!S.showAdultSeeking;
  if(S.showAdultSeeking&&!S.currentUser.adultVerified){
    S.showAdultSeeking=false;
    document.getElementById('adultWarning').style.display='flex';
    window._adultTarget='seeking';
    return;
  }
  btn.textContent=S.showAdultSeeking?'🔞 성인글 숨기기':'🔞 성인글 보기';
  renderSeeking();
}

// ══════════════════════════════════════════════════════
//  추천 커미션 (커미션 하단)
// ══════════════════════════════════════════════════════
function renderRelatedComms(artistId, currentCommId){
  const related=S.commissions.filter(c=>!c.hidden&&c.id!==currentCommId).sort(()=>Math.random()-.5).slice(0,4);
  if(!related.length)return'';
  return`<div style="margin-top:36px;"><div class="sec-ttl" style="margin-bottom:16px;">🎨 비슷한 커미션</div><div class="card-grid">${related.map(c=>commCard(c)).join('')}</div></div>`;
}

// ══════════════════════════════════════════════════════
//  goto 확장
// ══════════════════════════════════════════════════════
const _origGoto=goto;
window.goto=function(name){
  _origGoto(name);
  if(name==='community')renderCommunity();
  if(name==='shop'){if(!S.currentUser){toast('상점은 로그인 후 이용 가능합니다.','err');openM('mLogin');return;}renderShop();}
  if(name==='userprofile'){renderUserProfile();const u=S.users.find(x=>x.id===S.selectedUserId);if(u)setTimeout(()=>applyUserProfileDecorations(u),100);}
};

// ══════════════════════════════════════════════════════
//  캡쳐 방지 (성인 콘텐츠)
// ══════════════════════════════════════════════════════
// ── 캡쳐 방지 (강화) ──
document.addEventListener('keyup',function(e){
  if(e.key==='PrintScreen'){
    toast('🚫 캡쳐가 차단되었습니다.','err');
    try{navigator.clipboard.writeText('');}catch(e){}
  }
});
// 우클릭 방지 (성인 콘텐츠 영역)
document.addEventListener('contextmenu',function(e){
  if(e.target.closest('.comm-post-img')&&S.showAdultContent){
    e.preventDefault();
    toast('🚫 이미지 저장이 제한되어 있습니다.','err');
  }
});
// 드래그 방지
document.addEventListener('dragstart',function(e){
  if(e.target.tagName==='IMG'&&e.target.closest('.comm-post-img')){
    const card=e.target.closest('.comm-post-card');
    const postId=card?.dataset?.postId;
    const p=(S.communityPosts||[]).find(x=>String(x.id)===postId);
    if(p&&!p.saveAllow){e.preventDefault();}
  }
});


// ── 태그 자동완성 시스템 ──
const TAG_LIST=['#일러스트','#캐릭터','#배경','#SD치비','#동양풍','#판타지','#현대풍','#SF','#공포',
  '#여성캐릭터','#남성캐릭터','#동물','#드래곤','#마법','#갑옷','#복고풍','#귀여운','#섹시한',
  '#애니풍','#리얼리즘','#수채화','#디지털아트','#흑백','#컬러풀','#파스텔','#다크',
  '#게임캐릭터','#OC','#팬아트','#커플','#그룹','#버추얼','#VTuber','#로고','#배너',
  '#GIF','#애니메이션','#배경화면','#포트폴리오','#SNS','#상업용','#비상업','#빠른납기'];

function initTagInput(inputId, suggestId){
  const inp=document.getElementById(inputId);
  const sug=document.getElementById(suggestId);
  if(!inp||!sug)return;
  inp.addEventListener('input',function(){
    const val=this.value;
    const lastHash=val.lastIndexOf('#');
    if(lastHash===-1){sug.style.display='none';return;}
    const partial=val.slice(lastHash).toLowerCase();
    const matches=TAG_LIST.filter(t=>t.toLowerCase().startsWith(partial)&&partial.length>0).slice(0,8);
    if(!matches.length){sug.style.display='none';return;}
    sug.style.display='flex';
    sug.innerHTML=matches.map(t=>`<button class="tag-suggest-btn" onclick="insertTag('${inputId}','${suggestId}','${t}')">${t}</button>`).join('');
  });
  inp.addEventListener('blur',function(){setTimeout(()=>{sug.style.display='none';},200);});
}

function insertTag(inputId, suggestId, tag){
  const inp=document.getElementById(inputId);if(!inp)return;
  const val=inp.value;
  const lastHash=val.lastIndexOf('#');
  inp.value=(lastHash>0?val.slice(0,lastHash):'')+tag+' ';
  const sug=document.getElementById(suggestId);if(sug)sug.style.display='none';
  inp.focus();
}


// ── 로그인 유지 ──
function doLogin(){
  const email=document.getElementById('lEmail')?.value?.trim();
  const pw=document.getElementById('lPw')?.value;
  const remember=document.getElementById('rememberMe')?.checked;
  if(!email||!pw){toast('이메일과 비밀번호를 입력해주세요.','err');return;}
  const u=S.users.find(u=>u.email===email&&u.pw===pw);
  if(!u){toast('이메일 또는 비밀번호가 올바르지 않습니다.','err');return;}
  if(u.banned){const until=u.banUntil?new Date(u.banUntil).toLocaleDateString('ko-KR'):'영구';toast(`이 계정은 정지되었습니다.\n만료: ${until}\n사유: ${u.banReason||'규정 위반'}`,'err');return;}
  S.currentUser=u;
  if(remember){try{localStorage.setItem('kimas_remember',JSON.stringify({email,pw}));}catch(e){}}
  save();closeM('mLogin');updateNav();
  toast(u.isOwner?'👑 운영자로 로그인했습니다.':u.name+'님, 환영합니다! 🎉','ok');
  restoreUserPrefs();
  goto(u.isOwner?'admin':'dashboard');
}

// ── Google 로그인 (Firebase Auth) ──
async function googleLogin(){
  if(!_firebaseAuth){
    toast('Firebase가 초기화 중입니다. 잠시 후 다시 시도해주세요.','err');
    return;
  }
  try {
    const provider = new firebase.auth.GoogleAuthProvider();
    provider.setCustomParameters({ prompt: 'select_account' });
    toast('Google 로그인 창을 여는 중...','ok');
    const result = await _firebaseAuth.signInWithPopup(provider);
    await handleGoogleResult(result);
  } catch(e){
    if(e.code==='auth/popup-closed-by-user'||e.code==='auth/cancelled-popup-request'){
      // 사용자가 닫음 — 무시
    } else if(e.code==='auth/popup-blocked'){
      toast('팝업이 차단됐어요!\n주소창 오른쪽 팝업 허용 아이콘을 클릭해주세요.','err');
    } else {
      toast('Google 로그인 실패: '+(e.message||e.code),'err');
      console.error('[KIMAS]',e);
    }
  }
}

async function handleGoogleResult(result){
  if(!result||!result.user)return;
  const gUser = result.user;

  // 이미 로그인 중이면 무시
  if(S.currentUser && (S.currentUser.email===gUser.email || S.currentUser.googleUid===gUser.uid)) {
    updateNav(); return;
  }

  // 기존 계정 찾기 (이메일 or googleUid)
  let existing = S.users.find(u => u.googleUid===gUser.uid || u.email===gUser.email);

  if(!existing){
    // 새 계정 생성
    const isOwner = gUser.email === 'cdk061201@gmail.com';
    const newUser = {
      id: Date.now(),
      name: gUser.displayName || gUser.email.split('@')[0],
      handle: '@' + (gUser.displayName||'user').replace(/\s/g,'').toLowerCase() + Math.floor(Math.random()*999),
      email: gUser.email,
      pw: '',
      avatarUrl: gUser.photoURL || null,
      role: 'client',
      plan: isOwner ? 'ultra' : 'free',
      isOwner,
      isAdmin: isOwner,
      bio: '',
      tags: [],
      done: 0,
      followers: 0,
      following: [],
      cash: 0,
      items: isOwner ? ['frame_gold','frame_teal','frame_rainbow','frame_night','bg_sakura','bg_galaxy','bg_ocean','slot_crystal','slot_fire','slot_night','slot_sakura'] : [],
      equipped: {},
      createdAt: new Date().toLocaleDateString('ko-KR'),
      googleUid: gUser.uid
    };
    S.users.push(newUser);
    existing = newUser;
    toast(`${gUser.displayName||gUser.email}님, 환영합니다! 🎉`,'ok');
  } else {
    // 기존 계정 업데이트
    existing.googleUid = gUser.uid;
    if(gUser.photoURL && !existing.avatarUrl) existing.avatarUrl = gUser.photoURL;
    toast(existing.isOwner ? '👑 운영자로 로그인했습니다.' : `${existing.name}님, 돌아오셨군요! 🎉`, 'ok');
  }

  S.currentUser = existing;
  save();
  closeM('mLogin');
  closeM('mSignup');
  updateNav();
  restoreUserPrefs();
  goto(existing.isOwner ? 'admin' : 'dashboard');
  setTimeout(()=>renderPbox(), 200);
}

// Firebase 자동 로그인 상태 감지 (페이지 로드 시)
function initFirebaseAuthListener(){
  if(!_firebaseAuth) return;
  _firebaseAuth.onAuthStateChanged(gUser => {
    if(gUser && !S.currentUser){
      // Firebase에 로그인된 상태인데 KIMAS는 로그아웃 상태 → 자동 로그인
      const existing = S.users.find(u => u.googleUid === gUser.uid || u.email === gUser.email);
      if(existing){
        S.currentUser = existing;
        save(); updateNav(); restoreUserPrefs();
        console.log('[KIMAS] Firebase 자동 로그인:', existing.name);
      }
    }
  });
}

// 자동 로그인 복원
function restoreRememberMe(){
  try{
    const saved=localStorage.getItem('kimas_remember');
    if(!saved)return;
    const {email,pw}=JSON.parse(saved);
    const u=S.users.find(x=>x.email===email&&x.pw===pw);
    if(u&&!u.banned){S.currentUser=u;save();updateNav();restoreUserPrefs();}
    else{localStorage.removeItem('kimas_remember');}
  }catch(e){}
}


// ── BOOT ──
if(!S.ads)S.ads=[];
if(!S.reports)S.reports=[];
if(!S.communityPosts)S.communityPosts=[];
if(!S.qnas)S.qnas=[];
if(!S.deleteLogs)S.deleteLogs=[];
handlePaymentSuccess();
handleAdPaymentSuccess();
handleCashPayment();
handleSlotExtPayment();
restoreRememberMe();
handleShareRoute();
restoreUserPrefs();
initFirebaseAuthListener();
setTimeout(()=>{ initTagInput('postTags','postTagsSug'); }, 300);
</script>
